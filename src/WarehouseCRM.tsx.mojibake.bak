  );
}

function TeamPage() {
  const engineerLoad = team.filter((person) => person.role.includes('Р†РЅР¶РµРЅРµСЂ'));
  return (
    <div className="page-grid">
      <PageTitle eyebrow="РЎРїС–РІСЂРѕР±С–С‚РЅРёРєРё" title="Р†РЅР¶РµРЅРµСЂРё С‚Р° РјРµРЅРµРґР¶РµСЂРё" text="РЈ РєРѕР¶РЅРѕРјСѓ СЂРµРјРѕРЅС‚С– РІРёРґРЅРѕ РІС–РґРїРѕРІС–РґР°Р»СЊРЅРѕРіРѕ С–РЅР¶РµРЅРµСЂР° С– РјРµРЅРµРґР¶РµСЂР°." />
      <section className="cards-grid">{team.map((person) => <article className="team-card" key={person.name}><div className="avatar">{person.name.slice(0, 1)}</div><h2>{person.name}</h2><p>{person.role}</p><div className="client-meta"><span>{person.active} Р·Р°РґР°С‡</span></div></article>)}</section>
      <section className="panel">
        <div className="panel-heading"><h2>РќР°РІР°РЅС‚Р°Р¶РµРЅРЅСЏ С–РЅР¶РµРЅРµСЂС–РІ</h2><span>{engineerLoad.length} С–РЅР¶РµРЅРµСЂС–РІ</span></div>
        <div className="task-list">
          {engineerLoad.map((person) => <Task key={person.name} icon={<Wrench />} title={person.name} text={`${person.active} Р°РєС‚РёРІРЅРёС… Р·Р°РґР°С‡. РљРµСЂС–РІРЅРёРє Р±Р°С‡РёС‚СЊ РЅР°РІР°РЅС‚Р°Р¶РµРЅРЅСЏ С– РјРѕР¶Рµ РїРµСЂРµРЅР°Р·РЅР°С‡РёС‚Рё Р·Р°РєР°Р·.`} />)}
        </div>
      </section>
    </div>
  );
}

