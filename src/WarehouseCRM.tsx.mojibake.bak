          <div className="panel-heading"><h2>РЎРµСЂРІС–СЃРЅС– РґРѕРєСѓРјРµРЅС‚Рё</h2><span>РЅР°СЂСЏРґ, С‚РµС…СЃС‚Р°РЅ, РіР°СЂР°РЅС‚С–СЏ</span></div>
          <div className="task-list">
            <Task icon={<ClipboardList />} title="РќР°СЂСЏРґ РЅР° СЂРµРјРѕРЅС‚" text={`в„– РќР -1001 В· РєР»С–С”РЅС‚ ${sampleOrder.client} В· РїСЂРёСЃС‚СЂС–Р№ ${sampleOrder.device} В· СЃРµСЂС–Р№РЅРёР№ РЅРѕРјРµСЂ ${sampleOrder.serial} В· РЅРµСЃРїСЂР°РІРЅС–СЃС‚СЊ: ${sampleOrder.issue} В· РїС–РґРїРёСЃРё РІРёРєРѕРЅР°РІС†СЏ, РјРµРЅРµРґР¶РµСЂР° С– РєР»С–С”РЅС‚Р°.`} />
            <Task icon={<ClipboardList />} title="РЁРІРёРґРєРёР№ РЅР°СЂСЏРґ" text="Р”Р»СЏ РєР°СЂС‚СЂРёРґР¶С–РІ: РєР»С–С”РЅС‚, РєР°СЂС‚СЂРёРґР¶, РІРёРґ СЂРѕР±РѕС‚Рё, СЂРµР·СѓР»СЊС‚Р°С‚, РїС–РґРїРёСЃРё РІРёРєРѕРЅР°РІС†СЏ С– РєР»С–С”РЅС‚Р°." />
            <Task icon={<X />} title="РђРєС‚ С‚РµС…РЅС–С‡РЅРѕРіРѕ СЃС‚Р°РЅСѓ" text="РљРѕРјС–СЃС–СЏ, РѕР±КјС”РєС‚, СЃРµСЂС–Р№РЅРёР№ РЅРѕРјРµСЂ, РґРµС„РµРєС‚Рё, РІРёСЃРЅРѕРІРѕРє: РЅРµ РїС–РґР»СЏРіР°С” СЂРµРјРѕРЅС‚Сѓ, РїС–РґРїРёСЃРё С‡Р»РµРЅС–РІ РєРѕРјС–СЃС–С—." />
            <Task icon={<ShieldCheck />} title="Р“Р°СЂР°РЅС‚С–Р№РЅРёР№ С‚Р°Р»РѕРЅ" text={`РџСЂРёСЃС‚СЂС–Р№ ${sampleOrder.device}, СЃРµСЂС–Р№РЅРёР№ РЅРѕРјРµСЂ ${sampleOrder.serial}, РґР°С‚Р° ${today}, С‚РµСЂРјС–РЅ РіР°СЂР°РЅС‚С–С—, СѓРјРѕРІРё, РїС–РґРїРёСЃ / РїРµС‡Р°С‚РєР°.`} />
            <Task icon={<Archive />} title="BAS" text="РЈ РєРѕР¶РЅРѕРјСѓ РґРѕРєСѓРјРµРЅС‚С– С” РґС–СЏ РџРµСЂРµРґР°С‚Рё РІ BAS. CRM РїРµСЂРµРґР°С” РєР»С–С”РЅС‚Р°, С‚РѕРІР°СЂРё / РїРѕСЃР»СѓРіРё, РєС–Р»СЊРєС–СЃС‚СЊ, СЃСѓРјРё, РџР”Р’, РЅРѕРјРµСЂ С– РґР°С‚Сѓ. РћС„С–С†С–Р№РЅР° РџРќ С– Р±СѓС…РіР°Р»С‚РµСЂСЃСЊРєС– РґРѕРєСѓРјРµРЅС‚Рё С„РѕСЂРјСѓСЋС‚СЊСЃСЏ РІ BAS." />
          </div>
        </div>
      </section>
      <section className="panel">
        <div className="panel-heading"><h2>Р РµС”СЃС‚СЂ РґРѕРєСѓРјРµРЅС‚С–РІ</h2><span>{documents.length} Р·Р°РїРёСЃС–РІ</span></div>
        <div className="table documents-table">
          <div className="table-row table-head"><span>РќРѕРјРµСЂ</span><span>РўРёРї</span><span>Р”Р¶РµСЂРµР»Рѕ</span><span>РљР»С–С”РЅС‚ / РїРѕСЃС‚Р°С‡Р°Р»СЊРЅРёРє</span><span>РЎС‚Р°С‚СѓСЃ</span><span>PDF / BAS</span></div>
          {documents.map((document) => (
            <div className="table-row" key={document.id}>
              <span>{document.number}<small>РІРµСЂСЃС–СЏ {document.version} В· {document.createdAt}</small></span>
              <span>{document.kind}</span>
              <span>{document.entityId}<small>{document.entityType}</small></span>
              <span>{document.clientOrSupplier}<small>{document.createdBy}</small></span>
              <span>{document.status}</span>
              <span>
                {document.pdfPath}
                <small>{document.amountGross ? `Р±РµР· РџР”Р’ ${money(document.amountNet ?? 0)} В· РџР”Р’ ${money(document.amountVat ?? 0)} В· Р· РџР”Р’ ${money(document.amountGross)}` : 'СЃСѓРјРё РЅРµ Р·Р°РґР°РЅС–'}</small>
                <button type="button">РџРµСЂРµРґР°С‚Рё РІ BAS</button>
                {document.status === 'Р§РµСЂРЅРµС‚РєР°' || document.status === 'Р“РѕС‚РѕРІРѕ' || document.status === 'РћС‡С–РєСѓС” РѕРїР»Р°С‚Рё' || document.status === 'Р“РѕС‚РѕРІРѕ РґРѕ РІРёРґР°С‡С–' ? <button type="button">Р РµРґР°РіСѓРІР°С‚Рё С‡РµСЂРЅРµС‚РєСѓ</button> : null}
                {document.status !== 'РџС–РґРїРёСЃР°РЅРѕ' ? <button type="button">РџРµСЂРµСЃРѕР·РґР°С‚Рё</button> : null}
                {document.status === 'Р§РµСЂРЅРµС‚РєР°' ? <button type="button">Р’РёРґР°Р»РёС‚Рё С‡РµСЂРЅРµС‚РєСѓ</button> : null}
              </span>
            </div>
          ))}
        </div>
        {documents.length === 0 && <div className="empty-state">Р”РѕРєСѓРјРµРЅС‚Рё С‰Рµ РЅРµ СЃС‚РІРѕСЂРµРЅС–. Р РµС”СЃС‚СЂ РЅРµ СЃС‚РІРѕСЂСЋС” С—С… РІСЂСѓС‡РЅСѓ: РІС–РґРєСЂРёР№С‚Рµ Р·Р°РјРѕРІР»РµРЅРЅСЏ, РїСЂРѕРґР°Р¶ Р°Р±Рѕ Р·Р°РєСѓРїРєСѓ С– РЅР°С‚РёСЃРЅС–С‚СЊ РїРѕС‚СЂС–Р±РЅСѓ РєРЅРѕРїРєСѓ РїСЂРѕС†РµСЃСѓ.</div>}
      </section>
      <section className="panel">
        <div className="panel-heading"><h2>РЁР°Р±Р»РѕРЅРё РґСЂСѓРєРѕРІР°РЅРёС… С„РѕСЂРј</h2><span>Р»РѕРіРѕС‚РёРї, СЂРµРєРІС–Р·РёС‚Рё, РїС–РґРїРёСЃРё, РїРµС‡Р°С‚РєР°</span></div>
        <div className="task-list">
          {templates.map((template) => (
            <Task key={template.kind} icon={<ClipboardList />} title={template.kind} text={`${template.description} ${template.lockedRule}`} />
          ))}
        </div>
      </section>
    </div>
  );
}

function TaxInvoicesPage({ invoices, orders }: { invoices: TaxInvoice[]; orders: ServiceOrder[] }) {
  const ready = invoices.filter((invoice) => invoice.status === 'Р“РѕС‚РѕРІРѕ РґРѕ СЂРµС”СЃС‚СЂР°С†С–С—');
  const overdue = invoices.filter((invoice) => invoice.status === 'РџСЂРѕСЃС‚СЂРѕС‡РµРЅРѕ');
  const stopped = invoices.filter((invoice) => ['РџРѕРјРёР»РєР°', 'Р—СѓРїРёРЅРµРЅРѕ'].includes(invoice.status));

  return (
    <div className="page-grid">
      <PageTitle eyebrow="РџРѕРґР°С‚РєРѕРІС– РЅР°РєР»Р°РґРЅС–" title="РќР”РЎ Р±РµР· РїРµСЂРµРЅРѕСЃСѓ РїРµСЂС–РѕРґСѓ" text="РђРєС‚ РІРёРґР°РЅРѕ РєР»С–С”РЅС‚Сѓ РѕР·РЅР°С‡Р°С” РїРѕРґР°С‚РєРѕРІСѓ РїРѕРґС–СЋ. РћРїР»Р°С‚Р° РІРїР»РёРІР°С” РЅР° РґРµР±С–С‚РѕСЂРєСѓ, Р°Р»Рµ РЅРµ РїРµСЂРµРЅРѕСЃРёС‚СЊ СЂРµС”СЃС‚СЂР°С†С–СЋ РџРќ." />
      <section className="stats-grid">
        <Metric icon={<ClipboardList />} label="Р“РѕС‚РѕРІРѕ РґРѕ СЂРµС”СЃС‚СЂР°С†С–С—" value={String(ready.length)} hint="Р°РєС‚ РІР¶Рµ РІРёРґР°РЅРѕ" />
        <Metric icon={<History />} label="РџСЂРѕСЃС‚СЂРѕС‡РµРЅРѕ" value={String(overdue.length)} hint="РїРѕС‚СЂС–Р±РЅР° РґС–СЏ Р±СѓС…РіР°Р»С‚РµСЂР°" />
        <Metric icon={<X />} label="РџРѕРјРёР»РєРё / Р·СѓРїРёРЅРµРЅРѕ" value={String(stopped.length)} hint="РѕРєСЂРµРјРёР№ РєРѕРЅС‚СЂРѕР»СЊ" />
        <Metric icon={<Banknote />} label="РџР”Р’ РґРѕ РєРѕРЅС‚СЂРѕР»СЋ" value={money(invoices.reduce((sum, item) => sum + item.vatAmount, 0))} hint="Р·Р° С‡РµСЂРЅРµС‚РєР°РјРё РџРќ" />
      </section>
      <section className="quick-actions">
        <button type="button">РџРµСЂРµРІС–СЂРёС‚Рё С‡РµСЂРЅРµС‚РєСѓ РџРќ</button>
        <button type="button">РџС–РґРїРёСЃР°С‚Рё С– РІС–РґРїСЂР°РІРёС‚Рё</button>
        <button type="button">Р—Р°РІР°РЅС‚Р°Р¶РёС‚Рё РєРІРёС‚Р°РЅС†С–СЋ</button>
        <button type="button">РџР°РєРµС‚РЅР° СЂРµС”СЃС‚СЂР°С†С–СЏ</button>
      </section>
      <section className="panel">
        <div className="panel-heading"><h2>РђРІС‚РѕРјР°С‚РёС‡РЅС– С‡РµСЂРЅРµС‚РєРё РџРќ</h2><span>РїРµСЂС€РёР№ РµС‚Р°Рї: РїРµСЂРµРІС–СЂРєР° Р±СѓС…РіР°Р»С‚РµСЂРѕРј</span></div>
        <div className="task-list">
          {ready.map((invoice) => {
            const order = orders.find((item) => item.id === invoice.orderId);
            return (
              <Task
                key={`draft-${invoice.id}`}
                icon={<ClipboardList />}
                title={`${invoice.id} В· ${invoice.client}`}
                text={`РџС–РґС‚СЏРіРЅСѓС‚Рѕ: РєР»С–С”РЅС‚ С– СЂРµРєРІС–Р·РёС‚Рё Р· РєР°СЂС‚РєРё, СЃСѓРјР° ${money(invoice.amount)}, РґР°С‚Р° РїРѕРґС–С— ${invoice.eventDate}, Р·Р°РєР°Р· ${invoice.orderId}, Р°РєС‚ ${order?.actIssuedAt ?? invoice.eventDate}, РџР”Р’ ${money(invoice.vatAmount)}. Р‘СѓС…РіР°Р»С‚РµСЂ РїРµСЂРµРІС–СЂСЏС” С– РІСЂСѓС‡РЅСѓ РїС–РґРїРёСЃСѓС” / РІС–РґРїСЂР°РІР»СЏС”.`}
              />
            );
          })}
          {ready.length === 0 && <div className="empty-state">Р§РµСЂРЅРµС‚РѕРє РџРќ РґР»СЏ РїРµСЂРµРІС–СЂРєРё Р·Р°СЂР°Р· РЅРµРјР°С”.</div>}
        </div>
      </section>
      <section className="panel">
        <div className="panel-heading"><h2>Р РµС”СЃС‚СЂ РџРќ</h2><span>РЅР°РїС–РІР°РІС‚РѕРјР°С‚РёС‡РЅРёР№ СЂРµР¶РёРј</span></div>
        <div className="table tax-table">
          <div className="table-row table-head"><span>РџРќ</span><span>Р—Р°РєР°Р·</span><span>РљР»С–С”РЅС‚</span><span>РџРѕРґС–СЏ</span><span>Р”РµРґР»Р°Р№РЅ</span><span>РЎСѓРјР° / РџР”Р’</span><span>РЎС‚Р°С‚СѓСЃ</span></div>
          {invoices.map((invoice) => {
            const order = orders.find((item) => item.id === invoice.orderId);
            const daysLeft = daysSince(invoice.deadline) > 0 ? 'РїСЂРѕСЃС‚СЂРѕС‡РµРЅРѕ' : `РґРѕ ${invoice.deadline}`;
            return (
              <div className="table-row" key={invoice.id}>
                <span>{invoice.id}<small>{invoice.formedAt}</small></span>
                <span>{invoice.orderId}<small>{order?.vatStatus ?? 'РђРєС‚ РІРёРґР°РЅРѕ'}</small></span>
                <span>{invoice.client}</span>
                <span>{invoice.eventDate}<small>Р°РєС‚ в‰  РѕРїР»Р°С‚Р°</small></span>
                <span>{daysLeft}</span>
                <span>{money(invoice.amount)}<small>РџР”Р’ {money(invoice.vatAmount)}</small></span>
                <span>{invoice.status}</span>
              </div>
            );
          })}
        </div>
      </section>
      <section className="panel">
        <div className="panel-heading"><h2>РџСЂР°РІРёР»Р°</h2><span>РѕР±РѕРІКјСЏР·РєРѕРІРѕ</span></div>
        <div className="task-list">
          <Task icon={<CheckCircle2 />} title="РџРµСЂРµРЅРѕСЃСѓ РЅРµРјР°С”" text="РЎС‚Р°С‚СѓСЃ РџРµСЂРµРЅРѕСЃ РЅР° РЅР°СЃС‚СѓРїРЅРёР№ РїРµСЂС–РѕРґ РЅРµ РІРёРєРѕСЂРёСЃС‚РѕРІСѓС”С‚СЊСЃСЏ. РђРєС‚ РІРёРґР°РЅРѕ в†’ РіРѕС‚РѕРІРѕ РґРѕ СЂРµС”СЃС‚СЂР°С†С–С— РџРќ Сѓ РїРѕС‚РѕС‡РЅРѕРјСѓ РїРµСЂС–РѕРґС–." />
          <Task icon={<Banknote />} title="РћРїР»Р°С‚Р° РѕРєСЂРµРјРѕ" text="РЇРєС‰Рѕ РѕРїР»Р°С‚Рё РЅРµРјР°С”, РџРќ РІСЃРµ РѕРґРЅРѕ РЅРµ Р±Р»РѕРєСѓС”С‚СЊСЃСЏ. CRM РїРѕРєР°Р·СѓС” Р±РѕСЂРі РєР»С–С”РЅС‚Р° РІ РґРµР±С–С‚РѕСЂС†С–." />
          <Task icon={<Bell />} title="РќР°РіР°РґСѓРІР°РЅРЅСЏ" text="Р‘СѓС…РіР°Р»С‚РµСЂ Р±Р°С‡РёС‚СЊ Р°РєС‚Рё Р±РµР· Р·Р°СЂРµС”СЃС‚СЂРѕРІР°РЅРѕС— РџРќ, СЂРёР·РёРє РґРµРґР»Р°Р№РЅСѓ, РїСЂРѕСЃС‚СЂРѕС‡РєСѓ, РїРѕРјРёР»РєРё С– Р·СѓРїРёРЅРєСѓ СЂРµС”СЃС‚СЂР°С†С–С—." />
        </div>
      </section>
    </div>
  );
}

function BasExchangePage({ items, mappings, actionLogs }: { items: BasExchangeItem[]; mappings: BasMapping[]; actionLogs: ActionLog[] }) {
  const byStatus = (status: BasExchangeStatus) => items.filter((item) => item.exchangeStatus === status).length;
  const exportRows = [
    { name: 'РљРѕРЅС‚СЂР°РіРµРЅС‚Рё', value: items.filter((item) => item.platformEntityType === 'counterparty').length },
    { name: 'РђРєС‚Рё', value: items.filter((item) => item.platformEntityType === 'act').length },
    { name: 'РћРїР»Р°С‚Рё', value: items.filter((item) => item.platformEntityType === 'payment').length },
    { name: 'РџСЂРѕРґР°Р¶С–', value: items.filter((item) => item.platformEntityType === 'sale').length },
    { name: 'Р—Р°РєСѓРїРєРё', value: items.filter((item) => item.platformEntityType === 'purchase').length },
    { name: 'РџРќ', value: items.filter((item) => item.platformEntityType === 'tax_invoice').length },
  ];
  const duplicateKeys = items
    .map((item) => `${item.platformEntityType}:${item.platformEntityId}`)
    .filter((key, index, list) => list.indexOf(key) !== index);
  const sections: Array<{ title: string; types: BasObjectType[] }> = [
    { title: 'РљРѕРЅС‚СЂР°РіРµРЅС‚Рё', types: ['counterparty'] },
    { title: 'РђРєС‚Рё', types: ['act'] },
    { title: 'РћРїР»Р°С‚Рё', types: ['payment'] },
    { title: 'РџРѕРґР°С‚РєРѕРІС– РЅР°РєР»Р°РґРЅС–', types: ['tax_invoice'] },
    { title: 'Р—Р°РєСѓРїРєРё', types: ['purchase'] },
    { title: 'Р”РѕР»РіРё', types: ['payment', 'act'] },
  ];

  return (
    <div className="page-grid">
      <PageTitle eyebrow="РћР±РјС–РЅ Р· BAS" title="РћРїРµСЂР°С†С–Р№РЅР° РїР»Р°С‚С„РѕСЂРјР° -> Р±СѓС…РіР°Р»С‚РµСЂС–СЏ" text="CRM С” РїРµСЂРІРёРЅРЅРёРј РґР¶РµСЂРµР»РѕРј Р·Р°РєР°Р·С–РІ, СЂРµРјРѕРЅС‚Сѓ, СЃРєР»Р°РґСѓ С– РѕРїР»Р°С‚. BAS С” РїРµСЂРІРёРЅРЅРёРј РґР¶РµСЂРµР»РѕРј Р±СѓС…РіР°Р»С‚РµСЂСЃСЊРєРѕРіРѕ РѕР±Р»С–РєСѓ, Р·РІС–С‚РЅРѕСЃС‚С– С– РџР”Р’." />
      <section className="stats-grid">
        <Metric icon={<ClipboardList />} label="New" value={String(byStatus('new'))} hint="РїРѕС‚СЂС–Р±РЅРѕ РїРѕСЃС‚Р°РІРёС‚Рё РІ С‡РµСЂРіСѓ" />
        <Metric icon={<History />} label="Queued" value={String(byStatus('queued'))} hint="РіРѕС‚РѕРІРѕ РґРѕ РІС‹РіСЂСѓР·РєРё" />
        <Metric icon={<Truck />} label="Sent" value={String(byStatus('sent'))} hint="РІС–РґРїСЂР°РІР»РµРЅРѕ" />
        <Metric icon={<CheckCircle2 />} label="Imported" value={String(byStatus('imported'))} hint="РїСЂРёР№РЅСЏС‚Рѕ BAS" />
        <Metric icon={<X />} label="Error" value={String(byStatus('error'))} hint="РїРѕС‚СЂС–Р±РЅРµ РІРёРїСЂР°РІР»РµРЅРЅСЏ" />
      </section>
      <section className="panel">
        <div className="panel-heading"><h2>Р§РµСЂРіРѕРІС–СЃС‚СЊ РІРїСЂРѕРІР°РґР¶РµРЅРЅСЏ</h2><span>СЃРїРѕС‡Р°С‚РєСѓ СЂРѕР±РѕС‚Р° СЃРµСЂРІС–СЃСѓ, РїРѕС‚С–Рј BAS</span></div>
        <div className="task-list">
          {basImplementationPhases.map((phase) => (
            <Task
              key={phase.phase}
              icon={phase.done ? <CheckCircle2 /> : phase.priority === 'РќРµ СЂРѕР±РёС‚Рё РЅР° СЃС‚Р°СЂС‚С–' ? <X /> : <History />}
              title={`${phase.phase} В· ${phase.title}`}
              text={`${phase.priority}. ${phase.result} РЎРєР»Р°Рґ: ${phase.items.join(', ')}.`}
            />
          ))}
        </div>
      </section>
      <section className="quick-actions">
        <button type="button">РЎС„РѕСЂРјСѓРІР°С‚Рё РџРќ</button>
        <button type="button">Р’РёРіСЂСѓР·РёС‚Рё РІ BAS</button>
        <button type="button">Р’РёРіСЂСѓР·РёС‚Рё РІСЃС– РЅРѕРІС–</button>
        <button type="button">РџС–РґС‚РІРµСЂРґРёС‚Рё РѕРїР»Р°С‚Сѓ</button>
        <button type="button">РџРѕРІС‚РѕСЂРёС‚Рё РІС–РґРїСЂР°РІРєСѓ</button>
        <button type="button">Р’С–РґРєСЂРёС‚Рё РїРѕРјРёР»РєСѓ</button>
        <button type="button">Excel / CSV / JSON</button>
      </section>
      <section className="panel">
        <div className="panel-heading"><h2>РљРѕРЅС‚СЂРѕР»СЊ СѓРЅС–РєР°Р»СЊРЅРѕСЃС‚С–</h2><span>platform_entity_type + platform_entity_id</span></div>
        <div className="task-list">
          <Task icon={<ShieldCheck />} title="РџРѕРІС‚РѕСЂРЅРµ СЃС‚РІРѕСЂРµРЅРЅСЏ Р·Р°Р±РѕСЂРѕРЅРµРЅРµ" text="РћРґРёРЅ С– С‚РѕР№ СЃР°РјРёР№ РґРѕРєСѓРјРµРЅС‚ РЅРµ РїРѕРІРёРЅРµРЅ СЃС‚РІРѕСЂСЋРІР°С‚РёСЃСЏ РІ BAS РїРѕРІС‚РѕСЂРЅРѕ. РљР»СЋС‡ СѓРЅС–РєР°Р»СЊРЅРѕСЃС‚С–: platform_entity_type + platform_entity_id." />
          <Task icon={duplicateKeys.length ? <X /> : <CheckCircle2 />} title="Р”СѓР±Р»С– РІ С‡РµСЂР·С–" text={duplicateKeys.length ? duplicateKeys.join(', ') : 'Р”СѓР±Р»С–РІ РЅРµ Р·РЅР°Р№РґРµРЅРѕ.'} />
          <Task icon={<Archive />} title="Payload" text="РљРѕР¶РµРЅ РґРѕРєСѓРјРµРЅС‚ РјР°С” payload_json, СЏРєРёР№ РјРѕР¶РЅР° РїРѕРІС‚РѕСЂРЅРѕ РІС–РґРїСЂР°РІРёС‚Рё РїС–СЃР»СЏ РІРёРїСЂР°РІР»РµРЅРЅСЏ РїРѕРјРёР»РєРё." />
        </div>
      </section>
      <section className="content-split">
        {sections.map((section) => {
          const rows = items.filter((item) => section.types.includes(item.platformEntityType));
          return (
            <div className="panel" key={section.title}>
              <div className="panel-heading"><h2>{section.title}</h2><span>{rows.length} РґРѕРєСѓРјРµРЅС‚С–РІ</span></div>
              <div className="task-list">
                {rows.slice(0, 3).map((item) => <Task key={`${section.title}-${item.id}`} icon={<ClipboardList />} title={`${item.platformEntityId} В· ${item.exchangeStatus}`} text={`${item.client} В· ${money(item.amountGross)} В· РџР”Р’ ${money(item.amountVat)}${item.lastError ? ` В· ${item.lastError}` : ''}`} />)}
                {rows.length === 0 && <div className="empty-state">Р”РѕРєСѓРјРµРЅС‚С–РІ РЅРµРјР°С”.</div>}
              </div>
            </div>
          );
        })}
      </section>
      <section className="content-split">
        <div className="panel">
          <div className="panel-heading"><h2>Р©Рѕ РїРµСЂРµРґР°С”С‚СЊСЃСЏ</h2><span>РµС‚Р°Рї 1: С„Р°Р№Р»Рё, РµС‚Р°Рї 2: API</span></div>
          <div className="task-list">
            {exportRows.map((row) => <Task key={row.name} icon={<Archive />} title={row.name} text={`${row.value} РѕР±КјС”РєС‚С–РІ Сѓ РїРѕС‚РѕС‡РЅС–Р№ С‡РµСЂР·С– Р°Р±Рѕ СЂРµС”СЃС‚СЂС– РѕР±РјС–РЅСѓ.`} />)}
          </div>
        </div>
        <div className="panel">
          <div className="panel-heading"><h2>РђСЂС…С–С‚РµРєС‚СѓСЂР°</h2><span>РІС–РґРїРѕРІС–РґР°Р»СЊРЅС–СЃС‚СЊ СЃРёСЃС‚РµРј</span></div>
          <div className="task-list">
            <Task icon={<LayoutDashboard />} title="РџР»Р°С‚С„РѕСЂРјР°" text="РџРµСЂРІРёРЅРЅРµ РґР¶РµСЂРµР»Рѕ: Р·Р°РєР°Р·С‹, СЂРµРјРѕРЅС‚Рё, СЃРєР»Р°Рґ, РѕРїР»Р°С‚Рё, РѕРїРµСЂР°С†С–Р№РЅС– СЃС‚Р°С‚СѓСЃРё." />
            <Task icon={<Banknote />} title="BAS" text="РџРµСЂРІРёРЅРЅРµ РґР¶РµСЂРµР»Рѕ: Р±СѓС…РіР°Р»С‚РµСЂСЃСЊРєРёР№ РѕР±Р»С–Рє, СЂРµРіР»Р°РјРµРЅС‚РѕРІР°РЅР° Р·РІС–С‚РЅС–СЃС‚СЊ, РџР”Р’." />
            <Task icon={<ClipboardList />} title="РџРµСЂС€РёР№ РµС‚Р°Рї" text="Р’РёРіСЂСѓР·РєР° Excel / CSV / JSON РґР»СЏ Р±СѓС…РіР°Р»С‚РµСЂР°." />
            <Task icon={<CheckCircle2 />} title="Р”СЂСѓРіРёР№ РµС‚Р°Рї" text="РђРІС‚РѕРјР°С‚РёС‡РЅРёР№ РјРѕРґСѓР»СЊ РѕР±РјС–РЅСѓ С‡РµСЂРµР· API / С„Р°Р№Р»-РѕР±РјС–РЅ РїС–СЃР»СЏ РїРѕРіРѕРґР¶РµРЅРЅСЏ С„РѕСЂРјР°С‚Сѓ." />
            <Task icon={<ShieldCheck />} title="РћР±РјРµР¶РµРЅРЅСЏ CRM" text="CRM РЅРµ РІРµРґРµ Р±СѓС…РіР°Р»С‚РµСЂСЃСЊРєРёР№ РѕР±Р»С–Рє С– РЅРµ С„РѕСЂРјСѓС” РѕС„С–С†С–Р№РЅСѓ РїРѕРґР°С‚РєРѕРІСѓ РЅР°РєР»Р°РґРЅСѓ. CRM РіРѕС‚СѓС” РґРѕРєСѓРјРµРЅС‚Рё С‚Р° РґР°РЅС–, BAS С„РѕСЂРјСѓС” РџРќ С– Р±СѓС…РіР°Р»С‚РµСЂСЃСЊРєС– РґРѕРєСѓРјРµРЅС‚Рё." />
          </div>
        </div>
      </section>
      <section className="panel">
        <div className="panel-heading"><h2>Р§РµСЂРіР° РѕР±РјС–РЅСѓ</h2><span>{items.length} РѕР±КјС”РєС‚С–РІ</span></div>
        <div className="table documents-table">
          <div className="table-row table-head"><span>Р”РѕРєСѓРјРµРЅС‚</span><span>РљР»С–С”РЅС‚</span><span>РЎСѓРјРё</span><span>РЎС‚Р°С‚СѓСЃ</span><span>BAS</span><span>Retry / Error</span></div>
          {items.map((item) => (
            <div className="table-row" key={item.id}>
              <span>{item.title}<small>{item.platformEntityType} В· {item.platformEntityId} В· СЃС‚РІРѕСЂРёРІ {item.createdBy}</small></span>
              <span>{item.client}<small>Р·Р°РєР°Р· {item.orderId ?? 'РЅРµРјР°С”'}</small></span>
              <span>{money(item.amountNet)}<small>РџР”Р’ {money(item.amountVat)} В· Р· РџР”Р’ {money(item.amountGross)}</small></span>
              <span>{item.exchangeStatus}<small>sent {item.sentAt ?? 'РЅС–'} В· confirmed {item.confirmedAt ?? 'РЅС–'}</small></span>
              <span>{item.basEntityId ?? 'РЅРµРјР°С”'}<small>{item.payloadJson}</small></span>
              <span>{item.retryCount}<small>{item.lastError ?? 'РЅРµРјР°С”'}</small></span>
            </div>
          ))}
        </div>
      </section>
      <section className="content-split">
        <div className="panel">
          <div className="panel-heading"><h2>РЎРѕРїРѕСЃС‚Р°РІР»РµРЅРЅСЏ РґРѕРІС–РґРЅРёРєС–РІ</h2><span>{mappings.length} РїСЂР°РІРёР»</span></div>
          <div className="table documents-table">
            <div className="table-row table-head"><span>Р”РѕРІС–РґРЅРёРє</span><span>РџР»Р°С‚С„РѕСЂРјР°</span><span>BAS</span><span>РЎС‚Р°С‚СѓСЃ</span></div>
            {mappings.map((mapping) => (
              <div className="table-row" key={`${mapping.directory}-${mapping.platformValue}`}>
                <span>{mapping.directory}</span>
                <span>{mapping.platformValue}</span>
                <span>{mapping.basValue}</span>
                <span>{mapping.status}</span>
              </div>
            ))}
          </div>
        </div>
        <div className="panel">
          <div className="panel-heading"><h2>Р›РѕРіСѓРІР°РЅРЅСЏ РѕР±РјС–РЅСѓ</h2><span>СѓСЃС– РґС–С— С„С–РєСЃСѓСЋС‚СЊСЃСЏ</span></div>
          <div className="task-list">
            {items.slice(0, 5).map((item) => <Task key={`log-${item.id}`} icon={<History />} title={`${item.exchangeStatus} В· ${item.platformEntityId}`} text={`${item.title}. ${item.lastError ? `РџРѕРјРёР»РєР°: ${item.lastError}` : `Р’С–РґРїРѕРІС–РґР°Р»СЊРЅРёР№: ${item.responsible}`}`} />)}
            {actionLogs.slice(0, 3).map((log) => <Task key={`action-${log.id}`} icon={<Bell />} title={`${log.action} В· ${log.entity}`} text={`${log.date} В· ${log.user}. ${log.comment}`} />)}
          </div>
        </div>
      </section>
    </div>
  );
}

function ProblemClientsPage({ orders, documents, setPage, setSelectedOrderId }: { orders: ServiceOrder[]; documents: PrintDocument[]; setPage: (page: Page) => void; setSelectedOrderId: (id: string) => void }) {
  const [managerFilter, setManagerFilter] = useState('РЈСЃС–');
  const [engineerFilter, setEngineerFilter] = useState('РЈСЃС–');
  const [typeFilter, setTypeFilter] = useState('РЈСЃС–');
  const [ageFilter, setAgeFilter] = useState('РЈСЃС–');
  const problems = buildServiceProblems(orders, documents);
  const managers = Array.from(new Set(problems.map((problem) => problem.manager)));
  const engineers = Array.from(new Set(problems.map((problem) => problem.engineer)));
  const types = Array.from(new Set(problems.map((problem) => problem.type)));
  const rows = problems.filter((problem) => {
    if (managerFilter !== 'РЈСЃС–' && problem.manager !== managerFilter) return false;
    if (engineerFilter !== 'РЈСЃС–' && problem.engineer !== engineerFilter) return false;
    if (typeFilter !== 'РЈСЃС–' && problem.type !== typeFilter) return false;
    if (ageFilter === '1+ РґРµРЅСЊ' && problem.days < 1) return false;
    if (ageFilter === '3+ РґРЅС–' && problem.days < 3) return false;
    if (ageFilter === '7+ РґРЅС–РІ' && problem.days < 7) return false;
    return true;
  });
  const critical = rows.filter((problem) => problem.level === 'РљСЂРёС‚РёС‡РЅРѕ');
  const important = rows.filter((problem) => problem.level === 'Р’Р°Р¶Р»РёРІРѕ');

  return (
    <div className="page-grid">
      <PageTitle eyebrow="РџСЂРѕР±Р»РµРјРё" title="РђРІС‚РѕРјР°С‚РёС‡РЅРёР№ РєРѕРЅС‚СЂРѕР»СЊ РїРѕРјРёР»РѕРє СЃРµСЂРІС–СЃСѓ" text="CRM СЃР°РјР° Р°РЅР°Р»С–Р·СѓС” Р·Р°РєР°Р·С‹, РґРѕРєСѓРјРµРЅС‚Рё, РѕРїР»Р°С‚Сѓ, РџР”Р’ С– СЂСѓС… РїСЂРѕС†РµСЃСѓ. РљРѕСЂРёСЃС‚СѓРІР°С‡ РЅРµ С€СѓРєР°С” РїРѕРјРёР»РєРё РІСЂСѓС‡РЅСѓ, Р° СЂРµР°РіСѓС” РЅР° РіРѕС‚РѕРІРёР№ СЃРїРёСЃРѕРє." />
      <section className="stats-grid">
        <Metric icon={<X />} label="РљСЂРёС‚РёС‡РЅРѕ" value={String(critical.length)} hint="РіСЂРѕС€С– / РїРѕРґР°С‚РєРё" />
        <Metric icon={<Bell />} label="Р’Р°Р¶Р»РёРІРѕ" value={String(important.length)} hint="РїСЂРѕС†РµСЃРё" />
        <Metric icon={<History />} label="РЈСЃСЊРѕРіРѕ РїСЂРѕР±Р»РµРј" value={String(rows.length)} hint="РїС–СЃР»СЏ С„С–Р»СЊС‚СЂС–РІ" />
        <Metric icon={<CheckCircle2 />} label="РђРІС‚РѕРѕРЅРѕРІР»РµРЅРЅСЏ" value="5-10 С…РІ" hint="СѓРјРѕРІРё РїРµСЂРµРІС–СЂСЏСЋС‚СЊСЃСЏ СЃРёСЃС‚РµРјРѕСЋ" />
      </section>
      <section className="quick-actions">
        <select value={managerFilter} onChange={(event) => setManagerFilter(event.target.value)} aria-label="РњРµРЅРµРґР¶РµСЂ">
          <option>РЈСЃС–</option>
          {managers.map((manager) => <option key={manager}>{manager}</option>)}
        </select>
        <select value={engineerFilter} onChange={(event) => setEngineerFilter(event.target.value)} aria-label="Р†РЅР¶РµРЅРµСЂ">
          <option>РЈСЃС–</option>
          {engineers.map((engineer) => <option key={engineer}>{engineer}</option>)}
        </select>
        <select value={typeFilter} onChange={(event) => setTypeFilter(event.target.value)} aria-label="РўРёРї РїСЂРѕР±Р»РµРјРё">
          <option>РЈСЃС–</option>
          {types.map((type) => <option key={type}>{type}</option>)}
        </select>
        <select value={ageFilter} onChange={(event) => setAgeFilter(event.target.value)} aria-label="РЎС‚СЂРѕРє">
          <option>РЈСЃС–</option>
          <option>1+ РґРµРЅСЊ</option>
          <option>3+ РґРЅС–</option>
          <option>7+ РґРЅС–РІ</option>
        </select>
      </section>
      <section className="panel">
        <div className="panel-heading"><h2>РЎРїРёСЃРѕРє РїСЂРѕР±Р»РµРј</h2><span>{rows.length} СЃРёРіРЅР°Р»С–РІ</span></div>
        <div className="table problem-table">
          <div className="table-row table-head"><span>Р С–РІРµРЅСЊ</span><span>Р—Р°РєР°Р· / РєР»С–С”РЅС‚</span><span>РџСЂРѕР±Р»РµРјР°</span><span>РўСЂРёРІР°С”</span><span>Р’С–РґРїРѕРІС–РґР°Р»СЊРЅРёР№</span><span>Р”С–С—</span></div>
          {rows.map((problem) => (
            <div className="table-row" key={problem.id}>
              <span>{problem.level}</span>
              <span>{problem.orderId}<small>{problem.client}</small></span>
              <span>{problem.type}<small>{problem.description}</small></span>
              <span>{problem.days} РґРЅ.</span>
              <span>{problem.responsible}<small>РјРµРЅРµРґР¶РµСЂ {problem.manager} В· С–РЅР¶РµРЅРµСЂ {problem.engineer}</small></span>
              <span>
                <button type="button" onClick={() => { setSelectedOrderId(problem.orderId); setPage('orders'); }}>Р’С–РґРєСЂРёС‚Рё Р·Р°РєР°Р·</button>
                {problem.target === 'payment' && <button type="button" onClick={() => { setSelectedOrderId(problem.orderId); setPage('orders'); }}>Р”Рѕ РѕРїР»Р°С‚Рё</button>}
                {problem.target === 'act' && <button type="button" onClick={() => setPage('documents')}>Р”Рѕ Р°РєС‚Р°</button>}
                {problem.target === 'document' && <button type="button" onClick={() => setPage('documents')}>Р”Рѕ РґРѕРєСѓРјРµРЅС‚Р°</button>}
              </span>
            </div>
          ))}
        </div>
        {rows.length === 0 && <div className="empty-state">Р—Р° РїРѕС‚РѕС‡РЅРёРјРё С„С–Р»СЊС‚СЂР°РјРё РїСЂРѕР±Р»РµРј РЅРµРјР°С”.</div>}
      </section>
      <section className="panel">
        <div className="panel-heading"><h2>РџСЂР°РІРёР»Р° РєРѕРЅС‚СЂРѕР»СЋ</h2><span>РїРµСЂРµРІС–СЂРєР° РєРѕР¶РЅС– 5-10 С…РІ</span></div>
        <div className="task-list">
          <Task icon={<Banknote />} title="РљСЂРёС‚РёС‡РЅРѕ" text="Р“СЂРѕС€С–, Р°РєС‚Рё, РІРёРґР°С‚РєРѕРІС–, РќР”РЎ С– Р±РѕСЂРіРё РїС–РґРЅС–РјР°СЋС‚СЊСЃСЏ СЏРє РєСЂРёС‚РёС‡РЅС– СЂРёР·РёРєРё." />
          <Task icon={<History />} title="Р’Р°Р¶Р»РёРІРѕ" text="Р“РѕС‚РѕРІРѕ, Р°Р»Рµ РЅРµ РІРёРґР°РЅРѕ; Р·Р°РєР°Р· Р±РµР· СЂСѓС…Сѓ; Р°РєС‚ РЅРµ РїРѕРІРµСЂРЅРµРЅРёР№ РєР»С–С”РЅС‚РѕРј." />
          <Task icon={<Bell />} title="РЈРІРµРґРѕРјР»РµРЅРЅСЏ" text="РџСЂРѕР±Р»РµРјРё РІРёРґРЅРѕ РЅР° РіРѕР»РѕРІРЅС–Р№ РєРµСЂС–РІРЅРёРєР°, РіРѕР»РѕРІРЅС–Р№ РјРµРЅРµРґР¶РµСЂР°, Сѓ С†РµРЅС‚СЂС– РїРѕРІС–РґРѕРјР»РµРЅСЊ С– РІ С†СЊРѕРјСѓ СЂРѕР·РґС–Р»С–." />
        </div>
      </section>
    </div>
  );
}

function OrderUnitsPage({ units, activeUser }: { units: OrderUnit[]; activeUser: User }) {
  const [scanCode, setScanCode] = useState('');
  const visibleUnits = activeUser.role === 'Р†РЅР¶РµРЅРµСЂ' ? units.filter((unit) => unit.engineer === activeUser.name) : units;
  const scanned = visibleUnits.find((unit) => unit.code.toLowerCase() === scanCode.trim().toLowerCase() || unit.id.toLowerCase() === scanCode.trim().toLowerCase());
  const onShelfWithoutCell = visibleUnits.filter((unit) => unit.status === 'РќР° РїРѕР»С†С–' && !unit.locationCode);

  return (
    <div className="page-grid">
      <PageTitle eyebrow="РћРґРёРЅРёС†С– Р·Р°РєР°Р·С–РІ" title="РњР°СЂРєСѓРІР°РЅРЅСЏ, СЃРєР°РЅСѓРІР°РЅРЅСЏ С– СЂСѓС… РїРѕ С†РµС…Сѓ" text="РљРѕР¶РµРЅ РїСЂРёСЃС‚СЂС–Р№ Р°Р±Рѕ РєР°СЂС‚СЂРёРґР¶ РјР°С” СЃРІС–Р№ ID, QR/С€С‚СЂРёС…РєРѕРґ, СЃС‚Р°С‚СѓСЃ, С–РЅР¶РµРЅРµСЂР° С– РјС–СЃС†Рµ Р·Р±РµСЂС–РіР°РЅРЅСЏ." />
      <section className="panel">
        <div className="panel-heading"><h2>РЎРєР°РЅСѓРІР°РЅРЅСЏ</h2><span>QR / barcode</span></div>
        <label>
          РљРѕРґ РѕРґРёРЅРёС†С–
          <input value={scanCode} onChange={(event) => setScanCode(event.target.value)} placeholder="РќР°РїСЂРёРєР»Р°Рґ BAR-1047-C2 Р°Р±Рѕ UNIT-1048-1" />
          <small>РЎРєР°РЅСѓРІР°РЅРЅСЏ РІС–РґРєСЂРёРІР°С” РѕРґРёРЅРёС†СЋ С– РїРѕРєР°Р·СѓС” РґРѕСЃС‚СѓРїРЅС– РґС–С—.</small>
        </label>
        {scanned && <div className="scan-result"><strong>{scanned.id} В· {scanned.type}</strong><span>{scanned.client} В· {scanned.status} В· {scanned.locationCode ?? 'Р±РµР· РїРѕР»РєРё'}</span></div>}
      </section>
      <section className="quick-actions">
        <button type="button">РЎС‚РІРѕСЂРёС‚Рё С‰Рµ РѕРґРёРЅ Р·Р°РєР°Р· РґР»СЏ С†СЊРѕРіРѕ РєР»С–С”РЅС‚Р°</button>
        <button type="button">Р”СЂСѓРє РЅР°РєР»РµР№РєРё</button>
        <button type="button">РџРѕРєР»Р°СЃС‚Рё РЅР° РїРѕР»РєСѓ</button>
        <button type="button">Р’РёРґР°С‚Рё С‡РµСЂРµР· СЃРєР°РЅСѓРІР°РЅРЅСЏ</button>
      </section>
      <section className="stats-grid">
        <Metric icon={<ClipboardList />} label="РћРґРёРЅРёС†СЊ" value={String(visibleUnits.length)} hint="РїСЂРёСЃС‚СЂРѕС— + РєР°СЂС‚СЂРёРґР¶С–" />
        <Metric icon={<Wrench />} label="Р’ СЂРµРјРѕРЅС‚С–" value={String(visibleUnits.filter((unit) => unit.status === 'Р’ СЂРµРјРѕРЅС‚С–').length)} hint="С†РµС…" />
        <Metric icon={<Archive />} label="РќР° РїРѕР»С†С–" value={String(visibleUnits.filter((unit) => unit.status === 'РќР° РїРѕР»С†С–').length)} hint="РіРѕС‚РѕРІС– Р°Р±Рѕ РѕС‡С–РєСѓСЋС‚СЊ" />
        <Metric icon={<X />} label="Р‘РµР· РєРѕРјС–СЂРєРё" value={String(onShelfWithoutCell.length)} hint="Р·Р°Р±РѕСЂРѕРЅРµРЅРѕ РїСЂР°РІРёР»Р°РјРё" />
      </section>
      <section className="panel">
        <div className="panel-heading"><h2>РўР°Р±Р»РёС†СЏ РѕРґРёРЅРёС†СЊ</h2><span>{visibleUnits.length} Р·Р°РїРёСЃС–РІ</span></div>
        <div className="table units-table">
          <div className="table-row table-head"><span>ID</span><span>Р—Р°РєР°Р·</span><span>РўРёРї</span><span>РЎС‚Р°С‚СѓСЃ</span><span>Р†РЅР¶РµРЅРµСЂ</span><span>РњС–СЃС†Рµ</span><span>РљРѕРґ</span></div>
          {visibleUnits.map((unit) => (
            <div className="table-row" key={unit.id}>
              <span>{unit.id}<small>{unit.groupId}</small></span>
              <span>{unit.orderId}<small>{unit.client}</small></span>
              <span>{unit.type}</span>
              <span>{unit.status}</span>
              <span>{unit.engineer}</span>
              <span>{unit.locationCode ?? 'РЅРµ Р·Р°РґР°РЅРѕ'}</span>
              <span>{unit.code}</span>
            </div>
          ))}
        </div>
      </section>
    </div>
  );
}

function StoragePage({ units, cells }: { units: OrderUnit[]; cells: StorageCell[] }) {
  const free = cells.filter((cell) => !cell.occupiedBy);
  const occupied = cells.filter((cell) => cell.occupiedBy);
  return (
    <div className="page-grid">
      <PageTitle eyebrow="РџРѕР»РєРё / РєРѕРјС–СЂРєРё" title="РљРѕРѕСЂРґРёРЅР°С‚РЅРµ Р·Р±РµСЂС–РіР°РЅРЅСЏ A-3-2" text="Р¤РѕСЂРјР°С‚ РєРѕРјС–СЂРєРё: Shelf-Level-Position. РЇРєС‰Рѕ РѕРґРёРЅРёС†СЏ РјР°С” СЃС‚Р°С‚СѓСЃ РќР° РїРѕР»С†С–, РјС–СЃС†Рµ Р·Р±РµСЂС–РіР°РЅРЅСЏ РѕР±РѕРІКјСЏР·РєРѕРІРµ." />
      <section className="stats-grid">
        <Metric icon={<Archive />} label="РљРѕРјС–СЂРѕРє" value={String(cells.length)} hint="РїС–РґРїРёСЃР°РЅС– С„С–Р·РёС‡РЅРѕ" />
        <Metric icon={<CheckCircle2 />} label="Р’С–Р»СЊРЅРѕ" value={String(free.length)} hint="СЃРёСЃС‚РµРјР° РјРѕР¶Рµ Р·Р°РїСЂРѕРїРѕРЅСѓРІР°С‚Рё" />
        <Metric icon={<PackageCheck />} label="Р—Р°Р№РЅСЏС‚Рѕ" value={String(occupied.length)} hint="РЅРµ РјРѕР¶РЅР° РїРѕРєР»Р°СЃС‚Рё РІРґСЂСѓРіРµ" />
        <Metric icon={<Search />} label="РџРѕС€СѓРє" value="РљРѕРґ / РєР»С–С”РЅС‚" hint="A-1-1 Р°Р±Рѕ Р·Р°РєР°Р·" />
      </section>
      <section className="panel">
        <div className="panel-heading"><h2>Р’С–Р·СѓР°Р»СЊРЅР° СЃС…РµРјР°</h2><span>РєРѕР»С–СЂ = Р·Р°Р№РЅСЏС‚С–СЃС‚СЊ</span></div>
        <div className="storage-grid">
          {cells.map((cell) => {
            const unit = units.find((item) => item.id === cell.occupiedBy);
            return <article className={cell.occupiedBy ? 'storage-cell storage-cell-busy' : 'storage-cell'} key={cell.id}><strong>{cell.code}</strong><span>{unit ? `${unit.id} В· ${unit.client}` : 'РІС–Р»СЊРЅР°'}</span></article>;
          })}
        </div>
      </section>
      <section className="panel">
        <div className="panel-heading"><h2>РџСЂР°РІРёР»Р° СЂРѕР·РјС–С‰РµРЅРЅСЏ</h2><span>Р±РµР· РІС‚СЂР°С‚</span></div>
        <div className="task-list">
          <Task icon={<X />} title="РќРµ РјРѕР¶РЅР° РІ Р·Р°Р№РЅСЏС‚Сѓ" text="CRM Р±Р»РѕРєСѓС” СЂРѕР·РјС–С‰РµРЅРЅСЏ РІ РєРѕРјС–СЂРєСѓ, РґРµ РІР¶Рµ Р»РµР¶РёС‚СЊ С–РЅС€Р° РѕРґРёРЅРёС†СЏ." />
          <Task icon={<Archive />} title="РќР° РїРѕР»С†С– = РєРѕРјС–СЂРєР°" text="РџСЂРё СЃС‚Р°С‚СѓСЃС– РќР° РїРѕР»С†С– РїРѕР»Рµ РњС–СЃС†Рµ Р·Р±РµСЂС–РіР°РЅРЅСЏ РѕР±РѕРІКјСЏР·РєРѕРІРµ." />
          <Task icon={<Search />} title="РЁРІРёРґРєРёР№ РїРѕС€СѓРє" text="РџРѕС€СѓРє РїСЂР°С†СЋС” РїРѕ QR, РєР»С–С”РЅС‚Сѓ, Р·Р°РєР°Р·Сѓ, СЃС‚Р°С‚СѓСЃСѓ С– РєРѕРѕСЂРґРёРЅР°С‚С– РїРѕР»РєРё." />
        </div>
      </section>
    </div>
  );
}

function MovementsPage({ movements, productName }: { movements: StockMovement[]; productName: (id: string) => string }) {
  return (
    <div className="page-grid">
      <PageTitle eyebrow="Р СѓС… СЃРєР»Р°РґСѓ" title="РџРѕРІРЅР° С–СЃС‚РѕСЂС–СЏ Р·РјС–РЅ Р·Р°Р»РёС€РєС–РІ" text="РљРѕР¶РЅР° РѕРїРµСЂР°С†С–СЏ РјР°С” С‚РёРї, РґР°С‚Сѓ, Р·Р°РїС‡Р°СЃС‚РёРЅСѓ, РєС–Р»СЊРєС–СЃС‚СЊ С– Р·РІ'СЏР·РѕРє С–Р· СЂРµРјРѕРЅС‚РѕРј Р°Р±Рѕ Р·Р°РєСѓРїС–РІР»РµСЋ." />
      <section className="panel">
        <div className="table movement-table">
          <div className="table-row table-head"><span>Р”Р°С‚Р°</span><span>РўРёРї</span><span>Р—Р°РїС‡Р°СЃС‚РёРЅР°</span><span>Рљ-СЃС‚СЊ</span><span>Р”РѕРєСѓРјРµРЅС‚</span><span>РљРѕРјРµРЅС‚Р°СЂ</span></div>
          {movements.map((movement) => (
            <div className="table-row" key={movement.id}>
              <span>{movement.date}</span>
              <span>{movement.type}</span>
              <span>{productName(movement.productId)}</span>
              <span>{movement.qty}</span>
              <span>{movement.orderId ?? movement.purchaseId}</span>
              <span>{movement.comment}</span>
            </div>
          ))}
        </div>
        {movements.length === 0 && <div className="empty-state">Р СѓС…С–РІ С‰Рµ РЅРµРјР°С”.</div>}
      </section>
    </div>
  );
}

function ClientsPage({ clients }: { clients: Array<{ name: string; phone: string; orders: number }> }) {
  return (
    <div className="page-grid">
      <PageTitle eyebrow="РљР»С–С”РЅС‚Рё" title="РљР»С–С”РЅС‚СЃСЊРєР° Р±Р°Р·Р° СЃРµСЂРІС–СЃСѓ" text="РљРѕРЅС‚Р°РєС‚Рё С‚Р° РєС–Р»СЊРєС–СЃС‚СЊ Р·РІРµСЂРЅРµРЅСЊ РґР»СЏ С€РІРёРґРєРѕРіРѕ РїСЂРёР№РѕРјСѓ С‚РµС…РЅС–РєРё." />
      <section className="cards-grid">
        {clients.map((client) => <article className="client-card" key={client.phone}><div className="avatar">{client.name.slice(0, 1)}</div><h2>{client.name}</h2><p>{client.phone}</p><div className="client-meta"><span>{client.orders} Р·Р°РјРѕРІР»РµРЅСЊ</span></div></article>)}
      </section>
    </div>
  );
}

function FinancePage({ orders, products, sales, analytics, cashShift, canDo }: { orders: ServiceOrder[]; products: Product[]; sales: Sale[]; analytics: { stockValue: number; salesDebt: number; serviceDebt: number; salesRevenue: number }; cashShift: CashShift; canDo: (permission: Permission) => boolean }) {
  const revenue = orders.reduce((sum, order) => sum + orderTotals(order).paid, 0) + analytics.salesRevenue;
  const cost = orders.reduce((sum, order) => sum + orderTotals(order).cost, 0);
  const saleDebt = sales.reduce((sum, sale) => sum + saleTotals(sale).debt, 0);
  return (
    <div className="page-grid">
      <PageTitle eyebrow="Р¤С–РЅР°РЅСЃРё" title="РЎРѕР±С–РІР°СЂС‚С–СЃС‚СЊ С– РјР°СЂР¶РёРЅР°Р»СЊРЅС–СЃС‚СЊ СЂРµРјРѕРЅС‚С–РІ" text="CRM СЂР°С…СѓС” Р·Р°РєСѓРїС–РІРµР»СЊРЅСѓ РІР°СЂС‚С–СЃС‚СЊ СЃРєР»Р°РґСѓ, СЃРѕР±С–РІР°СЂС‚С–СЃС‚СЊ Р·Р°РїС‡Р°СЃС‚РёРЅ Сѓ СЂРµРјРѕРЅС‚Р°С… С– РѕС‡С–РєСѓРІР°РЅСѓ РІРёСЂСѓС‡РєСѓ." />
      <section className="stats-grid">
        <Metric icon={<Banknote />} label="Р’РёСЂСѓС‡РєР°" value={money(revenue)} hint="СЂРµРјРѕРЅС‚Рё + РїСЂРѕРґР°Р¶С–" />
        <Metric icon={<Archive />} label="РЎРєР»Р°Рґ Р·Р° СЃРѕР±С–РІР°СЂС‚С–СЃС‚СЋ" value={canDo('cost.view') ? money(analytics.stockValue) : 'РџСЂРёС…РѕРІР°РЅРѕ'} hint="С‚РѕРІР°СЂ РЅР° СЃРєР»Р°РґС–" />
        <Metric icon={<Wrench />} label="РЎРѕР±С–РІР°СЂС‚С–СЃС‚СЊ Сѓ СЂРµРјРѕРЅС‚Р°С…" value={canDo('cost.view') ? money(cost) : 'РџСЂРёС…РѕРІР°РЅРѕ'} hint="РІРёРґР°РЅРѕ Р°Р±Рѕ РІСЃС‚Р°РЅРѕРІР»РµРЅРѕ" />
        <Metric icon={<CheckCircle2 />} label="Р‘РѕСЂРіРё РєР»С–С”РЅС‚С–РІ" value={money(saleDebt + analytics.serviceDebt)} hint="РїСЂРѕРґР°Р¶С– + СЂРµРјРѕРЅС‚Рё" />
      </section>
      <section className="panel">
        <div className="panel-heading"><h2>РљР°СЃРѕРІР° Р·РјС–РЅР°</h2><span className="tag tag-green">{cashShift.status}</span></div>
        <div className="details-grid">
          <Info label="Р—РјС–РЅР°" value={`${cashShift.id} В· РІС–РґРєСЂРёРІ ${cashShift.openedBy}`} />
          <Info label="Р“РѕС‚С–РІРєР°" value={money(cashShift.cashIncome)} />
          <Info label="РўРµСЂРјС–РЅР°Р»" value={money(cashShift.cardIncome)} />
          <Info label="Р‘РµР·РіРѕС‚С–РІРєР°" value={money(cashShift.bankIncome)} />
          <Info label="Р’РёС‚СЂР°С‚Рё / РїРѕРІРµСЂРЅРµРЅРЅСЏ" value={money(cashShift.cashExpense)} />
          <Info label="Р—Р°Р»РёС€РѕРє РєР°СЃРё" value={money(cashShift.cashIncome - cashShift.cashExpense)} />
        </div>
      </section>
      <section className="panel">
        <div className="panel-heading"><h2>Р‘СѓС…РіР°Р»С‚РµСЂСЃСЊРєРёР№ РґРѕСЃС‚СѓРї</h2><span>РѕР±Р»С–Рє С– РїРѕРґР°С‚РєРё</span></div>
        <div className="task-list">
          <Task icon={<Banknote />} title="РћРїР»Р°С‚Рё С– Р±РѕСЂРіРё" text="Р‘СѓС…РіР°Р»С‚РµСЂ Р±Р°С‡РёС‚СЊ РєР°СЃСѓ, Р±РµР·РЅР°Р», РїР»Р°С‚РµР¶С–, РїРѕРІРµСЂРЅРµРЅРЅСЏ С– Р·Р°Р±РѕСЂРіРѕРІР°РЅС–СЃС‚СЊ РєР»С–С”РЅС‚С–РІ." />
          <Task icon={<ShoppingCart />} title="РџСЂРѕРґР°Р¶С– С– РќР”РЎ" text="РЈ Р·РІС–С‚Р°С… РґРѕСЃС‚СѓРїРЅС– СЃСѓРјРё РїСЂРѕРґР°Р¶С–РІ, Р·РЅРёР¶РєРё, РІРёС…С–РґРЅРёР№ РџР”Р’ С– РїСЂРёР±СѓС‚РѕРє." />
          <Task icon={<Truck />} title="Р—Р°РєСѓРїРєРё С– РІС…С–РґРЅРёР№ РќР”РЎ" text="Р‘СѓС…РіР°Р»С‚РµСЂ Р±Р°С‡РёС‚СЊ РїРѕСЃС‚Р°С‡Р°Р»СЊРЅРёРєС–РІ, Р·Р°РєСѓРїС–РІРµР»СЊРЅС– С†С–РЅРё, СЃРѕР±С–РІР°СЂС‚С–СЃС‚СЊ С– РІС…С–РґРЅРёР№ РџР”Р’." />
          <Task icon={<Archive />} title="РЎРєР»Р°Рґ С– СЃРїРёСЃР°РЅРЅСЏ" text="Р”РѕСЃС‚СѓРїРЅРёР№ СЂСѓС… С‚РѕРІР°СЂС–РІ, СЃРѕР±С–РІР°СЂС‚С–СЃС‚СЊ, СЃРїРёСЃР°РЅРЅСЏ С– РїРѕРІРµСЂРЅРµРЅРЅСЏ." />
        </div>
      </section>
    </div>
  );
}

function ReportsPage({ orders, sales, movements, products, actionLogs, cashShift, canDo }: { orders: ServiceOrder[]; sales: Sale[]; movements: StockMovement[]; products: Product[]; actionLogs: ActionLog[]; cashShift: CashShift; canDo: (permission: Permission) => boolean }) {
  const salesToday = sales.filter((sale) => sale.date === today);
  const salesRevenue = sales.reduce((sum, sale) => sum + saleTotals(sale).paid, 0);
  const card = sales.flatMap((sale) => sale.payments).filter((payment) => payment.method === 'РљР°СЂС‚РєР°').reduce((sum, payment) => sum + payment.amount, 0);
  const cash = sales.flatMap((sale) => sale.payments).filter((payment) => payment.method === 'Р“РѕС‚С–РІРєР°').reduce((sum, payment) => sum + payment.amount, 0);
  const bank = sales.flatMap((sale) => sale.payments).filter((payment) => payment.method === 'Р‘РµР·РіРѕС‚С–РІРєР°').reduce((sum, payment) => sum + payment.amount, 0);
  const managerRevenue = sales.reduce<Record<string, number>>((acc, sale) => {
    acc[sale.manager] = (acc[sale.manager] ?? 0) + saleTotals(sale).paid;
    return acc;
  }, {});
  const returns = sales.flatMap((sale) => sale.returns);
  const productProfit = sales.reduce((sum, sale) => sum + saleTotals(sale).profit, 0);
  const repairProfit = orders.reduce((sum, order) => sum + orderTotals(order).finalProfit, 0);
  const salesVat = vatFromGross(sales.reduce((sum, sale) => sum + saleTotals(sale).total, 0));
  const purchaseGross = products.reduce((sum, product) => sum + product.stock * product.cost, 0);
  const purchaseVat = vatFromGross(purchaseGross);
  const vatDue = Math.max(salesVat.vat - purchaseVat.vat, 0);

  return (
    <div className="page-grid">
      <PageTitle eyebrow="Р—РІС–С‚Рё" title="РџСЂРѕРґР°Р¶С–, РєР°СЃР°, Р±РѕСЂРіРё, РїРѕРІРµСЂРЅРµРЅРЅСЏ С– РїСЂРёР±СѓС‚РѕРє" text="Р—РІС–С‚Рё СЂР°С…СѓСЋС‚СЊСЃСЏ Р°РІС‚РѕРјР°С‚РёС‡РЅРѕ Р· РѕРїР»Р°С‚, РІРёРґР°С‡, РїРѕРІРµСЂРЅРµРЅСЊ, СЂСѓС…С–РІ СЃРєР»Р°РґСѓ С‚Р° Р·Р°РєСЂРёС‚РёС… СЂРµРјРѕРЅС‚С–РІ." />
      <section className="stats-grid">
        <Metric icon={<ShoppingCart />} label="РџСЂРѕРґР°Р¶С– Р·Р° РґРµРЅСЊ" value={String(salesToday.length)} hint={money(salesRevenue)} />
        <Metric icon={<Banknote />} label="Р“РѕС‚С–РІРєР°" value={money(cash)} hint="РєР°СЃР°" />
        <Metric icon={<CheckCircle2 />} label="РљР°СЂС‚РєР°" value={money(card)} hint="С‚РµСЂРјС–РЅР°Р»" />
        <Metric icon={<Archive />} label="Р‘РµР·РіРѕС‚С–РІРєР°" value={money(bank)} hint="СЂР°С…СѓРЅРѕРє" />
      </section>
      <section className="panel">
        <div className="panel-heading"><h2>РќР”РЎ / РџР”Р’</h2><span>СЃС‚Р°РІРєР° 20%</span></div>
        <div className="details-grid">
          <Info label="РџСЂРѕРґР°Р¶С– Р±РµР· РџР”Р’" value={money(salesVat.net)} />
          <Info label="Р’РёС…С–РґРЅРёР№ РџР”Р’" value={money(salesVat.vat)} />
          <Info label="Р—Р°РєСѓРїРєРё Р±РµР· РџР”Р’" value={money(purchaseVat.net)} />
          <Info label="Р’С…С–РґРЅРёР№ РџР”Р’" value={money(purchaseVat.vat)} />
          <Info label="Р”Рѕ СЃРїР»Р°С‚Рё РџР”Р’" value={money(vatDue)} />
          <Info label="Р•РєСЃРїРѕСЂС‚" value="Excel, CSV, 1РЎ/BAS/M.E.Doc - РЅР°СЃС‚СѓРїРЅРёР№ backend РµС‚Р°Рї" />
        </div>
      </section>
      <section className="quick-actions">
        <button type="button" disabled={!canDo('reports.export')}>Р’РёРіСЂСѓР·РєР° РїСЂРѕРґР°Р¶С–РІ Excel</button>
        <button type="button" disabled={!canDo('reports.export')}>Р’РёРіСЂСѓР·РєР° Р·Р°РєСѓРїС–РІРµР»СЊ CSV</button>
        <button type="button" disabled={!canDo('reports.export')}>Р—РІС–С‚ РїРѕ РџР”Р’</button>
        <button type="button" disabled={!canDo('reports.export')}>Р•РєСЃРїРѕСЂС‚ РґР»СЏ BAS / 1РЎ</button>
        <button type="button" disabled={!canDo('reports.export')}>M.E.Doc</button>
      </section>
      <section className="panel">
        <div className="panel-heading"><h2>Р†РЅС‚РµРіСЂР°С†С–СЏ Р· BAS</h2><span>РїР»Р°С‚С„РѕСЂРјР° = РѕРїРµСЂР°С†С–Р№РЅР° СЃРёСЃС‚РµРјР°</span></div>
        <div className="task-list">
          <Task icon={<ClipboardList />} title="Р©Рѕ РїРµСЂРµРґР°С”РјРѕ" text="РђРєС‚Рё РІРёРєРѕРЅР°РЅРёС… СЂРѕР±С–С‚, РѕРїР»Р°С‚Рё, РїСЂРѕРґР°Р¶С–, Р·Р°РєСѓРїРєРё С– Р±РѕСЂРіРё РєР»С–С”РЅС‚С–РІ." />
          <Task icon={<Archive />} title="РџРµСЂС€РёР№ РµС‚Р°Рї" text="Р’РёРіСЂСѓР·РєР° Excel / CSV РґР»СЏ Р±СѓС…РіР°Р»С‚РµСЂР° Р±РµР· СЂСѓС‡РЅРѕРіРѕ Р·Р±РёСЂР°РЅРЅСЏ С‚Р°Р±Р»РёС†СЊ." />
          <Task icon={<CheckCircle2 />} title="Р”СЂСѓРіРёР№ РµС‚Р°Рї" text="API-С–РЅС‚РµРіСЂР°С†С–СЏ Р· BAS / 1РЎ РїС–СЃР»СЏ РїРѕСЏРІРё backend С– РїРѕРіРѕРґР¶РµРЅРЅСЏ С„РѕСЂРјР°С‚Сѓ РѕР±РјС–РЅСѓ." />
          <Task icon={<Banknote />} title="Р РѕР»СЊ BAS" text="BAS РІРёРєРѕСЂРёСЃС‚РѕРІСѓС”С‚СЊСЃСЏ РґР»СЏ Р±СѓС…РіР°Р»С‚РµСЂС–С—, Р·РІС–С‚РЅРѕСЃС‚С– С– РџР”Р’; CRM Р·Р°Р»РёС€Р°С”С‚СЊСЃСЏ РѕСЃРЅРѕРІРЅРѕСЋ СЃРёСЃС‚РµРјРѕСЋ Р·Р°РєР°Р·С–РІ, СЂРµРјРѕРЅС‚Сѓ, СЃРєР»Р°РґСѓ С– РѕРїР»Р°С‚." />
        </div>
      </section>
      <section className="panel">
        <div className="panel-heading"><h2>РљР°СЃР° С– С‚РµСЂРјС–РЅР°Р»</h2><span>{cashShift.id}</span></div>
        <div className="details-grid">
          <Info label="Р’С–РґРєСЂРёС‚С‚СЏ Р·РјС–РЅРё" value={cashShift.openedAt} />
          <Info label="РЎС‚Р°С‚СѓСЃ" value={cashShift.status} />
          <Info label="Р“РѕС‚С–РІРєР° РІ РєР°СЃС–" value={money(cashShift.cashIncome - cashShift.cashExpense)} />
          <Info label="РўРµСЂРјС–РЅР°Р»" value={money(cashShift.cardIncome)} />
          <Info label="Р‘РµР·РіРѕС‚С–РІРєР°" value={money(cashShift.bankIncome)} />
          <Info label="РџРѕРІРµСЂРЅРµРЅРЅСЏ РіРѕС‚С–РІРєРѕСЋ" value={money(cashShift.cashExpense)} />
        </div>
      </section>
      <section className="content-split">
        <div className="panel">
          <div className="panel-heading"><h2>Р’РёСЂСѓС‡РєР° РїРѕ РјРµРЅРµРґР¶РµСЂР°С…</h2><span>{Object.keys(managerRevenue).length} СЃРїС–РІСЂРѕР±С–С‚РЅРёРєС–РІ</span></div>
          <div className="task-list">
            {Object.entries(managerRevenue).map(([manager, value]) => <Task key={manager} icon={<Users />} title={manager} text={`Р’РёСЂСѓС‡РєР°: ${money(value)}`} />)}
          </div>
        </div>
        <div className="panel">
          <div className="panel-heading"><h2>РџСЂРёР±СѓС‚РѕРє</h2><span>С‚РѕРІР°СЂРё С– СЂРµРјРѕРЅС‚Рё</span></div>
          <div className="task-list">
            <Task icon={<PackageCheck />} title="РџСЂРёР±СѓС‚РѕРє РїРѕ С‚РѕРІР°СЂР°С…" text={canDo('reports.profit') || canDo('profit.view') ? money(productProfit) : 'РџСЂРёС…РѕРІР°РЅРѕ РїСЂР°РІР°РјРё РґРѕСЃС‚СѓРїСѓ'} />
            <Task icon={<Wrench />} title="РџСЂРёР±СѓС‚РѕРє РїРѕ СЂРµРјРѕРЅС‚Р°С…" text={canDo('reports.profit') || canDo('profit.view') ? money(repairProfit) : 'РџСЂРёС…РѕРІР°РЅРѕ РїСЂР°РІР°РјРё РґРѕСЃС‚СѓРїСѓ'} />
            <Task icon={<Truck />} title="РџРѕРІРµСЂРЅРµРЅРЅСЏ" text={`${returns.length} РґРѕРєСѓРјРµРЅС‚С–РІ`} />
          </div>
        </div>
      </section>
      <section className="panel">
        <div className="panel-heading"><h2>РљРѕРЅС‚СЂРѕР»СЊ СЃРєР»Р°РґСѓ С– Р»РѕРіС–РІ</h2><span>{movements.length} СЂСѓС…С–РІ В· {actionLogs.length} РґС–Р№</span></div>
        <div className="table movement-table">
          <div className="table-row table-head"><span>Р”Р°С‚Р°</span><span>РљРѕСЂРёСЃС‚СѓРІР°С‡</span><span>Р РѕР»СЊ</span><span>Р”С–СЏ</span><span>Р”РѕРєСѓРјРµРЅС‚</span><span>РљРѕРјРµРЅС‚Р°СЂ</span></div>
          {actionLogs.slice(0, 8).map((log) => (
            <div className="table-row" key={log.id}>
              <span>{log.date}</span>
              <span>{log.user}</span>
              <span>{log.role}</span>
              <span>{log.action}</span>
              <span>{log.entity}</span>
              <span>{log.comment}</span>
            </div>
          ))}
        </div>
      </section>
      <section className="panel">
        <div className="panel-heading"><h2>Р—Р°Р»РёС€РѕРє РїС–СЃР»СЏ РїСЂРѕРґР°Р¶С–РІ</h2><span>{products.length} РїРѕР·РёС†С–Р№</span></div>
        <div className="task-list">
          {products.map((product) => <Task key={product.id} icon={<Archive />} title={product.name} text={`Р”РѕСЃС‚СѓРїРЅРѕ ${available(product)} С€С‚., СЂРµР·РµСЂРІ ${product.reserved} С€С‚.`} />)}
        </div>
      </section>
    </div>
  );
}

function PayrollPage({ orders, activeUser }: { orders: ServiceOrder[]; activeUser: User }) {
  const closedStatuses: OrderStatus[] = ['Р’РёРґР°РЅРѕ', 'Р—Р°РєСЂРёС‚Рѕ'];
  const workRows = orders.flatMap((order) =>
    order.works.map((work, index) => {
      const employee = work.engineer ?? order.engineer;
      const rule = payrollRules.find((item) => item.employee === employee);
      const qty = work.qty ?? 1;
      const workAmount = work.price * qty;
      const accrued = closedStatuses.includes(order.status) ? payrollForWork(order, work, rule) : 0;
      return {
        id: `${order.id}-${index}`,
        order,
        work,
        employee,
        rule,
        qty,
        workAmount,
        accrualRule: work.accrualType === 'fixed_per_unit'
          ? `Р¤С–РєСЃ ${money(work.payrollFixedPerUnit ?? 0)} / С€С‚.`
          : `${work.payrollPercent ?? rule?.percent ?? 0}% РІС–Рґ СЂРѕР±РѕС‚Рё`,
        accrued,
        status: closedStatuses.includes(order.status) ? 'РќР°СЂР°С…РѕРІР°РЅРѕ' : 'РћС‡С–РєСѓС” Р·Р°РєСЂРёС‚С‚СЏ',
      };
    }),
  );
  const visibleRows = activeUser.role === 'Р†РЅР¶РµРЅРµСЂ' ? workRows.filter((row) => row.employee === activeUser.name) : workRows;
  const employeeSummaries = payrollRules.map((rule) => {
    const employeeRows = workRows.filter((row) => row.employee === rule.employee);
    const ordersCount = new Set(employeeRows.map((row) => row.order.id)).size;
    const operations = employeeRows.reduce((sum, row) => sum + row.qty, 0);
    const workAmount = employeeRows.reduce((sum, row) => sum + row.workAmount, 0);
    const accruedWorks = employeeRows.reduce((sum, row) => sum + row.accrued, 0);
    const isEngineer = rule.role === 'Р†РЅР¶РµРЅРµСЂ';
    const fixed = !isEngineer && rule.type === 'Р¤С–РєСЃРѕРІР°РЅР° СЃС‚Р°РІРєР°' ? rule.monthlyRate ?? 0 : 0;
    const bonus = isEngineer ? 0 : rule.bonus ?? 0;
    const returnsPenalty = isEngineer ? 0 : employeeRows.filter((row) => row.order.parts.some((part) => part.status === 'РџРѕРІРµСЂРЅРµРЅРЅСЏ')).length * (rule.penaltyPerReturn ?? 0);
    return {
      rule,
      ordersCount,
      operations,
      workAmount,
      accrued: isEngineer ? accruedWorks : Math.max(fixed + bonus - returnsPenalty, 0),
      fixed,
      bonus,
      returnsPenalty,
    };
  }).filter((row) => activeUser.role === 'Р†РЅР¶РµРЅРµСЂ' ? row.rule.employee === activeUser.name : true);
  const totalAccrued = employeeSummaries.reduce((sum, row) => sum + row.accrued, 0);
  const totalWorkAmount = visibleRows.reduce((sum, row) => sum + row.workAmount, 0);
  const pendingRows = visibleRows.filter((row) => row.status === 'РћС‡С–РєСѓС” Р·Р°РєСЂРёС‚С‚СЏ');

  return (
    <div className="page-grid">
      <PageTitle eyebrow="Р—Р°СЂРїР»Р°С‚Р°" title="РќР°СЂР°С…СѓРІР°РЅРЅСЏ РІС–Рґ РІРёРєРѕРЅР°РЅРёС… СЂРѕР±С–С‚" text="РљРѕР¶РЅР° РїРѕСЃР»СѓРіР° РјР°С” СЃРІРѕСЋ СЃС…РµРјСѓ: РїСЂРѕС†РµРЅС‚ РІС–Рґ СЃСѓРјРё СЂРѕР±РѕС‚Рё Р°Р±Рѕ С„С–РєСЃРѕРІР°РЅР° СЃС‚Р°РІРєР° Р·Р° РѕРґРёРЅРёС†СЋ. Р—Р°РјРѕРІР»РµРЅРЅСЏ РІ РїСЂРѕС†РµСЃС– РЅРµ РЅР°СЂР°С…РѕРІСѓСЋС‚СЊСЃСЏ, РїРѕРєРё РїСЂРёСЃС‚СЂС–Р№ РЅРµ РІРёРґР°РЅРѕ Р°Р±Рѕ Р·Р°РєР°Р· РЅРµ Р·Р°РєСЂРёС‚Рѕ." />
      <section className="stats-grid">
        <Metric icon={<Banknote />} label="РќР°СЂР°С…РѕРІР°РЅРѕ" value={money(totalAccrued)} hint="% РІС–Рґ СЂРѕР±РѕС‚Рё Р°Р±Рѕ С„С–РєСЃ Р·Р° РѕРґРёРЅРёС†СЋ" />
        <Metric icon={<Wrench />} label="РЎСѓРјР° СЂРѕР±С–С‚" value={money(totalWorkAmount)} hint="Р·Р° РІРёРґРёРјРёР№ РїРµСЂС–РѕРґ" />
        <Metric icon={<ClipboardList />} label="РћРїРµСЂР°С†С–Р№" value={String(visibleRows.reduce((sum, row) => sum + row.qty, 0))} hint="СЂСЏРґРєРё service_order_items" />
        <Metric icon={<History />} label="РћС‡С–РєСѓС” Р·Р°РєСЂРёС‚С‚СЏ" value={String(pendingRows.length)} hint="РЅРµ РІС…РѕРґРёС‚СЊ Сѓ Р·Р°СЂРїР»Р°С‚Сѓ" />
      </section>
      <section className="content-split">
        <div className="panel">
          <div className="panel-heading"><h2>РџС–РґСЃСѓРјРѕРє РїРѕ СЃРїС–РІСЂРѕР±С–С‚РЅРёРєР°С…</h2><span>{employeeSummaries.length} Р»СЋРґРµР№</span></div>
          <div className="task-list">
            {employeeSummaries.map((row) => (
              <Task key={row.rule.employee} icon={<Users />} title={`${row.rule.employee} В· ${row.rule.type}`} text={`Р—Р°РєР°Р·С–РІ ${row.ordersCount}, РѕРїРµСЂР°С†С–Р№ ${row.operations}, Р±Р°Р·Р° СЂРѕР±С–С‚ ${money(row.workAmount)}, СЃС‚Р°РІРєР° ${money(row.fixed)}, Р±РѕРЅСѓСЃ ${money(row.bonus)}, С€С‚СЂР°С„ ${money(row.returnsPenalty)}, РґРѕ РІРёРїР»Р°С‚Рё ${money(row.accrued)}.`} />
            ))}
          </div>
        </div>
        <div className="panel">
          <div className="panel-heading"><h2>РџСЂР°РІРёР»Р° РЅР°СЂР°С…СѓРІР°РЅРЅСЏ</h2><span>РјРѕР¶РЅР° Р·РјС–РЅСЋРІР°С‚Рё РІ РЅР°Р»Р°С€С‚СѓРІР°РЅРЅСЏС…</span></div>
          <div className="task-list">
            {payrollRules.filter((rule) => activeUser.role === 'Р†РЅР¶РµРЅРµСЂ' ? rule.employee === activeUser.name : true).map((rule) => (
              <Task key={rule.employee} icon={<ShieldCheck />} title={rule.employee} text={rule.role === 'Р†РЅР¶РµРЅРµСЂ' ? `Р‘Р°Р·РѕРІРёР№ РїСЂРѕС†РµРЅС‚ С–РЅР¶РµРЅРµСЂР°: ${rule.percent ?? 0}%. РЈ СЃР°РјС–Р№ РїРѕСЃР»СѓР·С– РјРѕР¶РЅР° РїРѕСЃС‚Р°РІРёС‚Рё percent_of_work_amount Р°Р±Рѕ fixed_per_unit.` : `${rule.type}. РЎС‚Р°РІРєР° ${money(rule.monthlyRate ?? 0)}, Р±РѕРЅСѓСЃ ${money(rule.bonus ?? 0)}.`} />
            ))}
          </div>
        </div>
      </section>
      <section className="panel">
        <div className="panel-heading"><h2>РЎРїРёСЃРѕРє СЂРѕР±С–С‚</h2><span>{visibleRows.length} СЂСЏРґРєС–РІ</span></div>
        <div className="table payroll-table">
          <div className="table-row table-head"><span>РЎРїС–РІСЂРѕР±С–С‚РЅРёРє</span><span>Р—Р°РєР°Р·</span><span>РџРѕСЃР»СѓРіР°</span><span>РЎС…РµРјР°</span><span>Рљ-СЃС‚СЊ</span><span>РЎСѓРјР°</span><span>РќР°СЂР°С…РѕРІР°РЅРѕ</span><span>РЎС‚Р°С‚СѓСЃ</span></div>
          {visibleRows.map((row) => (
            <div className="table-row" key={row.id}>
              <span>{row.employee}</span>
              <span>{row.order.id}<small>{row.order.status}</small></span>
              <span>{row.work.name}<small>{row.work.serviceType}</small></span>
              <span>{row.accrualRule}</span>
              <span>{row.qty}</span>
              <span>{money(row.workAmount)}</span>
              <span>{money(row.accrued)}</span>
              <span>{row.status}</span>
            </div>
          ))}
        </div>
      </section>
      <section className="panel">
        <div className="panel-heading"><h2>Р—Р°С…РёСЃС‚ РІС–Рґ СЃРїРѕСЂС–РІ</h2><span>РїСЂР°РІРёР»Р°</span></div>
        <div className="task-list">
          <Task icon={<CheckCircle2 />} title="РќРµ РїРѕ СЃР»РѕРІР°Рј" text="Р РѕР·СЂР°С…СѓРЅРѕРє С–РґРµ С‚С–Р»СЊРєРё РІС–Рґ service_order_items: С‚РёРї РїРѕСЃР»СѓРіРё, РєС–Р»СЊРєС–СЃС‚СЊ, С†С–РЅР°, СЃС…РµРјР° РЅР°СЂР°С…СѓРІР°РЅРЅСЏ, РІРёРєРѕРЅР°РІРµС†СЊ." />
          <Task icon={<ShieldCheck />} title="Р”РІС– СЃС…РµРјРё" text="Р РµРјРѕРЅС‚: percent_of_work_amount. Р—Р°РїСЂР°РІРєР° Р°Р±Рѕ СЂРµРіРµРЅРµСЂР°С†С–СЏ РєР°СЂС‚СЂРёРґР¶Р°: fixed_per_unit, РЅР°РїСЂРёРєР»Р°Рґ 30 Р°Р±Рѕ 50 РіСЂРЅ Р·Р° С€С‚СѓРєСѓ." />
          <Task icon={<History />} title="РќРµ РІ РїСЂРѕС†РµСЃС–" text="Р РѕР±РѕС‚Рё РІ Р·Р°РєР°Р·Р°С…, СЏРєС– С‰Рµ РЅРµ РІРёРґР°РЅС– Р°Р±Рѕ РЅРµ Р·Р°РєСЂРёС‚С–, РїРѕРєР°Р·СѓСЋС‚СЊСЃСЏ СЏРє РћС‡С–РєСѓС” Р·Р°РєСЂРёС‚С‚СЏ." />
          <Task icon={<X />} title="Р‘РµР· Р·Р°РґРЅСЊРѕРіРѕ С‡РёСЃР»Р°" text="РџС–СЃР»СЏ Р·Р°РєСЂРёС‚С‚СЏ СЂРµРјРѕРЅС‚Сѓ СЂРѕР±РѕС‚Рё С– РІР°СЂС‚С–СЃС‚СЊ РЅРµ РјРѕР¶РЅР° РјС–РЅСЏС‚Рё Р±РµР· РѕРєСЂРµРјРѕРіРѕ РїСЂР°РІР° С‚Р° Р°СѓРґРёС‚Сѓ." />
        </div>
      </section>
    </div>
  );
}

function AcceptanceChecklistPage() {
  const done = acceptanceChecklist.filter((item) => item.done).length;
  const total = acceptanceChecklist.length;
  return (
    <div className="page-grid">
      <PageTitle eyebrow="Р§РµРє-Р»РёСЃС‚ РїСЂРёР№РјР°РЅРЅСЏ" title="РљРѕРЅС‚СЂРѕР»СЊ РїРµСЂРµРґ РґРµРјРѕРЅСЃС‚СЂР°С†С–С”СЋ" text="Р¦РµР№ СЃРїРёСЃРѕРє РІРёРєРѕСЂРёСЃС‚РѕРІСѓС”С‚СЊСЃСЏ СЏРє С„С–РЅР°Р»СЊРЅР° РїРµСЂРµРІС–СЂРєР° СЃРёСЃС‚РµРјРё РїРµСЂРµРґ Р·РґР°С‡РµСЋ. РЎРёСЃС‚РµРјР° РІРІР°Р¶Р°С”С‚СЊСЃСЏ РіРѕС‚РѕРІРѕСЋ С‚С–Р»СЊРєРё РїС–СЃР»СЏ РїСЂРѕС…РѕРґР¶РµРЅРЅСЏ РІСЃС–С… РїСѓРЅРєС‚С–РІ." />
      <section className="stats-grid">
        <Metric icon={<CheckCircle2 />} label="Р“РѕС‚РѕРІРѕ" value={`${done}/${total}`} hint="РїРѕС‚РѕС‡РЅРёР№ MVP" />
        <Metric icon={<ShieldCheck />} label="Р‘РµР·РїРµРєР°" value="Р›РѕРіРё С– СЂРѕР»С–" hint="Р·Р°РєСЂРёС‚С– РґРѕРєСѓРјРµРЅС‚Рё Р·Р°С…РёС‰РµРЅС–" />
        <Metric icon={<Archive />} label="Backup" value="Cloud РµС‚Р°Рї" hint="С‰РѕРґРµРЅРЅРёР№ backup РЅР° VPS" />
        <Metric icon={<Wrench />} label="РђРЅС‚Рё-1РЎ" value="1-3 РєР»С–РєРё" hint="РїР»РѕСЃРєРµ РјРµРЅСЋ" />
      </section>
      <section className="panel">
        <div className="panel-heading"><h2>РџСѓРЅРєС‚Рё РїСЂРёР№РјР°РЅРЅСЏ</h2><span>{total} РїРµСЂРµРІС–СЂРѕРє</span></div>
        <div className="task-list">
          {acceptanceChecklist.map((item) => (
            <Task key={`${item.group}-${item.item}`} icon={item.done ? <CheckCircle2 /> : <History />} title={`${item.group} В· ${item.done ? 'РіРѕС‚РѕРІРѕ' : 'РїРѕС‚СЂС–Р±РµРЅ backend/cloud'}`} text={item.item} />
