  'Р“РѕС‚РѕРІРёР№ РґРѕ РІРёРґР°С‡С–': 'tag tag-teal',
  'РћС‡С–РєСѓС” РѕРїР»Р°С‚Рё': 'tag tag-amber',
  Р’РёРґР°РЅРѕ: 'tag tag-teal',
  Р—Р°РєСЂРёС‚Рѕ: 'tag tag-dark',
  РЎРєР°СЃРѕРІР°РЅРѕ: 'tag tag-gray',
  'РќРµ РїС–РґР»СЏРіР°С” СЂРµРјРѕРЅС‚Сѓ': 'tag tag-dark',
  'РћС‡С–РєСѓС” РєР»С–С”РЅС‚Р°': 'tag tag-amber',
  'РџР°СѓР·Р° / РІС–РґРєР»Р°РґРµРЅРѕ': 'tag tag-gray',
  РЎС‚РІРѕСЂРµРЅРѕ: 'tag tag-gray',
  'Р§Р°СЃС‚РєРѕРІРѕ РїСЂРёР±СѓР»Рѕ': 'tag tag-amber',
  Р§РµСЂРЅРµС‚РєР°: 'tag tag-gray',
  'Р§Р°СЃС‚РєРѕРІРѕ РѕРїР»Р°С‡РµРЅРѕ': 'tag tag-amber',
  РћРїР»Р°С‡РµРЅРѕ: 'tag tag-green',
};

function money(value: number) {
  return new Intl.NumberFormat('uk-UA', { style: 'currency', currency: 'UAH', maximumFractionDigits: 0 }).format(value);
}

function uid(prefix: string) {
  return `${prefix}-${Date.now().toString(36)}-${Math.random().toString(36).slice(2, 6)}`;
}

function available(product: Product) {
  return Math.max(product.stock - product.reserved, 0);
}

function batchTotalAvailable(product: Product) {
  return product.batches.reduce((sum, batch) => sum + batch.qtyAvailable, 0);
}

function oldestBatchAge(product: Product) {
  if (product.batches.length === 0) return 0;
  return Math.max(...product.batches.map((batch) => daysSince(batch.purchaseDate)));
}

function fifoConsumeBatches(product: Product, qty: number) {
  let remaining = qty;
  const allocations: BatchAllocation[] = [];
  const batches = product.batches.map((batch) => {
    if (remaining <= 0 || batch.qtyAvailable <= 0) return batch;
    const taken = Math.min(batch.qtyAvailable, remaining);
    if (taken > 0) {
      allocations.push({ batchId: batch.id, qty: taken, unitCost: batch.purchasePrice, purchaseDate: batch.purchaseDate });
      remaining -= taken;
      return { ...batch, qtyAvailable: batch.qtyAvailable - taken };
    }
    return batch;
  });
  if (remaining > 0) return null;
  const totalCost = allocations.reduce((sum, item) => sum + item.qty * item.unitCost, 0);
  return { batches, allocations, totalCost };
}

function restoreBatchAllocations(product: Product, allocations: BatchAllocation[]) {
  return product.batches.map((batch) => {
    const allocation = allocations.find((item) => item.batchId === batch.id);
    return allocation ? { ...batch, qtyAvailable: batch.qtyAvailable + allocation.qty } : batch;
  });
}

function saleTotals(sale: Sale) {
  const activeItems = sale.items.filter((item) => item.status !== 'РЎРєР°СЃРѕРІР°РЅРѕ');
  const sum = activeItems.reduce((total, item) => total + item.price * item.qty, 0);
  const discount = activeItems.reduce((total, item) => total + item.discount, 0);
  const paid = sale.payments.filter((payment) => payment.status !== 'РћС‡С–РєСѓС” РїС–РґС‚РІРµСЂРґР¶РµРЅРЅСЏ').reduce((total, payment) => total + payment.amount, 0);
  const cost = activeItems.filter((item) => item.status === 'Р’РёРґР°РЅРѕ').reduce((total, item) => total + item.cost * item.qty, 0);
  const returns = sale.returns.reduce((total, item) => total + item.refund, 0);
  const total = Math.max(sum - discount, 0);
  return { sum, discount, total, paid, debt: Math.max(total - paid, 0), cost, returns, profit: total - cost - returns };
}

function orderTotals(order: ServiceOrder) {
  const works = order.works.reduce((sum, work) => sum + work.price * (work.qty ?? 1), 0);
  const parts = order.parts.reduce((sum, part) => sum + part.price * part.qty, 0);
  const delivery = order.deliveryAmount ?? 0;
  const additionalExpenses = order.additionalExpenses ?? 0;
  const consumables = order.consumablesAmount ?? 0;
  const externalServices = order.externalServicesAmount ?? 0;
  const paid = order.payments.filter((payment) => payment.status !== 'РћС‡С–РєСѓС” РїС–РґС‚РІРµСЂРґР¶РµРЅРЅСЏ').reduce((sum, payment) => sum + payment.amount, 0);
  const purchaseCost = order.parts.filter((part) => part.status !== 'РџРѕРІРµСЂРЅРµРЅРЅСЏ').reduce((sum, part) => sum + part.cost * part.qty, 0);
  const engineerSalary = order.works.reduce((sum, work) => {
    const engineerName = work.engineer ?? order.engineer;
    const rule = payrollRules.find((item) => item.employee === engineerName);
    return sum + payrollForWork(order, work, rule);
  }, 0);
  const cost = purchaseCost + engineerSalary + delivery + additionalExpenses + consumables + externalServices;
  const total = works + parts + delivery;
  const isFinal = ['Р—Р°РєСЂРёС‚Рѕ', 'Р’РёРґР°РЅРѕ'].includes(order.status);
  return { works, parts, delivery, additionalExpenses, consumables, externalServices, total, paid, debt: Math.max(total - paid, 0), purchaseCost, engineerSalary, cost, profit: total - cost, finalProfit: isFinal ? total - cost : 0, isFinal };
}

function paymentTypeFor(amount: number, debtBeforePayment: number, fallback: PaymentType): PaymentType {
  if (fallback === 'РџРµСЂРµРґРїР»Р°С‚Р°' || fallback === 'РџРѕРІРµСЂРЅРµРЅРЅСЏ РєРѕС€С‚С–РІ') return fallback;
  if (amount >= debtBeforePayment) return 'РџРѕРІРЅР° РѕРїР»Р°С‚Р°';
  return 'Р§Р°СЃС‚РєРѕРІР° РѕРїР»Р°С‚Р°';
}

function vatFromGross(amount: number, rate = 0.2) {
  const net = amount / (1 + rate);
  return { net, vat: amount - net, gross: amount, rate };
}

function documentVatTotals(amountGross: number) {
  const vat = vatFromGross(amountGross);
  return { amountNet: vat.net, amountVat: vat.vat, amountGross: vat.gross };
}

function amountInWordsUA(amount: number) {
  const hryvnias = Math.floor(amount);
  const kop = Math.round((amount - hryvnias) * 100);
  return `${hryvnias.toLocaleString('uk-UA')} РіСЂРЅ ${String(kop).padStart(2, '0')} РєРѕРї.`;
}

function clientDetails(name: string, phone?: string): ClientRequisites {
  return clientRequisites[name] ?? { name, edrpou: 'РЅРµ РІРєР°Р·Р°РЅРѕ', address: 'РЅРµ РІРєР°Р·Р°РЅРѕ', contract: 'Р‘РµР· РґРѕРіРѕРІРѕСЂСѓ, Р·РіС–РґРЅРѕ СЂР°С…СѓРЅРєСѓ', contact: phone ?? 'РЅРµ РІРєР°Р·Р°РЅРѕ' };
}

function repairPaymentStatus(order: ServiceOrder): RepairPaymentStatus {
  const totals = orderTotals(order);
  if (order.payments.some((payment) => payment.type === 'РџРѕРІРµСЂРЅРµРЅРЅСЏ РєРѕС€С‚С–РІ')) return 'РџРѕРІРµСЂРЅРµРЅРЅСЏ';
  if (totals.paid <= 0 && totals.debt > 0) return 'РќРµ РѕРїР»Р°С‡РµРЅРѕ';
  if (totals.paid > 0 && totals.debt > 0) return order.payments.some((payment) => payment.type === 'РџРµСЂРµРґРїР»Р°С‚Р°') ? 'РџРµСЂРµРґРїР»Р°С‚Р°' : 'Р§Р°СЃС‚РєРѕРІРѕ РѕРїР»Р°С‡РµРЅРѕ';
  if (totals.debt <= 0 && totals.total > 0) return 'РџРѕРІРЅС–СЃС‚СЋ РѕРїР»Р°С‡РµРЅРѕ';
  return totals.debt > 0 ? 'Р‘РѕСЂРі' : 'РќРµ РѕРїР»Р°С‡РµРЅРѕ';
}

function payrollForWork(order: ServiceOrder, work: ServiceWork, rule?: PayrollRule) {
  const qty = work.qty ?? 1;
  const base = work.price * qty;
  if (work.accrualType === 'fixed_per_unit') return Math.round((work.payrollFixedPerUnit ?? 0) * qty);
  const percent = work.payrollPercent ?? rule?.percent ?? 0;
  return Math.round(base * (percent / 100));
}

const orderStatusFlow: Partial<Record<OrderStatus, OrderStatus[]>> = {
  РџСЂРёР№РЅСЏС‚Рѕ: ['РќР° РґС–Р°РіРЅРѕСЃС‚РёС†С–', 'Р’ СЂРµРјРѕРЅС‚С–', 'РЎРєР°СЃРѕРІР°РЅРѕ'],
  'РќР° РґС–Р°РіРЅРѕСЃС‚РёС†С–': ['РћС‡С–РєСѓС” РїРѕРіРѕРґР¶РµРЅРЅСЏ', 'РќРµ РїС–РґР»СЏРіР°С” СЂРµРјРѕРЅС‚Сѓ', 'РџР°СѓР·Р° / РІС–РґРєР»Р°РґРµРЅРѕ'],
  'РћС‡С–РєСѓС” РїРѕРіРѕРґР¶РµРЅРЅСЏ': ['РџРѕРіРѕРґР¶РµРЅРѕ', 'РЎРєР°СЃРѕРІР°РЅРѕ', 'РћС‡С–РєСѓС” РєР»С–С”РЅС‚Р°'],
  РџРѕРіРѕРґР¶РµРЅРѕ: ['РћС‡С–РєСѓС” Р·Р°РїС‡Р°СЃС‚РёРЅСѓ', 'Р’ СЂРµРјРѕРЅС‚С–', 'РЎРєР°СЃРѕРІР°РЅРѕ'],
  'РћС‡С–РєСѓС” Р·Р°РїС‡Р°СЃС‚РёРЅСѓ': ['Р’ СЂРµРјРѕРЅС‚С–', 'РџР°СѓР·Р° / РІС–РґРєР»Р°РґРµРЅРѕ', 'РЎРєР°СЃРѕРІР°РЅРѕ'],
  'Р’ СЂРµРјРѕРЅС‚С–': ['РќР° С‚РµСЃС‚СѓРІР°РЅРЅС–', 'РџР°СѓР·Р° / РІС–РґРєР»Р°РґРµРЅРѕ', 'РќРµ РїС–РґР»СЏРіР°С” СЂРµРјРѕРЅС‚Сѓ'],
  'РќР° С‚РµСЃС‚СѓРІР°РЅРЅС–': ['Р“РѕС‚РѕРІРёР№ РґРѕ РІРёРґР°С‡С–', 'Р’ СЂРµРјРѕРЅС‚С–'],
  'Р“РѕС‚РѕРІРёР№ РґРѕ РІРёРґР°С‡С–': ['РћС‡С–РєСѓС” РѕРїР»Р°С‚Рё', 'РћС‡С–РєСѓС” РєР»С–С”РЅС‚Р°', 'Р’РёРґР°РЅРѕ'],
  'РћС‡С–РєСѓС” РѕРїР»Р°С‚Рё': ['Р’РёРґР°РЅРѕ', 'РћС‡С–РєСѓС” РєР»С–С”РЅС‚Р°'],
  'РћС‡С–РєСѓС” РєР»С–С”РЅС‚Р°': ['Р’РёРґР°РЅРѕ', 'РЎРєР°СЃРѕРІР°РЅРѕ'],
  'РќРµ РїС–РґР»СЏРіР°С” СЂРµРјРѕРЅС‚Сѓ': ['Р’РёРґР°РЅРѕ'],
  Р’РёРґР°РЅРѕ: ['Р—Р°РєСЂРёС‚Рѕ'],
  'РџР°СѓР·Р° / РІС–РґРєР»Р°РґРµРЅРѕ': ['РќР° РґС–Р°РіРЅРѕСЃС‚РёС†С–', 'Р’ СЂРµРјРѕРЅС‚С–', 'РћС‡С–РєСѓС” РїРѕРіРѕРґР¶РµРЅРЅСЏ', 'РЎРєР°СЃРѕРІР°РЅРѕ'],
};

const managerStatuses: OrderStatus[] = ['РџСЂРёР№РЅСЏС‚Рѕ', 'РћС‡С–РєСѓС” РїРѕРіРѕРґР¶РµРЅРЅСЏ', 'РџРѕРіРѕРґР¶РµРЅРѕ', 'Р“РѕС‚РѕРІРёР№ РґРѕ РІРёРґР°С‡С–', 'РћС‡С–РєСѓС” РѕРїР»Р°С‚Рё', 'РћС‡С–РєСѓС” РєР»С–С”РЅС‚Р°', 'Р’РёРґР°РЅРѕ', 'РЎРєР°СЃРѕРІР°РЅРѕ', 'РќРµ РїС–РґР»СЏРіР°С” СЂРµРјРѕРЅС‚Сѓ'];
const engineerStatuses: OrderStatus[] = ['РќР° РґС–Р°РіРЅРѕСЃС‚РёС†С–', 'РћС‡С–РєСѓС” РїРѕРіРѕРґР¶РµРЅРЅСЏ', 'РћС‡С–РєСѓС” Р·Р°РїС‡Р°СЃС‚РёРЅСѓ', 'Р’ СЂРµРјРѕРЅС‚С–', 'РќР° С‚РµСЃС‚СѓРІР°РЅРЅС–', 'Р“РѕС‚РѕРІРёР№ РґРѕ РІРёРґР°С‡С–', 'РќРµ РїС–РґР»СЏРіР°С” СЂРµРјРѕРЅС‚Сѓ', 'РџР°СѓР·Р° / РІС–РґРєР»Р°РґРµРЅРѕ'];

function roleCanSetOrderStatus(role: Role, status: OrderStatus) {
  if (role === 'Р СѓРєРѕРІРѕРґРёС‚РµР»СЊ' || role === 'РђРґРјС–РЅС–СЃС‚СЂР°С‚РѕСЂ') return true;
  if (role === 'РњРµРЅРµРґР¶РµСЂ') return managerStatuses.includes(status);
  if (role === 'Р†РЅР¶РµРЅРµСЂ') return engineerStatuses.includes(status);
  return false;
}

function daysSince(dateText: string) {
  const match = dateText.match(/(\d{2})\.(\d{2})\.(\d{4})/);
  if (!match) return 0;
  const [, day, month, year] = match;
  const date = new Date(Number(year), Number(month) - 1, Number(day));
  const now = new Date(2026, 3, 21);
  return Math.max(0, Math.floor((now.getTime() - date.getTime()) / 86400000));
}

function buildServiceProblems(orders: ServiceOrder[], documents: PrintDocument[]) {
  const problems: ServiceProblem[] = [];
  const hasDocument = (orderId: string, kinds: DocumentKind[]) => documents.some((document) => document.entityType === 'service_order' && document.entityId === orderId && kinds.includes(document.kind));
  const addProblem = (order: ServiceOrder, type: ServiceProblemType, description: string, level: ServiceProblemLevel, days: number, target: ServiceProblem['target'], responsible = order.manager) => {
    problems.push({
      id: `${order.id}-${type}`,
      orderId: order.id,
      client: order.client,
      type,
      description,
      days,
      responsible,
      engineer: order.engineer,
      manager: order.manager,
      level,
      target,
    });
  };

  orders.forEach((order) => {
    const totals = orderTotals(order);
    const statusAge = daysSince(order.statusChangedAt);
    const actAge = order.actIssuedAt ? daysSince(order.actIssuedAt) : statusAge;
    const hasAct = hasDocument(order.id, ['РђРєС‚ РЅР°РґР°РЅРЅСЏ РїРѕСЃР»СѓРі', 'РђРєС‚ РІРёРєРѕРЅР°РЅРёС… СЂРѕР±С–С‚', 'РђРєС‚ РІРёРґР°С‡С–']);
    const hasDelivery = hasDocument(order.id, ['Р’РёРґР°С‚РєРѕРІР° РЅР°РєР»Р°РґРЅР°']);
    const hasTaxEvent = order.vatStatus === 'Р“РѕС‚РѕРІРѕ РґРѕ СЂРµС”СЃС‚СЂР°С†С–С— РџРќ' || order.vatStatus === 'РџРќ Р·Р°СЂРµС”СЃС‚СЂРѕРІР°РЅР°' || order.vatStatus === 'РџСЂРѕСЃС‚СЂРѕС‡РµРЅР° СЂРµС”СЃС‚СЂР°С†С–СЏ РџРќ';
    const hasActOrPayment = hasAct || totals.paid > 0;
    const isClosed = ['Р—Р°РєСЂРёС‚Рѕ', 'Р’РёРґР°РЅРѕ', 'РЎРєР°СЃРѕРІР°РЅРѕ'].includes(order.status);

    if (['Р“РѕС‚РѕРІРёР№ РґРѕ РІРёРґР°С‡С–', 'РћС‡С–РєСѓС” РєР»С–С”РЅС‚Р°', 'РћС‡С–РєСѓС” РѕРїР»Р°С‚Рё'].includes(order.status) && statusAge > 1 && !isClosed) {
      addProblem(order, 'Р—Р°РєР°Р· РіРѕС‚РѕРІРёР№, Р°Р»Рµ РЅРµ РІРёРґР°РЅРёР№', 'Р—Р°РєР°Р· РіРѕС‚РѕРІРёР№ Р±С–Р»СЊС€Рµ 24 РіРѕРґРёРЅ, Р°Р»Рµ РєР»С–С”РЅС‚Сѓ С‰Рµ РЅРµ РІРёРґР°РЅРёР№.', 'Р’Р°Р¶Р»РёРІРѕ', statusAge, 'order', order.manager);
    }
    if (hasAct && totals.paid === 0 && actAge > 1) {
      addProblem(order, 'РђРєС‚ С”, РѕРїР»Р°С‚Р° РІС–РґСЃСѓС‚РЅСЏ', 'РђРєС‚ СЃС„РѕСЂРјРѕРІР°РЅРѕ, Р°Р»Рµ РЅРµРјР°С” Р¶РѕРґРЅРѕС— РїС–РґС‚РІРµСЂРґР¶РµРЅРѕС— РѕРїР»Р°С‚Рё.', 'РљСЂРёС‚РёС‡РЅРѕ', actAge, 'payment', order.manager);
    }
    if (order.parts.length > 0 && !hasDelivery) {
      addProblem(order, 'Р—Р°РїС‡Р°СЃС‚РёРЅРё СЃРїРёСЃР°РЅС–, Р°Р»Рµ РЅРµРјР°С” РІРёРґР°С‚РєРѕРІРѕС— РЅР°РєР»Р°РґРЅРѕС—', 'РЈ Р·Р°РєР°Р·С– С” СЃРєР»Р°РґСЃСЊРєС– РїРѕР·РёС†С–С—, Р°Р»Рµ РІРёРґР°С‚РєРѕРІР° РЅР°РєР»Р°РґРЅР° РЅРµ СЃС‚РІРѕСЂРµРЅР°.', 'РљСЂРёС‚РёС‡РЅРѕ', statusAge, 'document', order.manager);
    }
    if (['Р“РѕС‚РѕРІРёР№ РґРѕ РІРёРґР°С‡С–', 'РћС‡С–РєСѓС” РѕРїР»Р°С‚Рё', 'РћС‡С–РєСѓС” РєР»С–С”РЅС‚Р°'].includes(order.status) && !hasAct) {
      addProblem(order, 'РќРµРјР°С” Р°РєС‚Р° РІРёРєРѕРЅР°РЅРёС… СЂРѕР±С–С‚', 'Р РѕР±РѕС‚Р° Р·Р°РІРµСЂС€РµРЅР°, Р°Р»Рµ Р°РєС‚ С‰Рµ РЅРµ СЃС„РѕСЂРјРѕРІР°РЅРѕ.', 'РљСЂРёС‚РёС‡РЅРѕ', statusAge, 'act', order.manager);
    }
    if (hasActOrPayment && !hasTaxEvent) {
      addProblem(order, 'РќРµРјР°С” РїС–РґСЃС‚Р°РІРё РґР»СЏ РїРѕРґР°С‚РєРѕРІРѕС— РЅР°РєР»Р°РґРЅРѕС—', 'Р„ Р°РєС‚ Р°Р±Рѕ РѕРїР»Р°С‚Р°, Р°Р»Рµ Р·Р°РєР°Р· РЅРµ РїРѕР·РЅР°С‡РµРЅРёР№ СЏРє РіРѕС‚РѕРІРёР№ РґРѕ РќРќ.', 'РљСЂРёС‚РёС‡РЅРѕ', Math.max(actAge, daysSince(order.debtSince ?? order.intakeDate)), 'act', 'Р‘СѓС…РіР°Р»С‚РµСЂ');
    }
    if (order.status === 'Р’ СЂРµРјРѕРЅС‚С–' && statusAge > 2) {
      addProblem(order, 'Р—Р°РєР°Р· Р±РµР· СЂСѓС…Сѓ', 'Р—Р°РєР°Р· Сѓ СЂРѕР±РѕС‚С– Р±РµР· Р·РјС–РЅРё СЃС‚Р°С‚СѓСЃСѓ Р±С–Р»СЊС€Рµ 2 РґРЅС–РІ.', 'Р’Р°Р¶Р»РёРІРѕ', statusAge, 'order', order.engineer);
    }
    if (order.actIssuedAt && !order.actReturnedAt && actAge > 3) {
      addProblem(order, 'РђРєС‚ РЅРµ РїРѕРІРµСЂРЅРµРЅРёР№ РєР»С–С”РЅС‚РѕРј', 'РђРєС‚ РІРёРґР°РЅРѕ, Р°Р»Рµ РїС–РґРїРёСЃ РєР»С–С”РЅС‚Р° РЅРµ Р·Р°С„С–РєСЃРѕРІР°РЅРѕ.', 'Р’Р°Р¶Р»РёРІРѕ', actAge, 'act', order.manager);
    }
    if (totals.paid > 0 && totals.paid < totals.total && !isClosed) {
      addProblem(order, 'Р„ Р·Р°Р±РѕСЂРіРѕРІР°РЅС–СЃС‚СЊ РїРѕ Р·Р°РєР°Р·Сѓ', `РћРїР»Р°С‡РµРЅРѕ ${money(totals.paid)} С–Р· ${money(totals.total)}.`, 'РљСЂРёС‚РёС‡РЅРѕ', daysSince(order.debtSince ?? order.intakeDate), 'payment', order.manager);
    }
  });

  return problems.sort((a, b) => {
    const priority = { РљСЂРёС‚РёС‡РЅРѕ: 0, Р’Р°Р¶Р»РёРІРѕ: 1, Р†РЅС„РѕСЂРјР°С†С–СЏ: 2 };
    return priority[a.level] - priority[b.level] || b.days - a.days;
  });
}

function defaultPageForRole(role: Role): Page {
  if (role === 'Р†РЅР¶РµРЅРµСЂ') return 'my-orders';
  return 'dashboard';
}

export function WarehouseCRM() {
  const [page, setPage] = useState<Page>(() => {
  return (localStorage.getItem('page') as Page) || 'dashboard';
});

useEffect(() => {
  localStorage.setItem('page', page);
}, [page]);
  const [activeUserId, setActiveUserId] = useState(() => {
  return localStorage.getItem('activeUserId') || currentUser.id;
});
useEffect(() => {
  localStorage.setItem('activeUserId', activeUserId);
}, [activeUserId]);
  const [showMenu, setShowMenu] = useState(false);
  const [query, setQuery] = useState('');
  const [products, setProducts] = useState<Product[]>(initialProducts);
  const [orders, setOrders] = useState<ServiceOrder[]>(initialOrders);
  const [customerList, setCustomerList] = useState(initialClients);
  const [sales, setSales] = useState<Sale[]>(initialSales);
  const [documents, setDocuments] = useState<PrintDocument[]>(initialDocuments);
  const [clientNotifications, setClientNotifications] = useState<ClientNotification[]>(initialClientNotifications);
  const [internalMessages, setInternalMessages] = useState<InternalMessage[]>(initialInternalMessages);
  const [notificationTemplates] = useState<ClientNotificationTemplate[]>(clientNotificationTemplates);
  const [repairApprovals, setRepairApprovals] = useState<RepairApproval[]>(initialRepairApprovals);
  const [requirements, setRequirements] = useState<PartRequirement[]>([]);
  const [purchases, setPurchases] = useState<PurchaseOrder[]>([]);
  const [receipts, setReceipts] = useState<GoodsReceipt[]>([]);
  const [movements, setMovements] = useState<StockMovement[]>([]);
  const [cashShift, setCashShift] = useState<CashShift>(initialCashShift);
  const [actionLogs, setActionLogs] = useState<ActionLog[]>([
    { id: 'LOG-1', date: today, user: currentUser.name, role: currentUser.role, action: 'Р’С…С–Рґ Сѓ СЃРёСЃС‚РµРјСѓ', entity: 'РЎРµСЃС–СЏ', comment: 'РЈСЃРїС–С€РЅРёР№ РІС…С–Рґ, 2FA СѓРІС–РјРєРЅРµРЅРѕ РґР»СЏ СЂРѕР»С– Р°РґРјС–РЅС–СЃС‚СЂР°С‚РѕСЂР°.' },
  ]);
  const [selectedOrderId, setSelectedOrderId] = useState(initialOrders[0].id);
  const [selectedSaleId, setSelectedSaleId] = useState(initialSales[0].id);
  const [selectedProductId, setSelectedProductId] = useState(initialProducts[0].id);
  const [selectedSaleProductId, setSelectedSaleProductId] = useState(initialProducts[0].id);
  const [qty, setQty] = useState(1);
  const [saleQty, setSaleQty] = useState(1);
  const [quickPhone, setQuickPhone] = useState('');
  const [quickClientName, setQuickClientName] = useState('');
  const [quickDevice, setQuickDevice] = useState('');
  const [quickProblem, setQuickProblem] = useState('');
  const [quickEngineerId, setQuickEngineerId] = useState(users.find((user) => user.role === 'Р†РЅР¶РµРЅРµСЂ')?.id ?? '');
  const [notice, setNotice] = useState('');

  const activeUser = users.find((user) => user.id === activeUserId) ?? currentUser;
  const canSwitchUsers = currentUser.role === 'Р СѓРєРѕРІРѕРґРёС‚РµР»СЊ' && activeUser.role === 'Р СѓРєРѕРІРѕРґРёС‚РµР»СЊ';
  const isOwnerControlView = currentUser.role === 'Р СѓРєРѕРІРѕРґРёС‚РµР»СЊ' && activeUser.id !== currentUser.id;
  const canViewPage = (targetPage: Page) => rolePageAccess[activeUser.role].includes(targetPage);
  const canDo = (permission: Permission) => roleFinePermissions[activeUser.role].includes(permission);
  const visibleNavItems = navItems.filter((item) => canViewPage(item.id));
  const engineerOwnOrders = activeUser.role === 'Р†РЅР¶РµРЅРµСЂ' ? orders.filter((order) => order.engineer === activeUser.name) : orders;
  const engineerHiddenAfterReady: OrderStatus[] = ['Р“РѕС‚РѕРІРёР№ РґРѕ РІРёРґР°С‡С–', 'РќРµ РїС–РґР»СЏРіР°С” СЂРµРјРѕРЅС‚Сѓ', 'Р’РёРґР°РЅРѕ', 'Р—Р°РєСЂРёС‚Рѕ', 'РЎРєР°СЃРѕРІР°РЅРѕ'];
  const visibleOrders = activeUser.role === 'Р†РЅР¶РµРЅРµСЂ'
    ? engineerOwnOrders.filter((order) => !engineerHiddenAfterReady.includes(order.status))
    : orders;
  const selectedOrder = visibleOrders.find((order) => order.id === selectedOrderId) ?? visibleOrders[0] ?? (activeUser.role === 'Р†РЅР¶РµРЅРµСЂ' ? engineerOwnOrders[0] : orders[0]) ?? orders[0];
  const selectedSale = sales.find((sale) => sale.id === selectedSaleId) ?? sales[0];
  const visibleInternalMessages = activeUser.role === 'Р СѓРєРѕРІРѕРґРёС‚РµР»СЊ'
    ? internalMessages
    : internalMessages.filter((message) => message.toUser === activeUser.name || message.toRole === activeUser.role);
  const unreadInternalMessages = visibleInternalMessages.filter((message) => message.status === 'РќРѕРІРµ').length;
  const filteredOrders = useMemo(() => {
    const needle = query.trim().toLowerCase();
    if (!needle) return visibleOrders;
    return visibleOrders.filter((order) => [order.id, order.client, order.phone, order.device, order.serial, order.issue].join(' ').toLowerCase().includes(needle));
  }, [visibleOrders, query]);

  const analytics = useMemo(() => {
    const stockValue = products.reduce((sum, product) => sum + product.stock * product.cost, 0);
    const partsInRepairs = products.reduce((sum, product) => sum + product.reserved + product.withEngineer + product.installed, 0);
    const ordered = purchases.reduce((sum, purchase) => sum + purchase.items.reduce((inner, item) => inner + item.qty - item.received, 0), 0);
    const required = requirements.filter((item) => item.status === 'РџРѕС‚СЂС–Р±РЅРѕ' || item.status === 'Р”Рѕ Р·Р°РєСѓРїС–РІР»С–').reduce((sum, item) => sum + item.qty, 0);
    const salesRevenue = sales.reduce((sum, sale) => sum + saleTotals(sale).paid, 0);
    const salesDebt = sales.reduce((sum, sale) => sum + saleTotals(sale).debt, 0);
    const serviceDebt = orders.reduce((sum, order) => sum + orderTotals(order).debt, 0);
    const salesProfit = sales.reduce((sum, sale) => sum + saleTotals(sale).profit, 0);
    const serviceProfit = orders.reduce((sum, order) => sum + orderTotals(order).finalProfit, 0);
    return { stockValue, partsInRepairs, ordered, required, salesRevenue, salesDebt, serviceDebt, salesProfit, serviceProfit };
  }, [products, purchases, requirements, sales, orders]);

  function productName(productId: string) {
    return products.find((product) => product.id === productId)?.name ?? 'РќРµРІС–РґРѕРјР° Р·Р°РїС‡Р°СЃС‚РёРЅР°';
  }

  function addMovement(movement: Omit<StockMovement, 'id' | 'date'>) {
    setMovements((current) => [{ id: uid('MOV'), date: today, ...movement }, ...current]);
  }

  function logAction(action: string, entity: string, comment: string) {
    setActionLogs((current) => [{ id: uid('LOG'), date: today, user: activeUser.name, role: activeUser.role, action, entity, comment }, ...current]);
  }

  function handleQuickPhoneChange(phone: string) {
    setQuickPhone(phone);
    const normalized = phone.replace(/\D/g, '');
    const found = customerList.find((client) => client.phone.replace(/\D/g, '').includes(normalized) || normalized.includes(client.phone.replace(/\D/g, '')));
    if (normalized.length >= 7 && found) {
      setQuickClientName(found.name);
    }
  }

  function createQuickOrder() {
    const engineer = users.find((user) => user.id === quickEngineerId && user.role === 'Р†РЅР¶РµРЅРµСЂ');
    if (!quickPhone.trim() || !quickClientName.trim() || !quickDevice.trim() || !quickProblem.trim() || !engineer) {
      setNotice('РЁРІРёРґРєРёР№ РїСЂРёР№РѕРј: Р·Р°РїРѕРІРЅС–С‚СЊ С‚РµР»РµС„РѕРЅ, С–РјКјСЏ, РїСЂРёСЃС‚СЂС–Р№, РїСЂРѕР±Р»РµРјСѓ С‚Р° С–РЅР¶РµРЅРµСЂР°.');
      return;
    }
    const nextNumber = orders.reduce((max, order) => {
      const match = order.id.match(/(\d+)/);
      return Math.max(max, match ? Number(match[1]) : 0);
    }, 1040) + 1;
    const orderId = `Р—Рќ-${nextNumber}`;
    const clientExists = customerList.some((client) => client.phone.replace(/\D/g, '') === quickPhone.replace(/\D/g, ''));
    if (!clientExists) {
      setCustomerList((current) => [{ name: quickClientName.trim(), phone: quickPhone.trim(), orders: 1 }, ...current]);
    } else {
      setCustomerList((current) => current.map((client) => (client.phone.replace(/\D/g, '') === quickPhone.replace(/\D/g, '') ? { ...client, name: quickClientName.trim(), orders: client.orders + 1 } : client)));
    }

    const order: ServiceOrder = {
      id: orderId,
      groupId: `GR-${today.replace(/\D/g, '')}-${orders.length + 1}`,
      qrUrl: `/orders/${orderId}`,
      client: quickClientName.trim(),
      phone: quickPhone.trim(),
      device: quickDevice.trim(),
      serial: 'РќРµ РІРєР°Р·Р°РЅРѕ',
      issue: quickProblem.trim(),
      engineer: engineer.name,
      manager: activeUser.name,
      legalEntity: false,
      status: 'РџСЂРёР№РЅСЏС‚Рѕ',
      statusChangedAt: today,
      intakeDate: today,
      promisedDate: 'РЈС‚РѕС‡РЅСЋС”С‚СЊСЃСЏ',
      deliveryAmount: 0,
      works: [],
      parts: [],
      payments: [],
      statusHistory: [
        { id: uid('H'), newStatus: 'РџСЂРёР№РЅСЏС‚Рѕ', changedBy: activeUser.name, changedAt: today, comment: 'РЁРІРёРґРєРёР№ РїСЂРёР№РѕРј Р·Р° 30 СЃРµРєСѓРЅРґ: Р·Р°РєР°Р· СЃС‚РІРѕСЂРµРЅРѕ Р±РµР· РїРµСЂРµС…РѕРґС–РІ.' },
      ],
    };
    setOrders((current) => [order, ...current]);
    setDocuments((current) => {
      const number = `РќР -${current.length + 1001}`;
      const totals = documentVatTotals(0);
      return [{
        id: uid('DOC'),
        kind: 'РќР°СЂСЏРґ РЅР° СЂРµРјРѕРЅС‚',
        number,
        entityType: 'service_order',
        entityId: orderId,
        clientOrSupplier: order.client,
        createdAt: today,
        createdBy: activeUser.name,
        version: 1,
        status: 'PDF Р·Р±РµСЂРµР¶РµРЅРѕ',
        pdfPath: `/documents/service_order/${orderId}/${number}.pdf`,
        amountNet: totals.amountNet,
        amountVat: totals.amountVat,
        amountGross: totals.amountGross,
      }, ...current];
    });
    setSelectedOrderId(orderId);
    enqueueClientNotification(order, 'РџСЂРёР№РѕРј РїСЂРёСЃС‚СЂРѕСЋ');
    logAction('РЁРІРёРґРєРёР№ РїСЂРёР№РѕРј', orderId, `${order.client}: ${order.device}. Р†РЅР¶РµРЅРµСЂ: ${engineer.name}.`);
    logAction('РђРІС‚РѕРґРѕРєСѓРјРµРЅС‚', orderId, 'РљРЅРѕРїРєР° "РџСЂРёР№РЅСЏС‚Рё Р·Р°РјРѕРІР»РµРЅРЅСЏ" Р°РІС‚РѕРјР°С‚РёС‡РЅРѕ СЃС‚РІРѕСЂРёР»Р° РЅР°СЂСЏРґ РЅР° СЂРµРјРѕРЅС‚.');
    setNotice(`${orderId}: Р·Р°РєР°Р· РїСЂРёР№РЅСЏС‚Рѕ, РєР»С–С”РЅС‚Р° ${clientExists ? 'Р·РЅР°Р№РґРµРЅРѕ' : 'СЃС‚РІРѕСЂРµРЅРѕ'}, С–РЅР¶РµРЅРµСЂР° РїСЂРёР·РЅР°С‡РµРЅРѕ. РќР°СЂСЏРґ СЃС‚РІРѕСЂРµРЅРѕ Р°РІС‚РѕРјР°С‚РёС‡РЅРѕ.`);
    setQuickPhone('');
    setQuickClientName('');
    setQuickDevice('');
    setQuickProblem('');
  }

  function sendInternalMessage(toUserId: string, orderId: string, text: string, dueAt: string, importance: InternalMessageImportance) {
    const recipient = users.find((user) => user.id === toUserId);
    if (!recipient || !text.trim()) {
      setNotice('РџРѕРІС–РґРѕРјР»РµРЅРЅСЏ РЅРµ СЃС‚РІРѕСЂРµРЅРѕ: РІРёР±РµСЂС–С‚СЊ СЃРїС–РІСЂРѕР±С–С‚РЅРёРєР° С– РЅР°РїРёС€С–С‚СЊ Р·Р°РґР°С‡Сѓ.');
      return;
    }
    const message: InternalMessage = {
      id: uid('MSG-IN'),
      toUser: recipient.name,
      toRole: recipient.role,
      orderId: orderId || undefined,
      text: text.trim(),
      dueAt: dueAt.trim() || today,
      importance,
      status: 'РќРѕРІРµ',
      createdBy: activeUser.name,
      createdAt: today,
    };
    setInternalMessages((current) => [message, ...current]);
    logAction('Р’РЅСѓС‚СЂС–С€РЅС” РїРѕРІС–РґРѕРјР»РµРЅРЅСЏ', orderId || recipient.name, `РљРѕРјСѓ: ${recipient.role} вЂ” ${recipient.name}. ${message.text}`);
    setNotice(`РџРѕРІС–РґРѕРјР»РµРЅРЅСЏ РґР»СЏ ${recipient.name} СЃС‚РІРѕСЂРµРЅРѕ.`);
  }

  function updateInternalMessageStatus(messageId: string, status: InternalMessageStatus) {
    const message = internalMessages.find((item) => item.id === messageId);
    setInternalMessages((current) => current.map((item) => (item.id === messageId ? { ...item, status } : item)));
    if (message) {
      logAction('РЎС‚Р°С‚СѓСЃ РїРѕРІС–РґРѕРјР»РµРЅРЅСЏ', message.orderId || message.toUser, `${message.toUser}: ${status}.`);
    }
  }

  function renderClientMessage(template: ClientNotificationTemplate, order: ServiceOrder, days = 3) {
    const totals = orderTotals(order);
    return template.text
      .split('{client}').join(order.client)
      .split('{order}').join(order.id)
      .split('{amount}').join(money(totals.total))
      .split('{days}').join(String(days))
      .split('{date}').join(order.promisedDate);
  }

  function enqueueClientNotification(order: ServiceOrder, event: NotificationEvent, preferredChannel?: NotificationChannel, manual = false) {
    const template =
      notificationTemplates.find((item) => item.event === event && item.enabled && (!preferredChannel || item.channel === preferredChannel)) ??
      notificationTemplates.find((item) => item.event === event && item.enabled);

    if (!template) {
      const disabled: ClientNotification = {
        id: uid('MSG'),
        orderId: order.id,
        client: order.client,
        phone: order.phone,
        channel: preferredChannel ?? 'SMS',
        event,
        message: `РЁР°Р±Р»РѕРЅ РґР»СЏ РїРѕРґС–С— "${event}" РІРёРјРєРЅРµРЅРѕ.`,
        status: 'Р’РёРјРєРЅРµРЅРѕ',
        createdAt: today,
      };
      setClientNotifications((current) => [disabled, ...current]);
      setNotice(`РџРѕРІС–РґРѕРјР»РµРЅРЅСЏ РЅРµ РІС–РґРїСЂР°РІР»РµРЅРѕ: С€Р°Р±Р»РѕРЅ "${event}" РІРёРјРєРЅРµРЅРѕ.`);
      return;
    }

    const alreadySentToday = clientNotifications.some((item) => item.orderId === order.id && item.event === event && item.channel === template.channel && item.createdAt === today && item.status === 'Р’С–РґРїСЂР°РІР»РµРЅРѕ');
    if (alreadySentToday && !manual) {
      setNotice(`CRM РЅРµ СЃРїР°РјРёС‚СЊ РєР»С–С”РЅС‚Р°: ${event} РІР¶Рµ РІС–РґРїСЂР°РІР»РµРЅРѕ СЃСЊРѕРіРѕРґРЅС–.`);
      return;
    }

    const notification: ClientNotification = {
      id: uid('MSG'),
      orderId: order.id,
      client: order.client,
      phone: order.phone,
      channel: template.channel,
      event,
      message: renderClientMessage(template, order),
      status: 'Р’С–РґРїСЂР°РІР»РµРЅРѕ',
      createdAt: today,
      sentAt: today,
    };
    setClientNotifications((current) => [notification, ...current]);
    logAction(manual ? 'РџРѕРІС‚РѕСЂ СѓРІРµРґРѕРјР»РµРЅРЅСЏ' : 'РђРІС‚РѕСѓРІРµРґРѕРјР»РµРЅРЅСЏ РєР»С–С”РЅС‚Сѓ', order.id, `${template.channel}: ${event}. ${notification.message}`);
    setNotice(`${template.channel}: РєР»С–С”РЅС‚Сѓ ${order.client} РІС–РґРїСЂР°РІР»РµРЅРѕ РїРѕРІС–РґРѕРјР»РµРЅРЅСЏ "${event}".`);
  }

  function notificationEventForStatus(status: OrderStatus): NotificationEvent | undefined {
    const map: Partial<Record<OrderStatus, NotificationEvent>> = {
      РџСЂРёР№РЅСЏС‚Рѕ: 'РџСЂРёР№РѕРј РїСЂРёСЃС‚СЂРѕСЋ',
      'РћС‡С–РєСѓС” РїРѕРіРѕРґР¶РµРЅРЅСЏ': 'Р”С–Р°РіРЅРѕСЃС‚РёРєР° Р·Р°РІРµСЂС€РµРЅР°',
      РџРѕРіРѕРґР¶РµРЅРѕ: 'РџРѕРіРѕРґР¶РµРЅРЅСЏ СЂРµРјРѕРЅС‚Сѓ',
      'РћС‡С–РєСѓС” Р·Р°РїС‡Р°СЃС‚РёРЅСѓ': 'РћС‡С–РєСѓРІР°РЅРЅСЏ Р·Р°РїС‡Р°СЃС‚РёРЅРё',
      'Р“РѕС‚РѕРІРёР№ РґРѕ РІРёРґР°С‡С–': 'Р“РѕС‚РѕРІРѕ РґРѕ РІРёРґР°С‡С–',
      Р’РёРґР°РЅРѕ: 'Р’РёРґР°С‡Р°',
    };
    return map[status];
  }

  function approvalClientUrl(token: string) {
    if (typeof window === 'undefined') return `/approval/${token}`;
    return `${window.location.origin}${window.location.pathname}#/approval/${token}`;
  }

  function sendRepairApproval(order: ServiceOrder, channel: NotificationChannel = 'Telegram') {
    const totals = orderTotals(order);
    if (!order.diagnosisResult) {
      setNotice('РЎРїРѕС‡Р°С‚РєСѓ РїРѕС‚СЂС–Р±РЅРѕ Р·Р°РІРµСЂС€РёС‚Рё РґС–Р°РіРЅРѕСЃС‚РёРєСѓ С– РІРєР°Р·Р°С‚Рё СЂРµР·СѓР»СЊС‚Р°С‚.');
      return;
    }
    if (totals.total <= 0) {
      setNotice('РЎРѕРіР»Р°СЃСѓРІР°РЅРЅСЏ РЅРµРјРѕР¶Р»РёРІРµ: РЅРµРјР°С” СЃСѓРјРё СЂРѕР±С–С‚ Р°Р±Рѕ Р·Р°РїС‡Р°СЃС‚РёРЅ.');
      return;
    }

    const token = uid('APPROVAL');
    const clientUrl = approvalClientUrl(token);
    const messageText = `${order.client}, СЂРµРјРѕРЅС‚ РїСЂРёСЃС‚СЂРѕСЋ ${order.device}. Р’Р°СЂС‚С–СЃС‚СЊ: ${money(totals.total)}. РџС–РґС‚РІРµСЂРґС–С‚СЊ: ${clientUrl}`;
    const approval: RepairApproval = {
      id: uid('APR'),
      orderId: order.id,
      token,
      client: order.client,
      phone: order.phone,
      device: order.device,
      issue: order.issue,
      worksSnapshot: order.works.map((work) => ({ ...work })),
      partsSnapshot: order.parts.map((part) => ({ name: productName(part.productId), qty: part.qty, price: part.price })),
      totalAmount: totals.total,
      promisedDate: order.promisedDate,
      status: 'РћС‡С–РєСѓС” РІС–РґРїРѕРІС–РґСЊ',
      sentAt: today,
      sentChannel: channel,
      messageText,
      clientUrl,
    };

    setRepairApprovals((current) => [approval, ...current.filter((item) => !(item.orderId === order.id && item.status === 'РћС‡С–РєСѓС” РІС–РґРїРѕРІС–РґСЊ'))]);
    updateOrderStatus(order.id, 'РћС‡С–РєСѓС” РїРѕРіРѕРґР¶РµРЅРЅСЏ', 'РњРµРЅРµРґР¶РµСЂ РІС–РґРїСЂР°РІРёРІ РєР»С–С”РЅС‚Сѓ СЃС‚РѕСЂС–РЅРєСѓ РїРѕРіРѕРґР¶РµРЅРЅСЏ СЂРµРјРѕРЅС‚Сѓ.');
    enqueueClientNotification(order, 'РџРѕРіРѕРґР¶РµРЅРЅСЏ СЂРµРјРѕРЅС‚Сѓ', channel, true);
    logAction('Р’С–РґРїСЂР°РІРєР° РїРѕРіРѕРґР¶РµРЅРЅСЏ', order.id, `${channel}: ${messageText}`);
    setNotice(`РџРѕРіРѕРґР¶РµРЅРЅСЏ ${order.id} РІС–РґРїСЂР°РІР»РµРЅРѕ РєР»С–С”РЅС‚Сѓ. РЎСѓРјР° С– СЃРєР»Р°Рґ СЂРѕР±С–С‚ Р·Р°С„С–РєСЃРѕРІР°РЅС–: ${money(totals.total)}.`);
  }

  function recordApprovalResponse(approvalId: string, accepted: boolean, manual = false) {
    const approval = repairApprovals.find((item) => item.id === approvalId);
    if (!approval) return;
    setRepairApprovals((current) =>
      current.map((item) =>
        item.id === approvalId
          ? {
              ...item,
              status: accepted ? 'РџС–РґС‚РІРµСЂРґР¶РµРЅРѕ' : 'Р’С–РґРјРѕРІР°',
              responseAt: today,
              responseIp: manual ? 'manual' : '93.77.120.14',
              responseComment: manual ? 'РњРµРЅРµРґР¶РµСЂ Р·Р°С„С–РєСЃСѓРІР°РІ РІС–РґРїРѕРІС–РґСЊ РІСЂСѓС‡РЅСѓ.' : 'РљР»С–С”РЅС‚ РІС–РґРїРѕРІС–РІ С‡РµСЂРµР· СЃС‚РѕСЂС–РЅРєСѓ РїРѕРіРѕРґР¶РµРЅРЅСЏ.',
            }
          : item,
      ),
    );
    updateOrderStatus(approval.orderId, accepted ? 'РџРѕРіРѕРґР¶РµРЅРѕ' : 'РџР°СѓР·Р° / РІС–РґРєР»Р°РґРµРЅРѕ', accepted ? 'РљР»С–С”РЅС‚ РїС–РґС‚РІРµСЂРґРёРІ СЂРµРјРѕРЅС‚ С‡РµСЂРµР· РїРѕРіРѕРґР¶РµРЅРЅСЏ.' : 'РљР»С–С”РЅС‚ РІС–РґРјРѕРІРёРІСЃСЏ Р°Р±Рѕ РїРѕСЃС‚Р°РІРёРІ СЂРµРјРѕРЅС‚ РЅР° РїР°СѓР·Сѓ.');
    logAction(accepted ? 'РџРѕРіРѕРґР¶РµРЅРЅСЏ СЂРµРјРѕРЅС‚Сѓ' : 'Р’С–РґРјРѕРІР° РІС–Рґ СЂРµРјРѕРЅС‚Сѓ', approval.orderId, `${approval.client}: ${approval.totalAmount} РіСЂРЅ. ${manual ? 'Р’СЂСѓС‡РЅСѓ' : 'Р§РµСЂРµР· РїРѕСЃРёР»Р°РЅРЅСЏ'}.`);
    setNotice(accepted ? `${approval.orderId}: РєР»С–С”РЅС‚ РїС–РґС‚РІРµСЂРґРёРІ СЂРµРјРѕРЅС‚.` : `${approval.orderId}: РєР»С–С”РЅС‚ РІС–РґРјРѕРІРёРІСЃСЏ, Р·Р°РєР°Р· РїРµСЂРµРІРµРґРµРЅРѕ РІ РїР°СѓР·Сѓ.`);
  }

  function markApprovalNoAnswer(approvalId: string) {
    const approval = repairApprovals.find((item) => item.id === approvalId);
    if (!approval) return;
    setRepairApprovals((current) => current.map((item) => (item.id === approvalId ? { ...item, status: 'РќРµРјР°С” РІС–РґРїРѕРІС–РґС–' } : item)));
    const order = orders.find((item) => item.id === approval.orderId);
    if (order) enqueueClientNotification(order, 'РќР°РіР°РґСѓРІР°РЅРЅСЏ', 'SMS', true);
    logAction('РќР°РіР°РґСѓРІР°РЅРЅСЏ РїРѕРіРѕРґР¶РµРЅРЅСЏ', approval.orderId, 'РќРµРјР°С” РІС–РґРїРѕРІС–РґС– РІС–Рґ РєР»С–С”РЅС‚Р°, РІС–РґРїСЂР°РІР»РµРЅРѕ РЅР°РіР°РґСѓРІР°РЅРЅСЏ.');
    setNotice(`${approval.orderId}: РІС–РґРїРѕРІС–РґС– РЅРµРјР°С”, РєР»С–С”РЅС‚Сѓ РІС–РґРїСЂР°РІР»РµРЅРѕ РЅР°РіР°РґСѓРІР°РЅРЅСЏ.`);
  }

  function createDocumentRecord(kind: DocumentKind, entityType: PrintDocument['entityType'], entityId: string, clientOrSupplier: string, status: PrintDocument['status'], sourceOrder?: ServiceOrder) {
    const sourceSale = sales.find((sale) => sale.id === entityId);
    if (kind === 'Р’РёРґР°С‚РєРѕРІР° РЅР°РєР»Р°РґРЅР°' && sourceOrder && sourceOrder.parts.length === 0) return undefined;
    if (kind === 'Р’РёРґР°С‚РєРѕРІР° РЅР°РєР»Р°РґРЅР°' && sourceSale && sourceSale.items.length === 0) return undefined;
    const gross = sourceOrder ? orderTotals(sourceOrder).total : sourceSale ? saleTotals(sourceSale).total : 0;
    const totals = documentVatTotals(gross);
    const number = `${documentPrefix[kind]}-${documents.length + 1001}`;
    return {
      id: uid('DOC'),
      kind,
      number,
      entityType,
      entityId,
      clientOrSupplier,
      createdAt: today,
      createdBy: activeUser.name,
      version: 1,
      status,
      pdfPath: `/documents/${entityType}/${entityId}/${number}.pdf`,
      amountNet: totals.amountNet,
      amountVat: totals.amountVat,
      amountGross: totals.amountGross,
    } satisfies PrintDocument;
  }

  function addDocumentIfMissing(kind: DocumentKind, entityType: PrintDocument['entityType'], entityId: string, clientOrSupplier: string, status: PrintDocument['status'], sourceOrder?: ServiceOrder) {
    let created: PrintDocument | undefined;
    setDocuments((current) => {
      const existing = current.find((document) => document.kind === kind && document.entityId === entityId);
      if (existing) return current;
      const sourceSale = sales.find((sale) => sale.id === entityId);
      if (kind === 'Р’РёРґР°С‚РєРѕРІР° РЅР°РєР»Р°РґРЅР°' && sourceOrder && sourceOrder.parts.length === 0) return current;
      if (kind === 'Р’РёРґР°С‚РєРѕРІР° РЅР°РєР»Р°РґРЅР°' && sourceSale && sourceSale.items.length === 0) return current;
      const gross = sourceOrder ? orderTotals(sourceOrder).total : sourceSale ? saleTotals(sourceSale).total : 0;
      const totals = documentVatTotals(gross);
      const number = `${documentPrefix[kind]}-${current.length + 1001}`;
      created = {
        id: uid('DOC'),
        kind,
        number,
        entityType,
        entityId,
        clientOrSupplier,
        createdAt: today,
        createdBy: activeUser.name,
        version: 1,
        status,
        pdfPath: `/documents/${entityType}/${entityId}/${number}.pdf`,
        amountNet: totals.amountNet,
        amountVat: totals.amountVat,
        amountGross: totals.amountGross,
      };
      return [created, ...current];
    });
    if (created) logAction('РђРІС‚РѕРґРѕРєСѓРјРµРЅС‚', entityId, `${kind} ${created.number}: СЃС‚Р°С‚СѓСЃ "${status}".`);
    return created;
  }

  function createSmartReadyDocuments(order: ServiceOrder) {
    const createdKinds: string[] = [];
    const act = addDocumentIfMissing('РђРєС‚ РЅР°РґР°РЅРЅСЏ РїРѕСЃР»СѓРі', 'service_order', order.id, order.client, 'Р“РѕС‚РѕРІРѕ', order);
    if (act) createdKinds.push('Р°РєС‚');
    const invoice = addDocumentIfMissing('Р Р°С…СѓРЅРѕРє РЅР° РѕРїР»Р°С‚Сѓ', 'service_order', order.id, order.client, 'РћС‡С–РєСѓС” РѕРїР»Р°С‚Рё', order);
    if (invoice) createdKinds.push('СЂР°С…СѓРЅРѕРє');
    if (order.parts.length > 0) {
      const delivery = addDocumentIfMissing('Р’РёРґР°С‚РєРѕРІР° РЅР°РєР»Р°РґРЅР°', 'service_order', order.id, order.client, 'Р“РѕС‚РѕРІРѕ РґРѕ РІРёРґР°С‡С–', order);
      if (delivery) createdKinds.push('РІРёРґР°С‚РєРѕРІР°');
    }
    setOrders((current) => current.map((item) => (item.id === order.id ? { ...item, vatStatus: 'Р“РѕС‚РѕРІРѕ РґРѕ СЂРµС”СЃС‚СЂР°С†С–С— РџРќ', actIssuedAt: item.actIssuedAt ?? today, debtSince: item.debtSince ?? today } : item)));
    if (orderTotals(order).debt > 0 || daysSince(order.statusChangedAt) > 2) {
      setInternalMessages((current) => [
        {
          id: uid('MSG-IN'),
          toUser: order.manager,
          toRole: 'РњРµРЅРµРґР¶РµСЂ',
          orderId: order.id,
          text: 'РђРєС‚ СЃС„РѕСЂРјРѕРІР°РЅРѕ, Р°Р»Рµ РѕРїР»Р°С‚Рё С‰Рµ РЅРµРјР°С”. РџРѕС‚СЂС–Р±РЅРѕ РїСЂРѕРєРѕРЅС‚СЂРѕР»СЋРІР°С‚Рё РѕРїР»Р°С‚Сѓ РєР»С–С”РЅС‚Р°.',
          dueAt: today,
          importance: 'Р’Р°Р¶Р»РёРІР°',
          status: 'РќРѕРІРµ',
          createdBy: 'РЎРёСЃС‚РµРјР°',
          createdAt: today,
        },
        ...(daysSince(order.statusChangedAt) > 2 ? [{
          id: uid('MSG-IN'),
          toUser: order.manager,
          toRole: 'РњРµРЅРµРґР¶РµСЂ' as Role,
          orderId: order.id,
          text: `Р—Р°РєР°Р· Р±РµР· СЂСѓС…Сѓ ${daysSince(order.statusChangedAt)} РґРЅ. РїС–СЃР»СЏ СЃС‚Р°С‚СѓСЃСѓ "${order.status}". РџРѕС‚СЂС–Р±РµРЅ РєРѕРЅС‚СЂРѕР»СЊ.`,
          dueAt: today,
          importance: 'Р’Р°Р¶Р»РёРІР°' as InternalMessageImportance,
          status: 'РќРѕРІРµ' as InternalMessageStatus,
          createdBy: 'РЎРёСЃС‚РµРјР°',
          createdAt: today,
        }] : []),
        {
          id: uid('MSG-IN'),
          toUser: 'Р‘СѓС…РіР°Р»С‚РµСЂ',
          toRole: 'Р‘СѓС…РіР°Р»С‚РµСЂ',
          orderId: order.id,
          text: 'РђРєС‚ СЃС„РѕСЂРјРѕРІР°РЅРѕ, РїС–РґРїРёСЃ РєР»С–С”РЅС‚Р° С‰Рµ РЅРµ Р·Р°С„С–РєСЃРѕРІР°РЅРѕ. РќР”РЎ: РіРѕС‚РѕРІРѕ РґРѕ С„РѕСЂРјСѓРІР°РЅРЅСЏ РґР°РЅРёС… РґР»СЏ РќРќ.',
          dueAt: today,
          importance: 'Р’Р°Р¶Р»РёРІР°',
          status: 'РќРѕРІРµ',
          createdBy: 'РЎРёСЃС‚РµРјР°',
          createdAt: today,
        },
        ...current,
      ]);
    }
    logAction('РђРІС‚РѕРјР°С‚РёРєР° РґРѕРєСѓРјРµРЅС‚С–РІ', order.id, `Р“РѕС‚РѕРІРѕ: СЃС‚РІРѕСЂРµРЅРѕ ${createdKinds.length ? createdKinds.join(', ') : 'Р±РµР· РЅРѕРІРёС… РґРѕРєСѓРјРµРЅС‚С–РІ, РґСѓР±Р»С–РєР°С‚Рё РІР¶Рµ С–СЃРЅСѓСЋС‚СЊ'}. РќР”РЎ: РіРѕС‚РѕРІРѕ РґРѕ С„РѕСЂРјСѓРІР°РЅРЅСЏ РґР°РЅРёС… РґР»СЏ РќРќ.`);
    return createdKinds;
  }

  function printDocument(kind: DocumentKind, entityType: PrintDocument['entityType'], entityId: string, clientOrSupplier: string) {
    const existing = documents.find((document) => document.kind === kind && document.entityId === entityId);
    if (existing) {
      setNotice(`Р”РѕРєСѓРјРµРЅС‚ "${kind}" РІР¶Рµ С” РІ СЂРµС”СЃС‚СЂС–: ${existing.number}. Р’С–РґРєСЂРёРІР°С”РјРѕ РґСЂСѓРє.`);
      logAction('Р”СЂСѓРє РґРѕРєСѓРјРµРЅС‚Р°', entityId, `${kind} РїРѕРІС‚РѕСЂРЅРѕ РІС–РґРєСЂРёС‚Рѕ РґР»СЏ РґСЂСѓРєСѓ.`);
      window.print();
      return;
    }

    const prefix: Record<DocumentKind, string> = {
      'РљРІРёС‚Р°РЅС†С–СЏ РїСЂРёР№РѕРјСѓ': 'РљРџ',
      'РђРєС‚ РґС–Р°РіРЅРѕСЃС‚РёРєРё': 'РђР”',
      'Р—Р°РєР°Р·-РЅР°СЂСЏРґ': 'Р—РќР”',
      'Р Р°С…СѓРЅРѕРє РЅР° РѕРїР»Р°С‚Сѓ': 'Р РҐ',
      'РђРєС‚ РЅР°РґР°РЅРЅСЏ РїРѕСЃР»СѓРі': 'РђРќРџ',
      'РђРєС‚ РІРёРєРѕРЅР°РЅРёС… СЂРѕР±С–С‚': 'РђР’Р ',
      'РђРєС‚ РІРёРґР°С‡С–': 'РђР’',
      'Р’РёРґР°С‚РєРѕРІР° РЅР°РєР»Р°РґРЅР°': 'Р’Рќ',
      'РќР°СЂСЏРґ РЅР° СЂРµРјРѕРЅС‚': 'РќР ',
      'РЁРІРёРґРєРёР№ РЅР°СЂСЏРґ': 'РЁРќ',
      'РђРєС‚ С‚РµС…РЅС–С‡РЅРѕРіРѕ СЃС‚Р°РЅСѓ': 'РђРўРЎ',
      'Р“Р°СЂР°РЅС‚С–Р№РЅРёР№ С‚Р°Р»РѕРЅ': 'Р“Рў',
      'РўРѕРІР°СЂРЅРёР№ С‡РµРє': 'РўР§',
      'РќР°РєР»Р°РґРЅР° РїСЂРѕРґР°Р¶Сѓ': 'РќРџ',
      'РљР°СЃРѕРІРёР№ С‡РµРє': 'РљР§',
      'Р”РѕРєСѓРјРµРЅС‚ РїРѕРІРµСЂРЅРµРЅРЅСЏ': 'РџР’',
      'РџСЂРёС…С–РґРЅР° РЅР°РєР»Р°РґРЅР°': 'РџРќ',
    };
    const number = `${prefix[kind]}-${documents.length + 1001}`;
    const sourceOrder = orders.find((order) => order.id === entityId);
    const sourceSale = sales.find((sale) => sale.id === entityId);
    if (kind === 'Р’РёРґР°С‚РєРѕРІР° РЅР°РєР»Р°РґРЅР°' && sourceOrder && sourceOrder.parts.length === 0) {
      setNotice('Р’РёРґР°С‚РєРѕРІР° РЅР°РєР»Р°РґРЅР° СЃС‚РІРѕСЂСЋС”С‚СЊСЃСЏ С‚С–Р»СЊРєРё СЏРєС‰Рѕ РІ РґРѕРєСѓРјРµРЅС‚С– С” С‚РѕРІР°СЂ Р°Р±Рѕ РєРѕРјРїР»РµРєС‚СѓСЋС‡С– Р·С– СЃРєР»Р°РґСѓ.');
      return;
    }
    if (kind === 'Р’РёРґР°С‚РєРѕРІР° РЅР°РєР»Р°РґРЅР°' && sourceSale && sourceSale.items.length === 0) {
      setNotice('Р’РёРґР°С‚РєРѕРІР° РЅР°РєР»Р°РґРЅР° РїСЂРѕРґР°Р¶Сѓ СЃС‚РІРѕСЂСЋС”С‚СЊСЃСЏ С‚С–Р»СЊРєРё СЏРєС‰Рѕ С” С‚РѕРІР°СЂРЅС– РїРѕР·РёС†С–С—.');
      return;
    }
    const gross = sourceOrder ? orderTotals(sourceOrder).total : sourceSale ? saleTotals(sourceSale).total : 0;
    const totals = documentVatTotals(gross);
    const document: PrintDocument = {
      id: uid('DOC'),
      kind,
      number,
      entityType,
      entityId,
      clientOrSupplier,
      createdAt: today,
      createdBy: activeUser.name,
      version: 1,
      status: 'PDF Р·Р±РµСЂРµР¶РµРЅРѕ',
      pdfPath: `/documents/${entityType}/${entityId}/${number}.pdf`,
      amountNet: totals.amountNet,
      amountVat: totals.amountVat,
      amountGross: totals.amountGross,
    };

    setDocuments((current) => [document, ...current]);
    setNotice(`РЎС‚РІРѕСЂРµРЅРѕ PDF-РґРѕРєСѓРјРµРЅС‚ "${kind}" ${number}. Р’С–РЅ РїСЂРёРІ'СЏР·Р°РЅРёР№ РґРѕ ${entityId} С– Р·Р°РїРёСЃР°РЅРёР№ Сѓ Р¶СѓСЂРЅР°Р».`);
    logAction('РЎС‚РІРѕСЂРµРЅРЅСЏ PDF', entityId, `${kind} ${number}: СЃС‚РІРѕСЂРµРЅРѕ, Р·Р±РµСЂРµР¶РµРЅРѕ С– РїС–РґРіРѕС‚РѕРІР»РµРЅРѕ РґРѕ РґСЂСѓРєСѓ.`);
    window.print();
  }

  function registerCashPayment(amount: number, method: PaymentMethod, isRefund = false) {
    setCashShift((current) => {
      const sign = isRefund ? -1 : 1;
      return {
        ...current,
        cashIncome: method === 'Р“РѕС‚С–РІРєР°' ? current.cashIncome + amount * sign : current.cashIncome,
        cardIncome: method === 'РљР°СЂС‚РєР°' ? current.cardIncome + amount * sign : current.cardIncome,
        bankIncome: method === 'Р‘РµР·РіРѕС‚С–РІРєР°' ? current.bankIncome + amount * sign : current.bankIncome,
        cashExpense: isRefund && method === 'Р“РѕС‚С–РІРєР°' ? current.cashExpense + amount : current.cashExpense,
      };
    });
  }

  function writeOffInstalledPartsForOrder(order: ServiceOrder, comment: string) {
    let writtenOff = 0;
    order.parts.forEach((part) => {
      if (part.status === 'Р’СЃС‚Р°РЅРѕРІР»РµРЅРѕ') {
        patchProduct(part.productId, (item) => ({ ...item, installed: Math.max(item.installed - part.qty, 0) }));
        patchOrderPart(order.id, part.id, (item) => ({ ...item, status: 'РЎРїРёСЃР°РЅРѕ' }));
        addMovement({ type: 'РЎРїРёСЃР°РЅРЅСЏ', productId: part.productId, qty: part.qty, orderId: order.id, comment });
        logAction('РЎРїРёСЃР°РЅРЅСЏ Р·Р°РїС‡Р°СЃС‚РёРЅРё РїС–СЃР»СЏ РѕРїР»Р°С‚Рё', order.id, `${productName(part.productId)}: ${part.qty} С€С‚.`);
        writtenOff += 1;
      }
    });
    return writtenOff;
  }

  function patchProduct(productId: string, updater: (product: Product) => Product) {
    setProducts((current) => current.map((product) => (product.id === productId ? updater(product) : product)));
  }

  function patchOrderPart(orderId: string, partId: string, updater: (part: OrderPart) => OrderPart) {
    setOrders((current) =>
      current.map((order) =>
        order.id === orderId
          ? { ...order, parts: order.parts.map((part) => (part.id === partId ? updater(part) : part)) }
          : order,
      ),
    );
  }

  function updateOrderStatus(orderId: string, status: OrderStatus, comment = 'РЎС‚Р°С‚СѓСЃ Р·РјС–РЅРµРЅРѕ СЃРёСЃС‚РµРјРѕСЋ.') {
    setOrders((current) =>
      current.map((order) =>
        order.id === orderId
          ? {
              ...order,
              status,
              statusChangedAt: today,
              statusHistory: [
                { id: uid('H'), oldStatus: order.status, newStatus: status, changedBy: activeUser.name, changedAt: today, comment },
                ...order.statusHistory,
              ],
            }
          : order,
      ),
    );
  }

  function addPartToRepair() {
    const product = products.find((item) => item.id === selectedProductId);
    if (!product || !selectedOrder) return;
    const requestedQty = Math.max(1, qty);
    const orderPartId = uid('OP');

    if (available(product) >= requestedQty) {
      setOrders((current) =>
        current.map((order) =>
          order.id === selectedOrder.id
            ? {
                ...order,
                status: 'Р’ СЂРµРјРѕРЅС‚С–',
                parts: [...order.parts, { id: orderPartId, productId: product.id, qty: requestedQty, status: 'Р—Р°СЂРµР·РµСЂРІРѕРІР°РЅРѕ', cost: product.cost, price: product.price }],
              }
            : order,
        ),
      );
      patchProduct(product.id, (item) => ({ ...item, reserved: item.reserved + requestedQty }));
      addMovement({ type: 'Р РµР·РµСЂРІ', productId: product.id, qty: requestedQty, orderId: selectedOrder.id, comment: 'Р РµР·РµСЂРІ СЃС‚РІРѕСЂРµРЅРѕ Р°РІС‚РѕРјР°С‚РёС‡РЅРѕ РїСЂРё РґРѕРґР°РІР°РЅРЅС– РІ СЂРµРјРѕРЅС‚.' });
      logAction('Р РµР·РµСЂРІ Р·Р°РїС‡Р°СЃС‚РёРЅРё', selectedOrder.id, `${product.name}: ${requestedQty} С€С‚.`);
      setNotice(`Р—Р°РїС‡Р°СЃС‚РёРЅСѓ "${product.name}" Р·Р°СЂРµР·РµСЂРІРѕРІР°РЅРѕ РїС–Рґ ${selectedOrder.id}.`);
      return;
    }

    const requirementId = uid('REQ');
    setRequirements((current) => [{ id: requirementId, orderId: selectedOrder.id, productId: product.id, qty: requestedQty, status: 'РџРѕС‚СЂС–Р±РЅРѕ' }, ...current]);
    setOrders((current) =>
      current.map((order) =>
        order.id === selectedOrder.id
          ? {
              ...order,
              status: 'РћС‡С–РєСѓС” Р·Р°РїС‡Р°СЃС‚РёРЅСѓ',
              parts: [...order.parts, { id: orderPartId, productId: product.id, qty: requestedQty, status: 'РџРѕС‚СЂС–Р±РЅРѕ', cost: product.cost, price: product.price, requirementId }],
            }
          : order,
      ),
    );
    enqueueClientNotification(selectedOrder, 'РћС‡С–РєСѓРІР°РЅРЅСЏ Р·Р°РїС‡Р°СЃС‚РёРЅРё');
    setNotice(`РќР° СЃРєР»Р°РґС– РЅРµРјР°С” "${product.name}". РЎС‚РІРѕСЂРµРЅРѕ РїРѕС‚СЂРµР±Сѓ РґР»СЏ ${selectedOrder.id}.`);
    logAction('РЎС‚РІРѕСЂРµРЅРЅСЏ РїРѕС‚СЂРµР±Рё', selectedOrder.id, `${product.name}: ${requestedQty} С€С‚.`);
  }

  function orderPart(order: ServiceOrder, part: OrderPart) {
    const purchaseId = uid('PO');
    const requirementId = part.requirementId ?? uid('REQ');
    if (!part.requirementId) {
      setRequirements((current) => [{ id: requirementId, orderId: order.id, productId: part.productId, qty: part.qty, status: 'Р”Рѕ Р·Р°РєСѓРїС–РІР»С–' }, ...current]);
    }
    setRequirements((current) => current.map((item) => (item.id === requirementId ? { ...item, status: 'Р—Р°РјРѕРІР»РµРЅРѕ' } : item)));
    setPurchases((current) => [
      {
        id: purchaseId,
        supplier: 'РџРѕСЃС‚Р°С‡Р°Р»СЊРЅРёРє Р·Р°РїС‡Р°СЃС‚РёРЅ',
        items: [{ productId: part.productId, qty: part.qty, price: part.cost, received: 0, requirementId, orderId: order.id }],
        status: 'Р—Р°РјРѕРІР»РµРЅРѕ',
        orderedAt: today,
        expectedAt: '22.04.2026',
      },
      ...current,
    ]);
    patchOrderPart(order.id, part.id, (item) => ({ ...item, status: 'Р—Р°РјРѕРІР»РµРЅРѕ', requirementId, purchaseId }));
    updateOrderStatus(order.id, 'РћС‡С–РєСѓС” Р·Р°РїС‡Р°СЃС‚РёРЅСѓ');
    enqueueClientNotification(order, 'РћС‡С–РєСѓРІР°РЅРЅСЏ Р·Р°РїС‡Р°СЃС‚РёРЅРё');
    logAction('РЎС‚РІРѕСЂРµРЅРЅСЏ Р·Р°РєСѓРїС–РІР»С–', purchaseId, `Р—Р°РєСѓРїС–РІР»СЏ РїСЂРёРІ'СЏР·Р°РЅР° РґРѕ СЂРµРјРѕРЅС‚Сѓ ${order.id}.`);
    setNotice(`РЎС‚РІРѕСЂРµРЅРѕ Р·Р°РєСѓРїС–РІР»СЋ ${purchaseId} С– РїСЂРёРІ'СЏР·Р°РЅРѕ С—С— РґРѕ ${order.id}.`);
  }

  function movePurchase(purchaseId: string) {
    setPurchases((current) => current.map((purchase) => (purchase.id === purchaseId ? { ...purchase, status: 'Р’ РґРѕСЂРѕР·С–' } : purchase)));
    const purchase = purchases.find((item) => item.id === purchaseId);
    purchase?.items.forEach((item) => {
      if (item.requirementId) {
        setRequirements((current) => current.map((req) => (req.id === item.requirementId ? { ...req, status: 'Р’ РґРѕСЂРѕР·С–' } : req)));
      }
      if (item.orderId) {
        setOrders((current) =>
          current.map((order) =>
            order.id === item.orderId
              ? { ...order, parts: order.parts.map((part) => (part.purchaseId === purchaseId ? { ...part, status: 'Р’ РґРѕСЂРѕР·С–' } : part)) }
              : order,
          ),
        );
      }
    });
    logAction('Р—РјС–РЅР° СЃС‚Р°С‚СѓСЃСѓ Р·Р°РєСѓРїС–РІР»С–', purchaseId, 'Р—Р°РєСѓРїС–РІР»СЏ РїРѕР·РЅР°С‡РµРЅР° СЏРє РІ РґРѕСЂРѕР·С–.');
    setNotice(`Р—Р°РєСѓРїС–РІР»СЏ ${purchaseId} РїРѕР·РЅР°С‡РµРЅР° СЏРє "Р’ РґРѕСЂРѕР·С–".`);
  }

  function receivePurchase(purchaseId: string) {
    const purchase = purchases.find((item) => item.id === purchaseId);
    if (!purchase) return;
    purchase.items.forEach((item) => {
      const qtyToReceive = item.qty - item.received;
      if (qtyToReceive <= 0) return;
      patchProduct(item.productId, (product) => ({
        ...product,
        stock: product.stock + qtyToReceive,
        cost: item.price,
        batches: [
          ...product.batches,
          {
            id: uid('BAT'),
            productId: item.productId,
            qtyTotal: qtyToReceive,
            qtyAvailable: qtyToReceive,
            purchasePrice: item.price,
            purchaseDate: today,
            source: purchase.supplier,
            comment: `РџР°СЂС‚С–СЏ СЃС‚РІРѕСЂРµРЅР° Р· Р·Р°РєСѓРїРєРё ${purchaseId}.`,
          },
        ],
      }));
      setReceipts((current) => [
        { id: uid('GR'), date: today, supplier: purchase.supplier, productId: item.productId, qty: qtyToReceive, price: item.price, purchaseId },
        ...current,
      ]);
      addMovement({ type: 'РџСЂРёС…С–Рґ', productId: item.productId, qty: qtyToReceive, purchaseId, comment: 'РџСЂРёС…С–Рґ Р·Р° Р·Р°РєСѓРїС–РІР»РµСЋ. CRM РїСЂРѕРїРѕРЅСѓС” СЂРµР·РµСЂРІ РїС–Рґ Р·Р°РјРѕРІР»РµРЅРЅСЏ.' });
      if (item.requirementId) {
        setRequirements((current) => current.map((req) => (req.id === item.requirementId ? { ...req, status: 'РџСЂРёР±СѓР»Рѕ' } : req)));
      }
      if (item.orderId) {
        setOrders((current) =>
          current.map((order) =>
            order.id === item.orderId
              ? { ...order, parts: order.parts.map((part) => (part.purchaseId === purchaseId ? { ...part, status: 'РџСЂРёР±СѓР»Рѕ' } : part)) }
              : order,
          ),
        );
      }
    });
    setPurchases((current) =>
      current.map((item) =>
        item.id === purchaseId
          ? { ...item, status: 'РџСЂРёР±СѓР»Рѕ', items: item.items.map((line) => ({ ...line, received: line.qty })) }
          : item,
      ),
    );
    logAction('РџСЂРёС…С–Рґ С‚РѕРІР°СЂСѓ', purchaseId, 'РћС„РѕСЂРјР»РµРЅРѕ РїСЂРёС…С–Рґ Р·Р° Р·Р°РєСѓРїС–РІР»РµСЋ.');
    setNotice(`РџСЂРёС…С–Рґ Р·Р° ${purchaseId} РѕС„РѕСЂРјР»РµРЅРѕ. РўРµРїРµСЂ РјРѕР¶РЅР° Р·Р°СЂРµР·РµСЂРІСѓРІР°С‚Рё Р·Р°РїС‡Р°СЃС‚РёРЅСѓ РїС–Рґ СЂРµРјРѕРЅС‚.`);
  }

  function reserveArrived(order: ServiceOrder, part: OrderPart) {
    const product = products.find((item) => item.id === part.productId);
    if (!product || available(product) < part.qty) {
      setNotice('Р РµР·РµСЂРІ РЅРµРјРѕР¶Р»РёРІРёР№: РґРѕСЃС‚СѓРїРЅРѕРіРѕ Р·Р°Р»РёС€РєСѓ РЅРµРґРѕСЃС‚Р°С‚РЅСЊРѕ.');
      return;
    }
    patchProduct(part.productId, (item) => ({ ...item, reserved: item.reserved + part.qty }));
    patchOrderPart(order.id, part.id, (item) => ({ ...item, status: 'Р—Р°СЂРµР·РµСЂРІРѕРІР°РЅРѕ' }));
    addMovement({ type: 'Р РµР·РµСЂРІ', productId: part.productId, qty: part.qty, orderId: order.id, comment: 'Р РµР·РµСЂРІ РїС–СЃР»СЏ РїСЂРёС…РѕРґСѓ С‚РѕРІР°СЂСѓ.' });
    logAction('Р РµР·РµСЂРІ РїС–СЃР»СЏ РїСЂРёС…РѕРґСѓ', order.id, `${product.name}: ${part.qty} С€С‚.`);
    setNotice(`Р—Р°РїС‡Р°СЃС‚РёРЅСѓ "${product.name}" Р·Р°СЂРµР·РµСЂРІРѕРІР°РЅРѕ РїС–Рґ ${order.id}.`);
  }

  function issueToEngineer(order: ServiceOrder, part: OrderPart) {
    const product = products.find((item) => item.id === part.productId);
    if (!product || part.status !== 'Р—Р°СЂРµР·РµСЂРІРѕРІР°РЅРѕ' || product.reserved < part.qty || product.stock < part.qty) {
      setNotice('Р’РёРґР°С‡Р° РЅРµРјРѕР¶Р»РёРІР°: РїРѕС‚СЂС–Р±РµРЅ Р°РєС‚РёРІРЅРёР№ СЂРµР·РµСЂРІ.');
      return;
    }
    const fifo = fifoConsumeBatches(product, part.qty);
    if (!fifo) {
      setNotice('Р’РёРґР°С‡Р° РЅРµРјРѕР¶Р»РёРІР°: РїРѕ РїР°СЂС‚С–СЏС… РЅРµ РІРёСЃС‚Р°С‡Р°С” Р·Р°Р»РёС€РєСѓ, РїРµСЂРµРІС–СЂС‚Рµ СЃРєР»Р°Рґ.');
      return;
    }
    patchProduct(part.productId, (item) => ({
      ...item,
      stock: item.stock - part.qty,
      reserved: item.reserved - part.qty,
      withEngineer: item.withEngineer + part.qty,
      batches: fifo.batches,
    }));
    patchOrderPart(order.id, part.id, (item) => ({
      ...item,
      status: 'Р’РёРґР°РЅРѕ С–РЅР¶РµРЅРµСЂСѓ',
      cost: Math.round(fifo.totalCost / part.qty),
      batchAllocations: fifo.allocations,
    }));
    addMovement({ type: 'Р’РёРґР°С‡Р° С–РЅР¶РµРЅРµСЂСѓ', productId: part.productId, qty: part.qty, orderId: order.id, comment: `Р’РёРґР°РЅРѕ С–РЅР¶РµРЅРµСЂСѓ ${order.engineer}. FIFO: ${fifo.allocations.map((line) => `${line.batchId} x${line.qty}`).join(', ')}.` });
    logAction('Р’РёРґР°С‡Р° С–РЅР¶РµРЅРµСЂСѓ', order.id, `${product.name}: ${part.qty} С€С‚. РІРёРґР°РЅРѕ ${order.engineer}. FIFO ${fifo.allocations.map((line) => `${line.batchId}/${line.qty}`).join(', ')}.`);
    setNotice(`Р—Р°РїС‡Р°СЃС‚РёРЅСѓ РІРёРґР°РЅРѕ С–РЅР¶РµРЅРµСЂСѓ ${order.engineer}. РЎРїРёСЃР°РЅРЅСЏ РїРѕ РїР°СЂС‚С–СЏС… РІРёРєРѕРЅР°РЅРѕ FIFO.`);
  }

  function markInstalled(order: ServiceOrder, part: OrderPart) {
    const product = products.find((item) => item.id === part.productId);
    if (!product || part.status !== 'Р’РёРґР°РЅРѕ С–РЅР¶РµРЅРµСЂСѓ' || product.withEngineer < part.qty) {
      setNotice('Р’СЃС‚Р°РЅРѕРІР»РµРЅРЅСЏ РЅРµРјРѕР¶Р»РёРІРµ: Р·Р°РїС‡Р°СЃС‚РёРЅР° С‰Рµ РЅРµ РІРёРґР°РЅР° С–РЅР¶РµРЅРµСЂСѓ.');
      return;
    }
    patchProduct(part.productId, (item) => ({ ...item, withEngineer: item.withEngineer - part.qty, installed: item.installed + part.qty }));
    patchOrderPart(order.id, part.id, (item) => ({ ...item, status: 'Р’СЃС‚Р°РЅРѕРІР»РµРЅРѕ' }));
    addMovement({ type: 'Р’СЃС‚Р°РЅРѕРІР»РµРЅРЅСЏ', productId: part.productId, qty: part.qty, orderId: order.id, comment: 'Р†РЅР¶РµРЅРµСЂ РІС–РґРјС–С‚РёРІ Р·Р°РїС‡Р°СЃС‚РёРЅСѓ СЏРє РІСЃС‚Р°РЅРѕРІР»РµРЅСѓ.' });
    logAction('Р’СЃС‚Р°РЅРѕРІР»РµРЅРЅСЏ Р·Р°РїС‡Р°СЃС‚РёРЅРё', order.id, `${product.name}: ${part.qty} С€С‚.`);
    setNotice('Р—Р°РїС‡Р°СЃС‚РёРЅСѓ РІСЃС‚Р°РЅРѕРІР»РµРЅРѕ. РџСЂРё Р·Р°РєСЂРёС‚С‚С– СЂРµРјРѕРЅС‚Сѓ CRM СЃРїРёС€Рµ СЃРѕР±С–РІР°СЂС‚С–СЃС‚СЊ РґРѕРєСѓРјРµРЅС‚РѕРј.');
  }

  function closeOrder(order: ServiceOrder) {
    const notInstalled = order.parts.some((part) => !['Р’СЃС‚Р°РЅРѕРІР»РµРЅРѕ', 'РЎРїРёСЃР°РЅРѕ'].includes(part.status));
    if (notInstalled) {
      setNotice('Р—Р°РєСЂРёС‚Рё СЂРµРјРѕРЅС‚ РЅРµ РјРѕР¶РЅР°: С” Р·Р°РїС‡Р°СЃС‚РёРЅРё РЅРµ РІ РєС–РЅС†РµРІРѕРјСѓ СЃС‚Р°С‚СѓСЃС–.');
      return;
    }
    if (orderTotals(order).debt > 0) {
      setNotice('Р—Р°РєСЂРёС‚Рё С– РІРёРґР°С‚Рё СЂРµРјРѕРЅС‚ РЅРµ РјРѕР¶РЅР°: С” Р±РѕСЂРі РєР»С–С”РЅС‚Р°.');
      return;
    }
    order.parts.forEach((part) => {
      if (part.status === 'Р’СЃС‚Р°РЅРѕРІР»РµРЅРѕ') {
        patchProduct(part.productId, (item) => ({ ...item, installed: Math.max(item.installed - part.qty, 0) }));
        patchOrderPart(order.id, part.id, (item) => ({ ...item, status: 'РЎРїРёСЃР°РЅРѕ' }));
        addMovement({ type: 'РЎРїРёСЃР°РЅРЅСЏ', productId: part.productId, qty: part.qty, orderId: order.id, comment: 'РђРІС‚РѕРјР°С‚РёС‡РЅРµ СЃРїРёСЃР°РЅРЅСЏ РїСЂРё Р·Р°РєСЂРёС‚С‚С– СЂРµРјРѕРЅС‚Сѓ.' });
        logAction('РЎРїРёСЃР°РЅРЅСЏ РїСЂРё Р·Р°РєСЂРёС‚С‚С– СЂРµРјРѕРЅС‚Сѓ', order.id, `${productName(part.productId)}: ${part.qty} С€С‚.`);
      }
    });
    updateOrderStatus(order.id, 'Р—Р°РєСЂРёС‚Рѕ');
    enqueueClientNotification(order, 'Р’РёРґР°С‡Р°');
    logAction('Р—Р°РєСЂРёС‚С‚СЏ С– РІРёРґР°С‡Р° СЂРµРјРѕРЅС‚Сѓ', order.id, 'Р РµРјРѕРЅС‚ Р·Р°РєСЂРёС‚Рѕ, РїСЂРёСЃС‚СЂС–Р№ РІРёРґР°РЅРѕ РєР»С–С”РЅС‚Сѓ.');
    setNotice(`Р РµРјРѕРЅС‚ ${order.id} Р·Р°РєСЂРёС‚Рѕ. Р’СЃС‚Р°РЅРѕРІР»РµРЅС– Р·Р°РїС‡Р°СЃС‚РёРЅРё СЃРїРёСЃР°РЅРѕ РґРѕРєСѓРјРµРЅС‚РѕРј.`);
  }

  function issueReadyOrder(order: ServiceOrder) {
    const allowedStatuses: OrderStatus[] = ['Р“РѕС‚РѕРІРёР№ РґРѕ РІРёРґР°С‡С–', 'РћС‡С–РєСѓС” РѕРїР»Р°С‚Рё', 'РћС‡С–РєСѓС” РєР»С–С”РЅС‚Р°', 'РќРµ РїС–РґР»СЏРіР°С” СЂРµРјРѕРЅС‚Сѓ'];
    if (!allowedStatuses.includes(order.status)) {
      setNotice('Р’РёРґР°С‚Рё Р·Р°РјРѕРІР»РµРЅРЅСЏ РјРѕР¶РЅР° С‚С–Р»СЊРєРё РїС–СЃР»СЏ СЃС‚Р°С‚СѓСЃСѓ "Р“РѕС‚РѕРІРёР№ РґРѕ РІРёРґР°С‡С–" Р°Р±Рѕ СЃР»СѓР¶Р±РѕРІРѕРіРѕ РѕС‡С–РєСѓРІР°РЅРЅСЏ.');
      return;
    }
    const totals = orderTotals(order);
    if (totals.debt > 0) {
      setNotice('Р’РёРґР°С‚Рё Р·Р°РјРѕРІР»РµРЅРЅСЏ РЅРµ РјРѕР¶РЅР°: С” Р±РѕСЂРі РєР»С–С”РЅС‚Р°. РЎРїРѕС‡Р°С‚РєСѓ РїСЂРёР№РјС–С‚СЊ РѕРїР»Р°С‚Сѓ Р°Р±Рѕ РѕРєСЂРµРјРѕ Р·Р°С„С–РєСЃСѓР№С‚Рµ РґРѕР·РІС–Р» РєРµСЂС–РІРЅРёРєР°.');
      return;
    }
    const hasIssueDocument = documents.some((document) => (
      document.entityType === 'service_order'
      && document.entityId === order.id
      && ['РђРєС‚ РЅР°РґР°РЅРЅСЏ РїРѕСЃР»СѓРі', 'РђРєС‚ РІРёРєРѕРЅР°РЅРёС… СЂРѕР±С–С‚', 'РђРєС‚ РІРёРґР°С‡С–', 'РђРєС‚ С‚РµС…РЅС–С‡РЅРѕРіРѕ СЃС‚Р°РЅСѓ'].includes(document.kind)
    ));
    if (!hasIssueDocument) {
      setNotice('Р’РёРґР°С‚Рё Р·Р°РјРѕРІР»РµРЅРЅСЏ РЅРµ РјРѕР¶РЅР°: СЃРїРѕС‡Р°С‚РєСѓ РјР°С” Р±СѓС‚Рё СЃС„РѕСЂРјРѕРІР°РЅРёР№ Р°РєС‚.');
      return;
    }
    const unfinishedParts = order.parts.some((part) => !['Р’СЃС‚Р°РЅРѕРІР»РµРЅРѕ', 'РЎРїРёСЃР°РЅРѕ', 'РџРѕРІРµСЂРЅРµРЅРЅСЏ'].includes(part.status));
    if (unfinishedParts) {
      setNotice('Р’РёРґР°С‚Рё Р·Р°РјРѕРІР»РµРЅРЅСЏ РЅРµ РјРѕР¶РЅР°: С” РЅРµР·Р°РІРµСЂС€РµРЅС– Р·Р°РїС‡Р°СЃС‚РёРЅРё Р°Р±Рѕ СЂРµР·РµСЂРІРё.');
      return;
    }
    order.parts.forEach((part) => {
      if (part.status === 'Р’СЃС‚Р°РЅРѕРІР»РµРЅРѕ') {
        patchProduct(part.productId, (item) => ({ ...item, installed: Math.max(item.installed - part.qty, 0) }));
        patchOrderPart(order.id, part.id, (item) => ({ ...item, status: 'РЎРїРёСЃР°РЅРѕ' }));
        addMovement({ type: 'РЎРїРёСЃР°РЅРЅСЏ', productId: part.productId, qty: part.qty, orderId: order.id, comment: 'РђРІС‚РѕРјР°С‚РёС‡РЅРµ СЃРїРёСЃР°РЅРЅСЏ РїСЂРё РІРёРґР°С‡С– С– Р·Р°РєСЂРёС‚С‚С– Р·Р°РјРѕРІР»РµРЅРЅСЏ РјРµРЅРµРґР¶РµСЂРѕРј.' });
        logAction('РЎРїРёСЃР°РЅРЅСЏ РїСЂРё РІРёРґР°С‡С– СЂРµРјРѕРЅС‚Сѓ', order.id, `${productName(part.productId)}: ${part.qty} С€С‚.`);
      }
    });
    setOrders((current) => current.map((item) => {
      if (item.id !== order.id) return item;
      return {
        ...item,
        status: 'Р—Р°РєСЂРёС‚Рѕ',
        statusChangedAt: today,
        actIssuedAt: item.legalEntity ? (item.actIssuedAt ?? today) : item.actIssuedAt,
        statusHistory: [
          {
            id: uid('H'),
            oldStatus: item.status,
            newStatus: 'Р—Р°РєСЂРёС‚Рѕ',
            changedBy: activeUser.name,
            changedAt: today,
            comment: `РњРµРЅРµРґР¶РµСЂ РІРёРґР°РІ Р·Р°РјРѕРІР»РµРЅРЅСЏ РєР»С–С”РЅС‚Сѓ. Р”Р°С‚Р° РІРёРґР°С‡С– С‚Р° РєРѕСЂРёСЃС‚СѓРІР°С‡ Р·Р°С„С–РєСЃРѕРІР°РЅС–: ${activeUser.name}.`,
          },
          ...item.statusHistory,
        ],
      };
    }));
    enqueueClientNotification(order, 'Р’РёРґР°С‡Р°');
    logAction('Р’РёРґР°С‡Р° С– Р·Р°РєСЂРёС‚С‚СЏ Р·Р°РјРѕРІР»РµРЅРЅСЏ', order.id, `Р’РёРґР°РІ ${activeUser.name}. Р”Р°С‚Р° РІРёРґР°С‡С–: ${today}.`);
    setNotice(`${order.id}: Р·Р°РјРѕРІР»РµРЅРЅСЏ РІРёРґР°РЅРѕ С– Р·Р°РєСЂРёС‚Рѕ. Р”Р°С‚Р° РІРёРґР°С‡С– С‚Р° РєРѕСЂРёСЃС‚СѓРІР°С‡ Р·Р°С„С–РєСЃРѕРІР°РЅС–.`);
  }

  function validateOrderTransition(order: ServiceOrder, nextStatus: OrderStatus) {
    if (nextStatus === 'РќРµ РїС–РґР»СЏРіР°С” СЂРµРјРѕРЅС‚Сѓ') {
      if (!roleCanSetOrderStatus(activeUser.role, nextStatus)) {
        return `Р РѕР»СЊ "${activeUser.role}" РЅРµ РјР°С” РїСЂР°РІР° РІСЃС‚Р°РЅРѕРІР»СЋРІР°С‚Рё СЃС‚Р°С‚СѓСЃ "${nextStatus}".`;
      }
      if (['Р—Р°РєСЂРёС‚Рѕ', 'Р’РёРґР°РЅРѕ', 'РЎРєР°СЃРѕРІР°РЅРѕ'].includes(order.status)) {
        return 'РќРµ РјРѕР¶РЅР° Р·РјС–РЅРёС‚Рё РІР¶Рµ РІРёРґР°РЅРёР№, Р·Р°РєСЂРёС‚РёР№ Р°Р±Рѕ СЃРєР°СЃРѕРІР°РЅРёР№ Р·Р°РєР°Р· РЅР° "РќРµ РїС–РґР»СЏРіР°С” СЂРµРјРѕРЅС‚Сѓ".';
      }
      return '';
    }
    const allowedNext = orderStatusFlow[order.status] ?? [];
    if (order.status !== nextStatus && !allowedNext.includes(nextStatus) && activeUser.role !== 'Р СѓРєРѕРІРѕРґРёС‚РµР»СЊ' && activeUser.role !== 'РђРґРјС–РЅС–СЃС‚СЂР°С‚РѕСЂ') {
      return `РџРµСЂРµС…С–Рґ "${order.status}" -> "${nextStatus}" РЅРµ РґРѕР·РІРѕР»РµРЅРёР№ Р±С–Р·РЅРµСЃ-РїСЂРѕС†РµСЃРѕРј.`;
    }
    if (!roleCanSetOrderStatus(activeUser.role, nextStatus)) {
      return `Р РѕР»СЊ "${activeUser.role}" РЅРµ РјР°С” РїСЂР°РІР° РІСЃС‚Р°РЅРѕРІР»СЋРІР°С‚Рё СЃС‚Р°С‚СѓСЃ "${nextStatus}".`;
    }
    if (nextStatus === 'РџРѕРіРѕРґР¶РµРЅРѕ' && !order.diagnosisResult) {
      return 'РќРµ РјРѕР¶РЅР° РїРѕРіРѕРґРёС‚Рё СЂРµРјРѕРЅС‚ Р±РµР· СЂРµР·СѓР»СЊС‚Р°С‚Сѓ РґС–Р°РіРЅРѕСЃС‚РёРєРё.';
    }
    if (nextStatus === 'РћС‡С–РєСѓС” Р·Р°РїС‡Р°СЃС‚РёРЅСѓ' && order.parts.length === 0) {
      return 'РќРµ РјРѕР¶РЅР° РѕС‡С–РєСѓРІР°С‚Рё Р·Р°РїС‡Р°СЃС‚РёРЅСѓ Р±РµР· СЃС‚РІРѕСЂРµРЅРѕС— РїРѕС‚СЂРµР±Рё Р°Р±Рѕ РґРѕРґР°РЅРѕС— РґРµС‚Р°Р»С–.';
    }
    if (nextStatus === 'Р’ СЂРµРјРѕРЅС‚С–') {
      if (!order.engineer) return 'РќРµ РјРѕР¶РЅР° РїРµСЂРµРґР°С‚Рё РІ СЂРµРјРѕРЅС‚ Р±РµР· РїСЂРёР·РЅР°С‡РµРЅРѕРіРѕ С–РЅР¶РµРЅРµСЂР°.';
      if (!order.engineerAcceptedAt) return 'Р†РЅР¶РµРЅРµСЂ РјР°С” СЃРїРѕС‡Р°С‚РєСѓ РЅР°С‚РёСЃРЅСѓС‚Рё "Р’Р·СЏС‚Рё РІ СЂРѕР±РѕС‚Сѓ".';
    }
    if (nextStatus === 'Р“РѕС‚РѕРІРёР№ РґРѕ РІРёРґР°С‡С–') {
      const unfinishedParts = order.parts.some((part) => !['Р’СЃС‚Р°РЅРѕРІР»РµРЅРѕ', 'РЎРїРёСЃР°РЅРѕ', 'РџРѕРІРµСЂРЅРµРЅРЅСЏ'].includes(part.status));
      if (unfinishedParts) return 'РќРµ РјРѕР¶РЅР° РїРѕР·РЅР°С‡РёС‚Рё РіРѕС‚РѕРІРёРј: С” РЅРµР·Р°РІРµСЂС€РµРЅС– Р·Р°РїС‡Р°СЃС‚РёРЅРё.';
    }
    if (nextStatus === 'Р’РёРґР°РЅРѕ' && order.status !== 'Р“РѕС‚РѕРІРёР№ РґРѕ РІРёРґР°С‡С–' && order.status !== 'РћС‡С–РєСѓС” РѕРїР»Р°С‚Рё' && order.status !== 'РћС‡С–РєСѓС” РєР»С–С”РЅС‚Р°' && order.status !== 'РќРµ РїС–РґР»СЏРіР°С” СЂРµРјРѕРЅС‚Сѓ') {
      return 'Р’РёРґР°С‚Рё РјРѕР¶РЅР° С‚С–Р»СЊРєРё РїС–СЃР»СЏ РіРѕС‚РѕРІРЅРѕСЃС‚С–, РѕС‡С–РєСѓРІР°РЅРЅСЏ РѕРїР»Р°С‚Рё, РѕС‡С–РєСѓРІР°РЅРЅСЏ РєР»С–С”РЅС‚Р° Р°Р±Рѕ СЃС‚Р°С‚СѓСЃСѓ "РќРµ РїС–РґР»СЏРіР°С” СЂРµРјРѕРЅС‚Сѓ".';
    }
    if (nextStatus === 'Р—Р°РєСЂРёС‚Рѕ' && order.status !== 'Р’РёРґР°РЅРѕ') {
      return 'Р—Р°РєСЂРёС‚Рё Р·Р°РєР°Р· РјРѕР¶РЅР° С‚С–Р»СЊРєРё РїС–СЃР»СЏ С„С–Р·РёС‡РЅРѕС— РІРёРґР°С‡С– РїСЂРёСЃС‚СЂРѕСЋ.';
    }
    return '';
  }

  function changeOrderStatus(order: ServiceOrder, nextStatus: OrderStatus, comment: string) {
    const error = validateOrderTransition(order, nextStatus);
    if (error) {
      setNotice(error);
      return;
    }
    if (nextStatus === 'РќРµ РїС–РґР»СЏРіР°С” СЂРµРјРѕРЅС‚Сѓ' && comment.trim().length < 10) {
      setNotice('РџРѕС‚СЂС–Р±РЅРѕ РІРєР°Р·Р°С‚Рё РїСЂРёС‡РёРЅСѓ: С‡РѕРјСѓ РїСЂРёСЃС‚СЂС–Р№ РЅРµ РїС–РґР»СЏРіР°С” СЂРµРјРѕРЅС‚Сѓ.');
      return;
    }
    if (nextStatus === 'РЎРєР°СЃРѕРІР°РЅРѕ') {
      order.parts.forEach((part) => {
        if (part.status === 'Р—Р°СЂРµР·РµСЂРІРѕРІР°РЅРѕ') {
          patchProduct(part.productId, (product) => ({ ...product, reserved: Math.max(product.reserved - part.qty, 0) }));
          addMovement({ type: 'Р—РЅСЏС‚С‚СЏ СЂРµР·РµСЂРІСѓ', productId: part.productId, qty: part.qty, orderId: order.id, comment: 'Р РµРјРѕРЅС‚ СЃРєР°СЃРѕРІР°РЅРѕ, СЂРµР·РµСЂРІ Р·РЅСЏС‚Рѕ.' });
        }
      });
    }
    if (nextStatus === 'Р“РѕС‚РѕРІРёР№ РґРѕ РІРёРґР°С‡С–') {
      updateOrderStatus(order.id, nextStatus, comment);
      enqueueClientNotification({ ...order, status: nextStatus }, 'Р“РѕС‚РѕРІРѕ РґРѕ РІРёРґР°С‡С–');
      const createdKinds = createSmartReadyDocuments(order);
      logAction('Р—РјС–РЅР° СЃС‚Р°С‚СѓСЃСѓ СЂРµРјРѕРЅС‚Сѓ', order.id, `${order.status} -> ${nextStatus}. ${comment}`);
      setNotice(`Р†РЅР¶РµРЅРµСЂ РЅР°С‚РёСЃРЅСѓРІ "Р“РѕС‚РѕРІРѕ". ${order.id}: Р°РєС‚, СЂР°С…СѓРЅРѕРє${order.parts.length > 0 ? ' С– РІРёРґР°С‚РєРѕРІР°' : ''} РїРµСЂРµРІС–СЂРµРЅС– Р°РІС‚РѕРјР°С‚РёС‡РЅРѕ. РЎС‚РІРѕСЂРµРЅРѕ: ${createdKinds.length ? createdKinds.join(', ') : 'РґРѕРєСѓРјРµРЅС‚Рё РІР¶Рµ Р±СѓР»Рё'}.`);
      return;
    }
    if (nextStatus === 'РќРµ РїС–РґР»СЏРіР°С” СЂРµРјРѕРЅС‚Сѓ') {
      updateOrderStatus(order.id, 'РќРµ РїС–РґР»СЏРіР°С” СЂРµРјРѕРЅС‚Сѓ', comment);
      enqueueClientNotification(order, 'Р“РѕС‚РѕРІРѕ РґРѕ РІРёРґР°С‡С–');
      logAction('РќРµ РїС–РґР»СЏРіР°С” СЂРµРјРѕРЅС‚Сѓ', order.id, `РџСЂРёС‡РёРЅР°: ${comment}. Р—Р°РјРѕРІР»РµРЅРЅСЏ РІРёРІРµРґРµРЅРѕ Р· Р°РєС‚РёРІРЅРёС… СЂРµРјРѕРЅС‚С–РІ С– РіРѕС‚РѕРІРµ РґРѕ РІРёРґР°С‡С– РєР»С–С”РЅС‚Сѓ.`);
      setNotice(`${order.id}: СЂРµРјРѕРЅС‚ РЅРµРјРѕР¶Р»РёРІРёР№. Р—Р°РјРѕРІР»РµРЅРЅСЏ РІРёРІРµРґРµРЅРѕ Р· Р°РєС‚РёРІРЅРёС… СЂРµРјРѕРЅС‚С–РІ С– РіРѕС‚РѕРІРµ РґРѕ РІРёРґР°С‡С–.`);
      return;
    }
    if (nextStatus === 'Р’РёРґР°РЅРѕ') {
      updateOrderStatus(order.id, 'Р’РёРґР°РЅРѕ', comment);
      enqueueClientNotification(order, 'Р’РёРґР°С‡Р°');
      logAction('Р’РёРґР°С‡Р° РїСЂРёСЃС‚СЂРѕСЋ', order.id, 'РџСЂРёСЃС‚СЂС–Р№ С„С–Р·РёС‡РЅРѕ РїРµСЂРµРґР°РЅРѕ РєР»С–С”РЅС‚Сѓ.');
      return;
    }
    if (nextStatus === 'Р—Р°РєСЂРёС‚Рѕ') {
      closeOrder(order);
      return;
    }
    updateOrderStatus(order.id, nextStatus, comment);
    const event = notificationEventForStatus(nextStatus);
    if (event) enqueueClientNotification({ ...order, status: nextStatus }, event);
    logAction('Р—РјС–РЅР° СЃС‚Р°С‚СѓСЃСѓ СЂРµРјРѕРЅС‚Сѓ', order.id, `${order.status} -> ${nextStatus}. ${comment}`);
    setNotice(`${order.id}: СЃС‚Р°С‚СѓСЃ Р·РјС–РЅРµРЅРѕ РЅР° "${nextStatus}".`);
  }

  function acceptOrderWork(order: ServiceOrder) {
    if (activeUser.role !== 'Р†РЅР¶РµРЅРµСЂ' || order.engineer !== activeUser.name) {
      setNotice('Р’Р·СЏС‚Рё РІ СЂРѕР±РѕС‚Сѓ РјРѕР¶Рµ С‚С–Р»СЊРєРё РїСЂРёР·РЅР°С‡РµРЅРёР№ С–РЅР¶РµРЅРµСЂ.');
      return;
    }
    setOrders((current) => current.map((item) => {
      if (item.id !== order.id) return item;
      const nextStatus: OrderStatus = item.status === 'РџСЂРёР№РЅСЏС‚Рѕ' ? 'Р’ СЂРµРјРѕРЅС‚С–' : item.status;
      return {
        ...item,
        engineerAcceptedAt: today,
        status: nextStatus,
        statusChangedAt: nextStatus !== item.status ? today : item.statusChangedAt,
        statusHistory: nextStatus !== item.status
          ? [{ id: uid('H'), oldStatus: item.status, newStatus: nextStatus, changedBy: activeUser.name, changedAt: today, comment: 'Р†РЅР¶РµРЅРµСЂ РЅР°С‚РёСЃРЅСѓРІ "Р’Р·СЏС‚Рё РІ СЂРѕР±РѕС‚Сѓ". CRM Р°РІС‚РѕРјР°С‚РёС‡РЅРѕ РїРµСЂРµРІРµР»Р° Р·Р°РєР°Р· Сѓ СЂРѕР±РѕС‚Сѓ.' }, ...item.statusHistory]
          : item.statusHistory,
      };
    }));
    logAction('Р†РЅР¶РµРЅРµСЂ РІР·СЏРІ Р·Р°РєР°Р·', order.id, `${activeUser.name} РїС–РґС‚РІРµСЂРґРёРІ СЂРѕР±РѕС‚Сѓ. РЎС‚Р°С‚СѓСЃ Р°РІС‚РѕРјР°С‚РёС‡РЅРѕ РїРµСЂРµРІРµРґРµРЅРѕ РІ СЂРѕР±РѕС‚Сѓ.`);
    setNotice(`${order.id}: С–РЅР¶РµРЅРµСЂ РІР·СЏРІ Р·Р°РєР°Р· Сѓ СЂРѕР±РѕС‚Сѓ. РЎС‚Р°С‚СѓСЃ РѕРЅРѕРІР»РµРЅРѕ Р°РІС‚РѕРјР°С‚РёС‡РЅРѕ.`);
  }

  function reassignEngineer(order: ServiceOrder) {
    const engineers = users.filter((user) => user.role === 'Р†РЅР¶РµРЅРµСЂ');
    const currentIndex = engineers.findIndex((user) => user.name === order.engineer);
    const nextEngineer = engineers[(currentIndex + 1) % engineers.length] ?? engineers[0];
    if (!nextEngineer) return;
    setOrders((current) => current.map((item) => (item.id === order.id ? { ...item, engineer: nextEngineer.name, engineerAcceptedAt: undefined } : item)));
    setActionLogs((current) => [{ id: uid('LOG'), date: today, user: activeUser.name, role: activeUser.role, action: 'Р—РјС–РЅР° С–РЅР¶РµРЅРµСЂР°', entity: order.id, comment: `${order.engineer} -> ${nextEngineer.name}` }, ...current]);
    setNotice(`${order.id}: С–РЅР¶РµРЅРµСЂР° Р·РјС–РЅРµРЅРѕ РЅР° ${nextEngineer.name}.`);
  }

  function addOrderPayment(order: ServiceOrder, amount: number, method: PaymentMethod, comment: string) {
    const totals = orderTotals(order);
    if (amount <= 0) {
      setNotice('РЎСѓРјР° РѕРїР»Р°С‚Рё РјР°С” Р±СѓС‚Рё Р±С–Р»СЊС€РѕСЋ Р·Р° 0.');
      return;
    }
    if (totals.debt <= 0) {
      setNotice('Р¤С–РЅР°РЅСЃРѕРІР° С‡Р°СЃС‚РёРЅР° Р·Р°РјРѕРІР»РµРЅРЅСЏ РІР¶Рµ Р·Р°РєСЂРёС‚Р°: Р±РѕСЂРіСѓ РЅРµРјР°С”.');
      return;
    }
    const amountToApply = Math.min(amount, totals.debt);
    const status: Payment['status'] = method === 'Р‘РµР·РіРѕС‚С–РІРєР°' ? 'РћС‡С–РєСѓС” РїС–РґС‚РІРµСЂРґР¶РµРЅРЅСЏ' : 'РџС–РґС‚РІРµСЂРґР¶РµРЅРѕ';
    const type = paymentTypeFor(amountToApply, totals.debt || amountToApply, comment === 'РџРµСЂРµРґРїР»Р°С‚Р°' ? 'РџРµСЂРµРґРїР»Р°С‚Р°' : 'Р”РѕРїР»Р°С‚Р°');
    const transactionNo = method === 'РљР°СЂС‚РєР°' ? uid('TERM') : method === 'Р‘РµР·РіРѕС‚С–РІРєР°' ? uid('BANK') : uid('CASH');
    const paidInFull = totals.debt - amountToApply <= 0;
    const canAutoReadyAfterPayment = paidInFull && method !== 'Р‘РµР·РіРѕС‚С–РІРєР°' && ['Р“РѕС‚РѕРІРёР№ РґРѕ РІРёРґР°С‡С–', 'РћС‡С–РєСѓС” РѕРїР»Р°С‚Рё', 'РћС‡С–РєСѓС” РєР»С–С”РЅС‚Р°'].includes(order.status);
    setOrders((current) =>
      current.map((item) =>
        item.id === order.id
          ? {
              ...item,
              status: canAutoReadyAfterPayment ? 'Р“РѕС‚РѕРІРёР№ РґРѕ РІРёРґР°С‡С–' : item.status,
              statusChangedAt: canAutoReadyAfterPayment ? today : item.statusChangedAt,
              vatStatus: item.vatStatus ?? 'Р“РѕС‚РѕРІРѕ РґРѕ СЂРµС”СЃС‚СЂР°С†С–С— РџРќ',
              debtSince: item.debtSince ?? today,
              payments: [...item.payments, { id: uid('PAY'), date: today, amount: amountToApply, method, type, transactionNo, acceptedBy: activeUser.name, orderId: order.id, comment, status }],
              statusHistory: canAutoReadyAfterPayment && item.status !== 'Р“РѕС‚РѕРІРёР№ РґРѕ РІРёРґР°С‡С–'
                ? [{ id: uid('H'), oldStatus: item.status, newStatus: 'Р“РѕС‚РѕРІРёР№ РґРѕ РІРёРґР°С‡С–', changedBy: 'РЎРёСЃС‚РµРјР°', changedAt: today, comment: 'РћРїР»Р°С‚Р° 100%. CRM Р°РІС‚РѕРјР°С‚РёС‡РЅРѕ РїС–РґС‚РІРµСЂРґРёР»Р° РіРѕС‚РѕРІРЅС–СЃС‚СЊ РґРѕ РІРёРґР°С‡С–.' }, ...item.statusHistory]
                : item.statusHistory,
            }
          : item,
      ),
    );
    if (method !== 'Р‘РµР·РіРѕС‚С–РІРєР°') {
      registerCashPayment(amountToApply, method);
      if (paidInFull) {
        const writtenOff = writeOffInstalledPartsForOrder(order, 'РђРІС‚РѕРјР°С‚РёС‡РЅРµ СЃРїРёСЃР°РЅРЅСЏ РІСЃС‚Р°РЅРѕРІР»РµРЅРёС… Р·Р°РїС‡Р°СЃС‚РёРЅ РїС–СЃР»СЏ РїРѕРІРЅРѕС— РѕРїР»Р°С‚Рё СЂРµРјРѕРЅС‚Сѓ.');
        if (writtenOff > 0) logAction('РђРІС‚РѕСЃРїРёСЃР°РЅРЅСЏ РїС–СЃР»СЏ РѕРїР»Р°С‚Рё', order.id, `РЎРїРёСЃР°РЅРѕ РїРѕР·РёС†С–Р№: ${writtenOff}.`);
      }
    }
    logAction('РџСЂРёР№РѕРј РѕРїР»Р°С‚Рё СЂРµРјРѕРЅС‚Сѓ', order.id, `${method}: ${money(amountToApply)}. ${comment}. РЎС‚Р°С‚СѓСЃ: ${status}.`);
    logAction('РќР”РЎ РїРѕРґС–СЏ', order.id, 'РћРїР»Р°С‚Р° Р·Р°С„С–РєСЃРѕРІР°РЅР°: РґР°РЅС– РіРѕС‚РѕРІС– РґРѕ С„РѕСЂРјСѓРІР°РЅРЅСЏ РќРќ Р·Р° РїСЂР°РІРёР»Р°РјРё СЃРёСЃС‚РµРјРё.');
    if (canAutoReadyAfterPayment) logAction('РђРІС‚РѕСЃС‚Р°С‚СѓСЃ РїС–СЃР»СЏ РѕРїР»Р°С‚Рё', order.id, 'РћРїР»Р°С‚Р° 100%: CRM РїРµСЂРµРІРµР»Р° Р·Р°РєР°Р· Сѓ "Р“РѕС‚РѕРІРёР№ РґРѕ РІРёРґР°С‡С–".');
    setNotice(method === 'Р‘РµР·РіРѕС‚С–РІРєР°'
      ? `${comment}: Р±РµР·РіРѕС‚С–РІРєРѕРІСѓ РѕРїР»Р°С‚Сѓ ${money(amountToApply)} Р·Р°С„С–РєСЃРѕРІР°РЅРѕ РґР»СЏ ${order.id}. РџРѕС‚СЂС–Р±РЅРµ РїС–РґС‚РІРµСЂРґР¶РµРЅРЅСЏ Р±СѓС…РіР°Р»С‚РµСЂР°.`
      : `${comment}: РїСЂРёР№РЅСЏС‚Рѕ ${money(amountToApply)} РґР»СЏ ${order.id}. Р—Р°Р»РёС€РѕРє ${money(Math.max(totals.debt - amountToApply, 0))}.`);
  }

  function transferOrderToBas(order: ServiceOrder) {
    const orderDocuments = documents.filter((document) => document.entityType === 'service_order' && document.entityId === order.id);
    const hasAct = orderDocuments.some((document) => ['РђРєС‚ РЅР°РґР°РЅРЅСЏ РїРѕСЃР»СѓРі', 'РђРєС‚ РІРёРєРѕРЅР°РЅРёС… СЂРѕР±С–С‚', 'РђРєС‚ РІРёРґР°С‡С–', 'РђРєС‚ С‚РµС…РЅС–С‡РЅРѕРіРѕ СЃС‚Р°РЅСѓ'].includes(document.kind));
    const hasInvoice = orderDocuments.some((document) => document.kind === 'Р Р°С…СѓРЅРѕРє РЅР° РѕРїР»Р°С‚Сѓ');
    const hasDelivery = order.parts.length === 0 || orderDocuments.some((document) => document.kind === 'Р’РёРґР°С‚РєРѕРІР° РЅР°РєР»Р°РґРЅР°');
    const hasPayment = order.payments.some((payment) => payment.status !== 'РћС‡С–РєСѓС” РїС–РґС‚РІРµСЂРґР¶РµРЅРЅСЏ');
    if (!hasAct || !hasInvoice || !hasDelivery || !hasPayment) {
      setNotice('РџРµСЂРµРґР°С‡Р° РІ BAS РЅРµРґРѕСЃС‚СѓРїРЅР°: РїРѕС‚СЂС–Р±РЅС– Р°РєС‚, СЂР°С…СѓРЅРѕРє, РІРёРґР°С‚РєРѕРІР° РґР»СЏ С‚РѕРІР°СЂС–РІ С– РїС–РґС‚РІРµСЂРґР¶РµРЅР° РѕРїР»Р°С‚Р°.');
      return;
    }
    logAction('РџРµСЂРµРґР°С‡Р° РІ BAS', order.id, `РџРµСЂРµРґР°РЅРѕ: Р°РєС‚, СЂР°С…СѓРЅРѕРє, ${order.parts.length ? 'РІРёРґР°С‚РєРѕРІР°, ' : ''}РѕРїР»Р°С‚Р°. Р”РѕРєСѓРјРµРЅС‚С–РІ: ${orderDocuments.length}.`);
    setNotice(`${order.id}: РґР°РЅС– РїС–РґРіРѕС‚РѕРІР»РµРЅРѕ С– РїРµСЂРµРґР°РЅРѕ РІ BAS: Р°РєС‚, СЂР°С…СѓРЅРѕРє, ${order.parts.length ? 'РІРёРґР°С‚РєРѕРІР°, ' : ''}РѕРїР»Р°С‚Р°.`);
  }

  function confirmBankPayment(paymentId: string) {
    let confirmed: Payment | undefined;
    let sourceOrder: ServiceOrder | undefined;
    setOrders((current) => current.map((order) => {
      const payment = order.payments.find((item) => item.id === paymentId && item.method === 'Р‘РµР·РіРѕС‚С–РІРєР°' && item.status === 'РћС‡С–РєСѓС” РїС–РґС‚РІРµСЂРґР¶РµРЅРЅСЏ');
      if (!payment) return order;
      confirmed = payment;
      sourceOrder = order;
      return {
        ...order,
        payments: order.payments.map((item) => (item.id === paymentId ? { ...item, status: 'РџС–РґС‚РІРµСЂРґР¶РµРЅРѕ', confirmedBy: activeUser.name, confirmedAt: today } : item)),
      };
    }));
    setSales((current) => current.map((sale) => {
      const payment = sale.payments.find((item) => item.id === paymentId && item.method === 'Р‘РµР·РіРѕС‚С–РІРєР°' && item.status === 'РћС‡С–РєСѓС” РїС–РґС‚РІРµСЂРґР¶РµРЅРЅСЏ');
      if (payment && !confirmed) confirmed = payment;
      return {
        ...sale,
        payments: sale.payments.map((item) => (item.id === paymentId && item.method === 'Р‘РµР·РіРѕС‚С–РІРєР°' && item.status === 'РћС‡С–РєСѓС” РїС–РґС‚РІРµСЂРґР¶РµРЅРЅСЏ' ? { ...item, status: 'РџС–РґС‚РІРµСЂРґР¶РµРЅРѕ', confirmedBy: activeUser.name, confirmedAt: today } : item)),
      };
    }));
    if (!confirmed) {
      setNotice('Р‘РµР·РіРѕС‚С–РІРєРѕРІСѓ РѕРїР»Р°С‚Сѓ РЅРµ Р·РЅР°Р№РґРµРЅРѕ Р°Р±Рѕ РІРѕРЅР° РІР¶Рµ РїС–РґС‚РІРµСЂРґР¶РµРЅР°.');
      return;
    }
    registerCashPayment(confirmed.amount, 'Р‘РµР·РіРѕС‚С–РІРєР°');
    if (sourceOrder && orderTotals(sourceOrder).debt - confirmed.amount <= 0) {
      writeOffInstalledPartsForOrder(sourceOrder, 'РђРІС‚РѕРјР°С‚РёС‡РЅРµ СЃРїРёСЃР°РЅРЅСЏ РІСЃС‚Р°РЅРѕРІР»РµРЅРёС… Р·Р°РїС‡Р°СЃС‚РёРЅ РїС–СЃР»СЏ РїС–РґС‚РІРµСЂРґР¶РµРЅРЅСЏ Р±РµР·РіРѕС‚С–РІРєРѕРІРѕС— РѕРїР»Р°С‚Рё.');
    }
    logAction('РџС–РґС‚РІРµСЂРґР¶РµРЅРЅСЏ Р±РµР·РіРѕС‚С–РІРєРё', confirmed.orderId ?? confirmed.saleId ?? paymentId, `${money(confirmed.amount)} РїС–РґС‚РІРµСЂРґРёРІ ${activeUser.name}.`);
    setNotice(`Р‘РµР·РіРѕС‚С–РІРєРѕРІСѓ РѕРїР»Р°С‚Сѓ ${money(confirmed.amount)} РїС–РґС‚РІРµСЂРґР¶РµРЅРѕ Р±СѓС…РіР°Р»С‚РµСЂРѕРј.`);
  }

  function returnServicePart(order: ServiceOrder, part: OrderPart, destination: 'РќР° СЃРєР»Р°Рґ' | 'Р‘СЂР°Рє') {
    if (!['Р—Р°СЂРµР·РµСЂРІРѕРІР°РЅРѕ', 'Р’РёРґР°РЅРѕ С–РЅР¶РµРЅРµСЂСѓ', 'Р’СЃС‚Р°РЅРѕРІР»РµРЅРѕ'].includes(part.status)) {
      setNotice('РџРѕРІРµСЂРЅРµРЅРЅСЏ РЅРµРјРѕР¶Р»РёРІРµ РґР»СЏ С†СЊРѕРіРѕ СЃС‚Р°С‚СѓСЃСѓ Р·Р°РїС‡Р°СЃС‚РёРЅРё.');
      return;
    }
    if (part.status === 'Р—Р°СЂРµР·РµСЂРІРѕРІР°РЅРѕ') {
      patchProduct(part.productId, (item) => ({ ...item, reserved: Math.max(item.reserved - part.qty, 0) }));
      addMovement({ type: 'Р—РЅСЏС‚С‚СЏ СЂРµР·РµСЂРІСѓ', productId: part.productId, qty: part.qty, orderId: order.id, comment: 'Р—Р°РїС‡Р°СЃС‚РёРЅР° Р·РЅСЏС‚Р° Р· СЂРµРјРѕРЅС‚Сѓ РґРѕ РІРёРґР°С‡С– С–РЅР¶РµРЅРµСЂСѓ.' });
    }
    if (part.status === 'Р’РёРґР°РЅРѕ С–РЅР¶РµРЅРµСЂСѓ') {
      patchProduct(part.productId, (item) => ({
        ...item,
        withEngineer: Math.max(item.withEngineer - part.qty, 0),
        stock: destination === 'РќР° СЃРєР»Р°Рґ' ? item.stock + part.qty : item.stock,
        batches: destination === 'РќР° СЃРєР»Р°Рґ' && part.batchAllocations ? restoreBatchAllocations(item, part.batchAllocations) : item.batches,
      }));
      addMovement({ type: destination === 'РќР° СЃРєР»Р°Рґ' ? 'РџРѕРІРµСЂРЅРµРЅРЅСЏ' : 'РЎРїРёСЃР°РЅРЅСЏ', productId: part.productId, qty: part.qty, orderId: order.id, comment: destination === 'РќР° СЃРєР»Р°Рґ' ? 'Р”РµС‚Р°Р»СЊ РЅРµ РїС–РґС–Р№С€Р»Р°, РїРѕРІРµСЂРЅСѓС‚Р° РЅР° СЃРєР»Р°Рґ.' : 'Р”РµС‚Р°Р»СЊ РЅРµ РїС–РґС–Р№С€Р»Р°, РїРµСЂРµРІРµРґРµРЅР° РІ Р±СЂР°Рє.' });
    }
    if (part.status === 'Р’СЃС‚Р°РЅРѕРІР»РµРЅРѕ') {
      patchProduct(part.productId, (item) => ({
        ...item,
        installed: Math.max(item.installed - part.qty, 0),
        stock: destination === 'РќР° СЃРєР»Р°Рґ' ? item.stock + part.qty : item.stock,
        batches: destination === 'РќР° СЃРєР»Р°Рґ' && part.batchAllocations ? restoreBatchAllocations(item, part.batchAllocations) : item.batches,
      }));
      addMovement({ type: destination === 'РќР° СЃРєР»Р°Рґ' ? 'РџРѕРІРµСЂРЅРµРЅРЅСЏ' : 'РЎРїРёСЃР°РЅРЅСЏ', productId: part.productId, qty: part.qty, orderId: order.id, comment: destination === 'РќР° СЃРєР»Р°Рґ' ? 'Р’СЃС‚Р°РЅРѕРІР»РµРЅР° РґРµС‚Р°Р»СЊ Р·РЅСЏС‚Р° С– РїРѕРІРµСЂРЅСѓС‚Р° РЅР° СЃРєР»Р°Рґ.' : 'Р’СЃС‚Р°РЅРѕРІР»РµРЅР° РґРµС‚Р°Р»СЊ Р·РЅСЏС‚Р° С– СЃРїРёСЃР°РЅР° РІ Р±СЂР°Рє.' });
    }
    patchOrderPart(order.id, part.id, (item) => ({ ...item, status: 'РџРѕРІРµСЂРЅРµРЅРЅСЏ', price: 0, batchAllocations: destination === 'РќР° СЃРєР»Р°Рґ' ? [] : item.batchAllocations }));
    logAction('РџРѕРІРµСЂРЅРµРЅРЅСЏ РІ СЃРµСЂРІС–СЃС–', order.id, `${productName(part.productId)}: ${part.qty} С€С‚., РЅР°РїСЂСЏРјРѕРє: ${destination}.`);
    setNotice('Р—Р°РїС‡Р°СЃС‚РёРЅСѓ Р·РЅСЏС‚Рѕ С–Р· СЃРµСЂРІС–СЃРЅРѕРіРѕ Р·Р°РјРѕРІР»РµРЅРЅСЏ, СЃРѕР±С–РІР°СЂС‚С–СЃС‚СЊ СЂРµРјРѕРЅС‚Сѓ РїРµСЂРµСЂР°С…РѕРІР°РЅР°.');
  }

  function updateSaleStatus(sale: Sale): SaleStatus {
    const totals = saleTotals(sale);
    const hasReserved = sale.items.some((item) => item.status === 'Р—Р°СЂРµР·РµСЂРІРѕРІР°РЅРѕ');
    const hasIssued = sale.items.length > 0 && sale.items.every((item) => ['Р’РёРґР°РЅРѕ', 'РџРѕРІРµСЂРЅРµРЅРЅСЏ', 'РЎРєР°СЃРѕРІР°РЅРѕ'].includes(item.status));
    if (sale.status === 'РЎРєР°СЃРѕРІР°РЅРѕ' || sale.status === 'РџРѕРІРµСЂРЅРµРЅРЅСЏ' || sale.status === 'Р—Р°РєСЂРёС‚Рѕ') return sale.status;
    if (hasIssued && totals.debt === 0) return 'Р—Р°РєСЂРёС‚Рѕ';
    if (hasIssued) return 'Р’РёРґР°РЅРѕ';
    if (totals.paid > 0 && totals.debt > 0) return 'Р§Р°СЃС‚РєРѕРІРѕ РѕРїР»Р°С‡РµРЅРѕ';
    if (totals.paid >= totals.total && totals.total > 0) return 'РћРїР»Р°С‡РµРЅРѕ';
    if (hasReserved) return totals.paid > 0 ? 'Р§Р°СЃС‚РєРѕРІРѕ РѕРїР»Р°С‡РµРЅРѕ' : 'Р—Р°СЂРµР·РµСЂРІРѕРІР°РЅРѕ';
    return sale.items.length > 0 ? 'РћС‡С–РєСѓС” РѕРїР»Р°С‚Рё' : 'Р§РµСЂРЅРµС‚РєР°';
  }

  function patchSale(saleId: string, updater: (sale: Sale) => Sale) {
    setSales((current) => current.map((sale) => (sale.id === saleId ? updater(sale) : sale)));
  }

  function addSaleItem() {
    const product = products.find((item) => item.id === selectedSaleProductId);
    if (!product || !selectedSale) return;
    const line: SaleItem = { id: uid('SI'), productId: product.id, qty: Math.max(1, saleQty), price: product.price, cost: product.cost, discount: 0, status: 'Р§РµСЂРЅРµС‚РєР°' };
    patchSale(selectedSale.id, (sale) => {
      const next = { ...sale, items: [...sale.items, line] };
      return { ...next, status: updateSaleStatus(next) };
    });
    logAction('Р”РѕРґР°РІР°РЅРЅСЏ С‚РѕРІР°СЂСѓ РІ РїСЂРѕРґР°Р¶', selectedSale.id, `${product.name}: ${line.qty} С€С‚.`);
    setNotice(`РўРѕРІР°СЂ "${product.name}" РґРѕРґР°РЅРѕ РІ РїСЂРѕРґР°Р¶ ${selectedSale.id}.`);
  }

  function reserveSale(sale: Sale) {
    let blocked = '';
    sale.items.forEach((item) => {
      if (item.status !== 'Р§РµСЂРЅРµС‚РєР°') return;
      const product = products.find((entry) => entry.id === item.productId);
      if (!product || available(product) < item.qty) {
        blocked = `РќРµРґРѕСЃС‚Р°С‚РЅСЊРѕ Р·Р°Р»РёС€РєСѓ РґР»СЏ "${product?.name ?? item.productId}".`;
        return;
      }
      patchProduct(item.productId, (entry) => ({ ...entry, reserved: entry.reserved + item.qty }));
      addMovement({ type: 'Р РµР·РµСЂРІ', productId: item.productId, qty: item.qty, orderId: sale.id, comment: 'Р РµР·РµСЂРІ С‚РѕРІР°СЂСѓ РїС–Рґ РїСЂРѕРґР°Р¶.' });
    });
    if (blocked) {
      setNotice(blocked);
      return;
    }
    patchSale(sale.id, (item) => {
      const next = { ...item, items: item.items.map((line) => (line.status === 'Р§РµСЂРЅРµС‚РєР°' ? { ...line, status: 'Р—Р°СЂРµР·РµСЂРІРѕРІР°РЅРѕ' as const } : line)) };
      return { ...next, status: updateSaleStatus(next) };
    });
    logAction('Р РµР·РµСЂРІ РїСЂРѕРґР°Р¶Сѓ', sale.id, 'РўРѕРІР°СЂРё Р·Р°СЂРµР·РµСЂРІРѕРІР°РЅРѕ РїС–Рґ РїСЂРѕРґР°Р¶.');
    setNotice(`РўРѕРІР°СЂРё Р·Р°СЂРµР·РµСЂРІРѕРІР°РЅРѕ РїС–Рґ РїСЂРѕРґР°Р¶ ${sale.id}.`);
  }

  function acceptSalePayment(sale: Sale, amount: number, method: PaymentMethod, comment: string) {
    if (amount <= 0) return;
    const type = paymentTypeFor(amount, saleTotals(sale).debt || amount, comment === 'Р§Р°СЃС‚РєРѕРІР° РѕРїР»Р°С‚Р°' ? 'Р§Р°СЃС‚РєРѕРІР° РѕРїР»Р°С‚Р°' : 'РџРѕРІРЅР° РѕРїР»Р°С‚Р°');
    const transactionNo = method === 'РљР°СЂС‚РєР°' ? uid('TERM') : method === 'Р‘РµР·РіРѕС‚С–РІРєР°' ? uid('BANK') : uid('CASH');
    const status: Payment['status'] = method === 'Р‘РµР·РіРѕС‚С–РІРєР°' ? 'РћС‡С–РєСѓС” РїС–РґС‚РІРµСЂРґР¶РµРЅРЅСЏ' : 'РџС–РґС‚РІРµСЂРґР¶РµРЅРѕ';
    patchSale(sale.id, (item) => {
      const next = { ...item, payments: [...item.payments, { id: uid('PAY'), date: today, amount, method, type, transactionNo, acceptedBy: activeUser.name, saleId: sale.id, comment, status }] };
      return { ...next, status: updateSaleStatus(next) };
    });
    if (method !== 'Р‘РµР·РіРѕС‚С–РІРєР°') registerCashPayment(amount, method);
    logAction('РџСЂРёР№РѕРј РѕРїР»Р°С‚Рё РїСЂРѕРґР°Р¶Сѓ', sale.id, `${method}: ${money(amount)}. ${comment}`);
    setNotice(method === 'Р‘РµР·РіРѕС‚С–РІРєР°' ? `${comment}: Р±РµР·РіРѕС‚С–РІРєСѓ ${money(amount)} Р·Р°С„С–РєСЃРѕРІР°РЅРѕ РґР»СЏ РїСЂРѕРґР°Р¶Сѓ ${sale.id}. РџРѕС‚СЂС–Р±РЅРµ РїС–РґС‚РІРµСЂРґР¶РµРЅРЅСЏ Р±СѓС…РіР°Р»С‚РµСЂР°.` : `${comment}: РїСЂРёР№РЅСЏС‚Рѕ ${money(amount)} РґР»СЏ РїСЂРѕРґР°Р¶Сѓ ${sale.id}.`);
  }

  function issueSale(sale: Sale) {
    const totals = saleTotals(sale);
    if (totals.debt > 0) {
      setNotice('Р’РёРґР°С‚Рё С‚РѕРІР°СЂ РЅРµ РјРѕР¶РЅР°: РїСЂРѕРґР°Р¶ РЅРµ РѕРїР»Р°С‡РµРЅРёР№ РїРѕРІРЅС–СЃС‚СЋ.');
      return;
    }
    const hasUnreserved = sale.items.some((item) => item.status !== 'Р—Р°СЂРµР·РµСЂРІРѕРІР°РЅРѕ');
    if (hasUnreserved) {
      setNotice('Р’РёРґР°С‚Рё С‚РѕРІР°СЂ РЅРµ РјРѕР¶РЅР°: СѓСЃС– РїРѕР·РёС†С–С— РјР°СЋС‚СЊ Р±СѓС‚Рё Р·Р°СЂРµР·РµСЂРІРѕРІР°РЅС–.');
      return;
    }
    const nextProducts = products.map((product) => ({ ...product, batches: product.batches.map((batch) => ({ ...batch })) }));
    const issuedItems = new Map<string, SaleItem>();
    const saleMovements: Array<{ productId: string; qty: number; comment: string }> = [];

    for (const item of sale.items) {
      const productIndex = nextProducts.findIndex((product) => product.id === item.productId);
      if (productIndex === -1) {
        setNotice(`РќРµ РІРґР°Р»РѕСЃСЏ Р·РЅР°Р№С‚Рё С‚РѕРІР°СЂ ${item.productId} РґР»СЏ РІРёРґР°С‡С– РїСЂРѕРґР°Р¶Сѓ.`);
        return;
      }
      const product = nextProducts[productIndex];
      const fifo = fifoConsumeBatches(product, item.qty);
      if (!fifo) {
        setNotice(`РќРµ РІРґР°Р»РѕСЃСЏ СЃРїРёСЃР°С‚Рё ${product.name}: РїРѕ РїР°СЂС‚С–СЏС… РЅРµРґРѕСЃС‚Р°С‚РЅСЊРѕ Р·Р°Р»РёС€РєСѓ РґР»СЏ РІРёРґР°С‡С–.`);
        return;
      }
      nextProducts[productIndex] = {
        ...product,
        stock: product.stock - item.qty,
        reserved: Math.max(product.reserved - item.qty, 0),
        batches: fifo.batches,
      };
      issuedItems.set(item.id, {
        ...item,
        status: 'Р’РёРґР°РЅРѕ',
        cost: Math.round(fifo.totalCost / item.qty),
        batchAllocations: fifo.allocations,
      });
      saleMovements.push({
        productId: item.productId,
        qty: item.qty,
        comment: `РџС–РґС‚РІРµСЂРґР¶РµРЅР° РІРёРґР°С‡Р° РєР»С–С”РЅС‚Сѓ, С‚РѕРІР°СЂ СЃРїРёСЃР°РЅРѕ Р·С– СЃРєР»Р°РґСѓ РїРѕ FIFO. РџР°СЂС‚С–С—: ${fifo.allocations.map((batch) => batch.batchId).join(', ')}.`,
      });
    }

    setProducts(nextProducts);
    saleMovements.forEach((movement) => addMovement({ type: 'РџСЂРѕРґР°Р¶', productId: movement.productId, qty: movement.qty, orderId: sale.id, comment: movement.comment }));
    patchSale(sale.id, (item) => {
      const next = {
        ...item,
        items: item.items.map((line) => issuedItems.get(line.id) ?? line),
      };
      return { ...next, status: updateSaleStatus(next) };
    });
    logAction('Р’РёРґР°С‡Р° РїСЂРѕРґР°Р¶Сѓ', sale.id, 'РўРѕРІР°СЂ РІРёРґР°РЅРѕ РєР»С–С”РЅС‚Сѓ, СЃРєР»Р°Рґ СЃРїРёСЃР°РЅРѕ РґРѕРєСѓРјРµРЅС‚РѕРј РїРѕ FIFO.');
    setNotice(`РџСЂРѕРґР°Р¶ ${sale.id} РІРёРґР°РЅРѕ С– Р·Р°РєСЂРёС‚Рѕ. РЎРёСЃС‚РµРјР° СЃРїРёСЃР°Р»Р° С‚РѕРІР°СЂ РїРѕ РїР°СЂС‚С–СЏС… FIFO.`);
  }

  function cancelSale(sale: Sale) {
    sale.items.forEach((item) => {
      if (item.status === 'Р—Р°СЂРµР·РµСЂРІРѕРІР°РЅРѕ') {
        patchProduct(item.productId, (product) => ({ ...product, reserved: Math.max(product.reserved - item.qty, 0) }));
        addMovement({ type: 'Р—РЅСЏС‚С‚СЏ СЂРµР·РµСЂРІСѓ', productId: item.productId, qty: item.qty, orderId: sale.id, comment: 'РџСЂРѕРґР°Р¶ СЃРєР°СЃРѕРІР°РЅРѕ РґРѕ РІРёРґР°С‡С–.' });
      }
    });
    patchSale(sale.id, (item) => ({ ...item, status: 'РЎРєР°СЃРѕРІР°РЅРѕ', items: item.items.map((line) => ({ ...line, status: 'РЎРєР°СЃРѕРІР°РЅРѕ' as const })) }));
    logAction('РЎРєР°СЃСѓРІР°РЅРЅСЏ РїСЂРѕРґР°Р¶Сѓ', sale.id, 'РџСЂРѕРґР°Р¶ СЃРєР°СЃРѕРІР°РЅРѕ РґРѕ РІРёРґР°С‡С–, СЂРµР·РµСЂРІ Р·РЅСЏС‚Рѕ.');
    setNotice(`РџСЂРѕРґР°Р¶ ${sale.id} СЃРєР°СЃРѕРІР°РЅРѕ, СЂРµР·РµСЂРІ Р·РЅСЏС‚Рѕ.`);
  }

  function returnSale(sale: Sale) {
    const issued = sale.items.find((item) => item.status === 'Р’РёРґР°РЅРѕ');
    if (!issued) {
      setNotice('РџРѕРІРµСЂРЅРµРЅРЅСЏ РјРѕР¶Р»РёРІРµ С‚С–Р»СЊРєРё РїС–СЃР»СЏ РІРёРґР°С‡С– С‚РѕРІР°СЂСѓ.');
      return;
    }
    const refund = Math.max(issued.price * issued.qty - issued.discount, 0);
    setProducts((current) => current.map((product) => {
      if (product.id !== issued.productId) return product;
      return {
        ...product,
        stock: product.stock + issued.qty,
        batches: issued.batchAllocations ? restoreBatchAllocations(product, issued.batchAllocations) : product.batches,
      };
    }));
    addMovement({
      type: 'РџРѕРІРµСЂРЅРµРЅРЅСЏ',
      productId: issued.productId,
      qty: issued.qty,
      orderId: sale.id,
      comment: issued.batchAllocations?.length ? `РџРѕРІРµСЂРЅРµРЅРЅСЏ С‚РѕРІР°СЂСѓ РєР»С–С”РЅС‚РѕРј, С‚РѕРІР°СЂ РїРѕРІРµСЂРЅРµРЅРѕ РЅР° СЃРєР»Р°Рґ Сѓ РїР°СЂС‚С–С—: ${issued.batchAllocations.map((batch) => batch.batchId).join(', ')}.` : 'РџРѕРІРµСЂРЅРµРЅРЅСЏ С‚РѕРІР°СЂСѓ РєР»С–С”РЅС‚РѕРј, С‚РѕРІР°СЂ РїРѕРІРµСЂРЅРµРЅРѕ РЅР° СЃРєР»Р°Рґ.',
    });
    patchSale(sale.id, (item) => ({
      ...item,
      status: 'РџРѕРІРµСЂРЅРµРЅРЅСЏ',
      items: item.items.map((line) => (line.id === issued.id ? { ...line, status: 'РџРѕРІРµСЂРЅРµРЅРЅСЏ' as const } : line)),
      returns: [...item.returns, { id: uid('RET'), saleId: sale.id, productId: issued.productId, qty: issued.qty, reason: 'РџРѕРІРµСЂРЅРµРЅРЅСЏ РєР»С–С”РЅС‚РѕРј', refund, destination: 'РќР° СЃРєР»Р°Рґ' }],
      payments: [...item.payments, { id: uid('PAY'), date: today, amount: -refund, method: 'Р“РѕС‚С–РІРєР°', type: 'РџРѕРІРµСЂРЅРµРЅРЅСЏ РєРѕС€С‚С–РІ', transactionNo: uid('REF'), acceptedBy: activeUser.name, saleId: sale.id, comment: 'РџРѕРІРµСЂРЅРµРЅРЅСЏ РєРѕС€С‚С–РІ РєР»С–С”РЅС‚Сѓ' }],
    }));
    registerCashPayment(refund, 'Р“РѕС‚С–РІРєР°', true);
    logAction('РџРѕРІРµСЂРЅРµРЅРЅСЏ РїСЂРѕРґР°Р¶Сѓ', sale.id, `${productName(issued.productId)}: ${issued.qty} С€С‚., РїРѕРІРµСЂРЅРµРЅРЅСЏ РєРѕС€С‚С–РІ ${money(refund)}.`);
    setNotice(`РћС„РѕСЂРјР»РµРЅРѕ РїРѕРІРµСЂРЅРµРЅРЅСЏ Р·Р° ${sale.id}. РџРѕРІРµСЂРЅРµРЅРЅСЏ РєРѕС€С‚С–РІ: ${money(refund)}.`);
  }

  const managerStatusOptions: OrderStatus[] = ['Р“РѕС‚РѕРІРёР№ РґРѕ РІРёРґР°С‡С–', 'РћС‡С–РєСѓС” РѕРїР»Р°С‚Рё', 'РћС‡С–РєСѓС” РєР»С–С”РЅС‚Р°', 'РќРµ РїС–РґР»СЏРіР°С” СЂРµРјРѕРЅС‚Сѓ'];
  return (
    <div className="app-shell">
      <aside className={`sidebar ${showMenu ? 'sidebar-open' : ''}`}>
        <div className="brand">
          <div className="brand-mark">РЎРђ</div>
          <div>
            <strong>РЎРџР•РљРўР -РђРЎ</strong>
            <span>Р„Р”Р РџРћРЈ 22590485</span>
          </div>
        </div>
        <nav className="navigation" aria-label="РћСЃРЅРѕРІРЅР° РЅР°РІС–РіР°С†С–СЏ">
          {visibleNavItems.map((item) => (
            <button
              key={item.id}
              className={page === item.id ? 'nav-item nav-item-active' : 'nav-item'}
              onClick={() => {
                setPage(item.id);
                setShowMenu(false);
              }}
            >
              {item.icon}
              {item.label}
            </button>
          ))}
        </nav>
        <div className="role-card">
          <span>РџРѕС‚РѕС‡РЅРёР№ РєРѕСЂРёСЃС‚СѓРІР°С‡</span>
          <strong>{activeUser.name}</strong>
          <small>{activeUser.role} В· СЃРµСЃС–СЏ {activeUser.session}</small>
        </div>
        <div className="support-card">
          <img src="https://images.unsplash.com/photo-1581092160607-ee22621dd758?auto=format&fit=crop&w=600&q=80" alt="Р†РЅР¶РµРЅРµСЂ РїРµСЂРµРІС–СЂСЏС” РѕР±Р»Р°РґРЅР°РЅРЅСЏ" />
          <strong>Р›РѕРіС–РєР° Р±РµР· РїРѕРјРёР»РѕРє</strong>
          <span>Р РµР·РµСЂРІ, Р·Р°РєСѓРїС–РІР»СЏ, РїСЂРёС…С–Рґ С– СЃРїРёСЃР°РЅРЅСЏ РїСЂРѕС…РѕРґСЏС‚СЊ С‚С–Р»СЊРєРё С‡РµСЂРµР· РґРѕРєСѓРјРµРЅС‚Рё.</span>
        </div>
      </aside>

      <main className="workspace">
        <header className="topbar">
          <button className="icon-button mobile-only" onClick={() => setShowMenu(!showMenu)} aria-label="Р’С–РґРєСЂРёС‚Рё РјРµРЅСЋ">
            {showMenu ? <X size={20} /> : <Menu size={20} />}
          </button>
          <div className="search-box">
            <Search size={18} />
            <input value={query} onChange={(event) => setQuery(event.target.value)} placeholder="РџРѕС€СѓРє Р·Р° РЅРѕРјРµСЂРѕРј, РєР»С–С”РЅС‚РѕРј, С‚РµР»РµС„РѕРЅРѕРј, СЃРµСЂС–Р№РЅРёРј РЅРѕРјРµСЂРѕРј Р°Р±Рѕ РїСЂРёСЃС‚СЂРѕС”Рј" />
          </div>
          {visibleInternalMessages.length > 0 && (
            <button className="icon-button notification-button" aria-label="Р¦РµРЅС‚СЂ РїРѕРІС–РґРѕРјР»РµРЅСЊ" onClick={() => setPage('dashboard')}>
              <Bell size={19} />
              {unreadInternalMessages > 0 && <span>{unreadInternalMessages}</span>}
            </button>
          )}
          <div className="current-user-badge">
            <strong>{activeUser.role} вЂ” {activeUser.name}</strong>
            <span>{activeUser.role === 'Р СѓРєРѕРІРѕРґРёС‚РµР»СЊ' ? 'СЂРµР¶РёРј РєРѕРЅС‚СЂРѕР»СЋ РєРµСЂС–РІРЅРёРєР°' : 'РїРµСЂРµРјРёРєР°РЅРЅСЏ СЂРѕР»РµР№ РїСЂРёС…РѕРІР°РЅРѕ'}</span>
          </div>
          {isOwnerControlView && (
            <button
              className="return-owner-button"
              type="button"
              onClick={() => {
                setActiveUserId(currentUser.id);
                setPage('dashboard');
                setActionLogs((current) => [{ id: uid('LOG'), date: today, user: currentUser.name, role: currentUser.role, action: 'РџРѕРІРµСЂРЅРµРЅРЅСЏ РґРѕ РєРµСЂС–РІРЅРёРєР°', entity: 'Р РѕР±РѕС‡РёР№ СЃС‚С–Р»', comment: 'РљРµСЂС–РІРЅРёРє РїРѕРІРµСЂРЅСѓРІСЃСЏ Р·С– СЃР»СѓР¶Р±РѕРІРѕРіРѕ РїРµСЂРµРіР»СЏРґСѓ СЂРѕР»С–.' }, ...current]);
              }}
            >
              Р”Рѕ РєРµСЂС–РІРЅРёРєР°
            </button>
          )}
          {canSwitchUsers && (
            <select
              className="role-select"
              value={activeUserId}
              onChange={(event) => {
                const nextUser = users.find((user) => user.id === event.target.value) ?? currentUser;
                setActiveUserId(nextUser.id);
                setPage(defaultPageForRole(nextUser.role));
                setActionLogs((current) => [{ id: uid('LOG'), date: today, user: currentUser.name, role: currentUser.role, action: 'РљРѕРЅС‚СЂРѕР»СЊ СЂРѕР»С–', entity: 'Р РѕР±РѕС‡РёР№ СЃС‚С–Р»', comment: `РљРµСЂС–РІРЅРёРє РІС–РґРєСЂРёРІ СЂРѕР±РѕС‡РёР№ СЃС‚С–Р» СЂРѕР»С– ${nextUser.role}: ${nextUser.name}.` }, ...current]);
              }}
              aria-label="РџРµСЂРµРјРёРєР°РЅРЅСЏ СЂРѕР»С– РґР»СЏ РєРѕРЅС‚СЂРѕР»СЋ РєРµСЂС–РІРЅРёРєРѕРј"
            >
              {users.map((user) => <option key={user.id} value={user.id}>{user.name} В· {user.role}</option>)}
            </select>
          )}
        </header>

        {notice && <div className="notice">{notice}</div>}

        <MessageFeed
          messages={visibleInternalMessages}
          activeUser={activeUser}
          users={users}
          orders={orders}
          onSend={sendInternalMessage}
          onStatus={updateInternalMessageStatus}
        />

        {!canViewPage(page) && <AccessDenied activeUser={activeUser} page={page} />}
        {canViewPage(page) && page === 'dashboard' && (
          <Dashboard
            analytics={analytics}
            orders={orders}
            sales={sales}
            products={products}
            documents={documents}
            actionLogs={actionLogs}
            requirements={requirements}
            purchases={purchases}
            taxInvoices={initialTaxInvoices}
            setPage={setPage}
            activeUser={activeUser}
            users={users}
            quickPhone={quickPhone}
            quickClientName={quickClientName}
            quickDevice={quickDevice}
            quickProblem={quickProblem}
            quickEngineerId={quickEngineerId}
            customerList={customerList}
            setQuickPhone={handleQuickPhoneChange}
            setQuickClientName={setQuickClientName}
            setQuickDevice={setQuickDevice}
            setQuickProblem={setQuickProblem}
            setQuickEngineerId={setQuickEngineerId}
            createQuickOrder={createQuickOrder}
            setSelectedOrderId={setSelectedOrderId}
          />
        )}
        {canViewPage(page) && page === 'sales' && (
          <SalesPage
            sales={sales}
            selectedSale={selectedSale}
            products={products}
            selectedSaleId={selectedSaleId}
            setSelectedSaleId={setSelectedSaleId}
            selectedSaleProductId={selectedSaleProductId}
            setSelectedSaleProductId={setSelectedSaleProductId}
            saleQty={saleQty}
            setSaleQty={setSaleQty}
            addSaleItem={addSaleItem}
            reserveSale={reserveSale}
            acceptSalePayment={acceptSalePayment}
            issueSale={issueSale}
            returnSale={returnSale}
            cancelSale={cancelSale}
            printDocument={printDocument}
            canDo={canDo}
            showCost={canDo('cost.view')}
            showProfit={canDo('profit.view')}
          />
        )}
        {canViewPage(page) && page === 'orders' && (
          <OrdersPage
            orders={filteredOrders}
            selectedOrder={selectedOrder}
            products={products}
            selectedOrderId={selectedOrderId}
            setSelectedOrderId={setSelectedOrderId}
            selectedProductId={selectedProductId}
            setSelectedProductId={setSelectedProductId}
            qty={qty}
            setQty={setQty}
            addPartToRepair={addPartToRepair}
            orderPart={orderPart}
            reserveArrived={reserveArrived}
            issueToEngineer={issueToEngineer}
            markInstalled={markInstalled}
            returnServicePart={returnServicePart}
            addOrderPayment={addOrderPayment}
            changeOrderStatus={changeOrderStatus}
            acceptOrderWork={acceptOrderWork}
            reassignEngineer={reassignEngineer}
            closeOrder={closeOrder}
            issueReadyOrder={issueReadyOrder}
            transferOrderToBas={transferOrderToBas}
            printDocument={printDocument}
            documents={documents}
            notifications={clientNotifications.filter((item) => item.orderId === selectedOrder.id)}
            sendClientNotification={enqueueClientNotification}
            approval={repairApprovals.find((item) => item.orderId === selectedOrder.id)}
            sendRepairApproval={sendRepairApproval}
            recordApprovalResponse={recordApprovalResponse}
            markApprovalNoAnswer={markApprovalNoAnswer}
            canDo={canDo}
            showCost={canDo('cost.view')}
            activeUser={activeUser}
          />
        )}
        {canViewPage(page) && page === 'my-orders' && (
          <OrdersPage
            orders={visibleOrders}
            allRoleOrders={engineerOwnOrders}
            selectedOrder={selectedOrder}
            products={products}
            selectedOrderId={selectedOrder.id}
            setSelectedOrderId={setSelectedOrderId}
            selectedProductId={selectedProductId}
            setSelectedProductId={setSelectedProductId}
            qty={qty}
            setQty={setQty}
            addPartToRepair={addPartToRepair}
            orderPart={orderPart}
            reserveArrived={reserveArrived}
            issueToEngineer={issueToEngineer}
            markInstalled={markInstalled}
            returnServicePart={returnServicePart}
            addOrderPayment={addOrderPayment}
            issueReadyOrder={issueReadyOrder}
            transferOrderToBas={transferOrderToBas}
            closeOrder={closeOrder}
            printDocument={printDocument}
            documents={documents}
            notifications={clientNotifications.filter((item) => item.orderId === selectedOrder.id)}
            sendClientNotification={enqueueClientNotification}
            approval={repairApprovals.find((item) => item.orderId === selectedOrder.id)}
            sendRepairApproval={sendRepairApproval}
            recordApprovalResponse={recordApprovalResponse}
            markApprovalNoAnswer={markApprovalNoAnswer}
            canDo={canDo}
            showCost={canDo('cost.view')}
            activeUser={activeUser}
            acceptOrderWork={acceptOrderWork}
            changeOrderStatus={changeOrderStatus}
            reassignEngineer={reassignEngineer}
          />
        )}
        {canViewPage(page) && page === 'parts' && <PartsPage products={products} requirements={requirements} productName={productName} showCost={canDo('cost.view')} />}
        {canViewPage(page) && page === 'purchases' && <PurchasesPage purchases={purchases} receipts={receipts} productName={productName} movePurchase={movePurchase} receivePurchase={receivePurchase} printDocument={printDocument} canDo={canDo} />}
        {canViewPage(page) && page === 'cash' && <CashPage orders={orders} sales={sales} cashShift={cashShift} activeUser={activeUser} confirmBankPayment={confirmBankPayment} />}
        {canViewPage(page) && page === 'returns' && <ReturnsPage sales={sales} orders={orders} products={products} productName={productName} />}
        {canViewPage(page) && page === 'documents' && <DocumentsPage documents={documents} templates={documentTemplates} />}
        {canViewPage(page) && page === 'tax-invoices' && <TaxInvoicesPage invoices={initialTaxInvoices} orders={orders} />}
        {canViewPage(page) && page === 'bas-exchange' && <BasExchangePage items={basExchangeItems} mappings={basMappings} actionLogs={actionLogs} />}
        {canViewPage(page) && page === 'problem-clients' && <ProblemClientsPage orders={orders} documents={documents} setPage={setPage} setSelectedOrderId={setSelectedOrderId} />}
        {canViewPage(page) && page === 'order-units' && <OrderUnitsPage units={initialOrderUnits} activeUser={activeUser} />}
        {canViewPage(page) && page === 'storage' && <StoragePage units={initialOrderUnits} cells={storageCells} />}
        {canViewPage(page) && page === 'movements' && <MovementsPage movements={movements} productName={productName} />}
        {canViewPage(page) && page === 'clients' && <ClientsPage clients={customerList} />}
        {canViewPage(page) && page === 'finance' && <FinancePage orders={orders} products={products} sales={sales} analytics={analytics} cashShift={cashShift} canDo={canDo} />}
        {canViewPage(page) && page === 'reports' && <ReportsPage orders={orders} sales={sales} movements={movements} products={products} actionLogs={actionLogs} cashShift={cashShift} canDo={canDo} />}
        {canViewPage(page) && page === 'payroll' && <PayrollPage orders={orders} activeUser={activeUser} />}
        {canViewPage(page) && page === 'acceptance' && <AcceptanceChecklistPage />}
        {canViewPage(page) && page === 'team' && <TeamPage />}
        {canViewPage(page) && page === 'settings' && <SettingsPage actionLogs={actionLogs} activeUser={activeUser} />}
      </main>
    </div>
  );
}

function PageTitle({ eyebrow, title, text }: { eyebrow: string; title: string; text: string }) {
  return (
    <section className="page-title">
      <span>{eyebrow}</span>
      <h1>{title}</h1>
      <p>{text}</p>
    </section>
  );
}

function AccessDenied({ activeUser, page }: { activeUser: User; page: Page }) {
  const pageName = navItems.find((item) => item.id === page)?.label ?? page;
  return (
    <div className="page-grid">
      <PageTitle eyebrow="Р”РѕСЃС‚СѓРї РѕР±РјРµР¶РµРЅРѕ" title="Р¦РµР№ СЂРѕР·РґС–Р» РїСЂРёС…РѕРІР°РЅРѕ РґР»СЏ СЂРѕР»С–" text={`РљРѕСЂРёСЃС‚СѓРІР°С‡ ${activeUser.name} РјР°С” СЂРѕР»СЊ ${activeUser.role}. Р РѕР·РґС–Р» "${pageName}" РЅРµ РІС…РѕРґРёС‚СЊ Сѓ РјС–РЅС–РјР°Р»СЊРЅРѕ РЅРµРѕР±С…С–РґРЅРёР№ РґРѕСЃС‚СѓРї РґР»СЏ С†С–С”С— СЂРѕР»С–.`} />
      <section className="panel">
        <div className="task-list">
          <Task icon={<ShieldCheck />} title="РџСЂРёРЅС†РёРї Р±РµР·РїРµРєРё" text="РЎРїС–РІСЂРѕР±С–С‚РЅРёРє Р±Р°С‡РёС‚СЊ С‚С–Р»СЊРєРё С‚С– РјРѕРґСѓР»С– Р№ РґС–С—, СЏРєС– РїРѕС‚СЂС–Р±РЅС– РґР»СЏ Р№РѕРіРѕ СЂРѕР±РѕС‚Рё." />
          <Task icon={<History />} title="Р–СѓСЂРЅР°Р»" text="РЎРїСЂРѕР±Рё Р·РјС–РЅРё СЂРѕР»С– С‚Р° РєСЂРёС‚РёС‡РЅС– РґС–С— С„С–РєСЃСѓСЋС‚СЊСЃСЏ РІ Р¶СѓСЂРЅР°Р»С–." />
        </div>
      </section>
    </div>
  );
}

function MessageFeed({
  messages,
  activeUser,
  users,
  orders,
  onSend,
  onStatus,
}: {
  messages: InternalMessage[];
  activeUser: User;
  users: User[];
  orders: ServiceOrder[];
  onSend: (toUserId: string, orderId: string, text: string, dueAt: string, importance: InternalMessageImportance) => void;
  onStatus: (messageId: string, status: InternalMessageStatus) => void;
}) {
  const [toUserId, setToUserId] = useState(users.find((user) => user.role === 'РњРµРЅРµРґР¶РµСЂ')?.id ?? users[0].id);
  const [orderId, setOrderId] = useState(orders[0]?.id ?? '');
  const [text, setText] = useState('');
  const [dueAt, setDueAt] = useState('20.04.2026 18:00');
  const [importance, setImportance] = useState<InternalMessageImportance>('Р’Р°Р¶Р»РёРІР°');

  if (messages.length === 0) return null;

  return (
    <section className="message-feed" aria-label="Р’РЅСѓС‚СЂС–С€РЅС– РїРѕРІС–РґРѕРјР»РµРЅРЅСЏ">
      <div className="message-feed-head">
        <div>
          <span>{activeUser.role === 'Р СѓРєРѕРІРѕРґРёС‚РµР»СЊ' ? 'Р¦РµРЅС‚СЂ РїРѕРІС–РґРѕРјР»РµРЅСЊ' : 'РњРѕС— Р·Р°РґР°С‡С–'}</span>
          <h2>{activeUser.role === 'Р СѓРєРѕРІРѕРґРёС‚РµР»СЊ' ? 'РђРґСЂРµСЃРЅС– РїРѕРІС–РґРѕРјР»РµРЅРЅСЏ РєРѕРјР°РЅРґРё' : 'РђРґСЂРµСЃРЅС– РїРѕРІС–РґРѕРјР»РµРЅРЅСЏ РґР»СЏ РјРµРЅРµ'}</h2>
        </div>
        <strong>{messages.filter((message) => message.status === 'РќРѕРІРµ').length} РЅРѕРІРёС…</strong>
      </div>

      {activeUser.role === 'Р СѓРєРѕРІРѕРґРёС‚РµР»СЊ' && (
        <form
          className="message-feed-form"
          onSubmit={(event) => {
            event.preventDefault();
            onSend(toUserId, orderId, text, dueAt, importance);
            setText('');
          }}
        >
          <select value={toUserId} onChange={(event) => setToUserId(event.target.value)} aria-label="РљРѕРјСѓ">
            {users.filter((user) => user.role !== 'Р СѓРєРѕРІРѕРґРёС‚РµР»СЊ').map((user) => <option key={user.id} value={user.id}>{user.role} вЂ” {user.name}</option>)}
          </select>
          <select value={orderId} onChange={(event) => setOrderId(event.target.value)} aria-label="Р—Р°РјРѕРІР»РµРЅРЅСЏ">
            <option value="">Р‘РµР· Р·Р°РјРѕРІР»РµРЅРЅСЏ</option>
            {orders.map((order) => <option key={order.id} value={order.id}>{order.id} вЂ” {order.client}</option>)}
          </select>
          <select value={importance} onChange={(event) => setImportance(event.target.value as InternalMessageImportance)} aria-label="Р’Р°Р¶Р»РёРІС–СЃС‚СЊ">
            <option value="Р—РІРёС‡Р°Р№РЅР°">Р—РІРёС‡Р°Р№РЅР°</option>
            <option value="Р’Р°Р¶Р»РёРІР°">Р’Р°Р¶Р»РёРІР°</option>
            <option value="РљСЂРёС‚РёС‡РЅР°">РљСЂРёС‚РёС‡РЅР°</option>
          </select>
          <input value={dueAt} onChange={(event) => setDueAt(event.target.value)} aria-label="РЎС‚СЂРѕРє" placeholder="РЎС‚СЂРѕРє" />
          <textarea value={text} onChange={(event) => setText(event.target.value)} placeholder="РўРµРєСЃС‚ Р·Р°РґР°С‡С– Р°Р±Рѕ РїРѕРІС–РґРѕРјР»РµРЅРЅСЏ" />
          <button type="submit" className="submit-button">РќР°РґС–СЃР»Р°С‚Рё</button>
        </form>
      )}

      <div className="message-feed-list">
        {messages.slice(0, 5).map((message) => (
          <article className={`message-item importance-${message.importance.toLowerCase()}`} key={message.id}>
            <div>
              <strong>{message.toRole} вЂ” {message.toUser}</strong>
              <p>{message.text}</p>
              <span>{message.orderId ? `Р—Р°РјРѕРІР»РµРЅРЅСЏ: ${message.orderId}. ` : ''}РЎС‚СЂРѕРє: {message.dueAt}. Р’С–Рґ: {message.createdBy}</span>
            </div>
            <div className="message-item-actions">
              <span className={`status-pill ${message.status === 'РќРѕРІРµ' ? 'danger' : message.status === 'Р’РёРєРѕРЅР°РЅРѕ' ? 'good' : ''}`}>{message.status}</span>
              <span>{message.importance}</span>
              {message.status === 'РќРѕРІРµ' && <button type="button" onClick={() => onStatus(message.id, 'РџСЂРѕС‡РёС‚Р°РЅРѕ')}>РџСЂРѕС‡РёС‚Р°РЅРѕ</button>}
              {message.status !== 'Р’РёРєРѕРЅР°РЅРѕ' && <button type="button" onClick={() => onStatus(message.id, 'Р’РёРєРѕРЅР°РЅРѕ')}>Р’РёРєРѕРЅР°РЅРѕ</button>}
            </div>
          </article>
        ))}
      </div>
    </section>
  );
}

function QuickOrderIntake({
  phone,
  clientName,
  device,
  problem,
  engineerId,
  users,
  customerList,
  onPhoneChange,
  onClientNameChange,
  onDeviceChange,
  onProblemChange,
  onEngineerChange,
  onSubmit,
}: {
  phone: string;
  clientName: string;
  device: string;
  problem: string;
  engineerId: string;
  users: User[];
  customerList: Array<{ name: string; phone: string; orders: number }>;
  onPhoneChange: (phone: string) => void;
  onClientNameChange: (name: string) => void;
  onDeviceChange: (device: string) => void;
  onProblemChange: (problem: string) => void;
  onEngineerChange: (id: string) => void;
  onSubmit: () => void;
}) {
  const normalized = phone.replace(/\D/g, '');
  const foundClient = normalized.length >= 7
    ? customerList.find((client) => client.phone.replace(/\D/g, '').includes(normalized) || normalized.includes(client.phone.replace(/\D/g, '')))
    : undefined;
  const engineers = users.filter((user) => user.role === 'Р†РЅР¶РµРЅРµСЂ');

  return (
    <section className="quick-intake-panel">
      <div className="panel-heading">
        <div>
          <h2>РЁРІРёРґРєРёР№ РїСЂРёР№РѕРј Р·Р°РєР°Р·Р°</h2>
          <span>30-60 СЃРµРєСѓРЅРґ Р±РµР· РїРµСЂРµС…РѕРґС–РІ</span>
        </div>
        <strong>{foundClient ? `РљР»С–С”РЅС‚Р° Р·РЅР°Р№РґРµРЅРѕ: ${foundClient.orders} Р·РІРµСЂРЅРµРЅСЊ` : 'РќРѕРІРёР№ РєР»С–С”РЅС‚ СЃС‚РІРѕСЂРёС‚СЊСЃСЏ Р°РІС‚РѕРјР°С‚РёС‡РЅРѕ'}</strong>
      </div>
      <form
        className="quick-intake-form"
        onSubmit={(event) => {
          event.preventDefault();
          onSubmit();
        }}
      >
        <label>
          РџРѕС€СѓРє РїРѕ С‚РµР»РµС„РѕРЅСѓ
          <input value={phone} onChange={(event) => onPhoneChange(event.target.value)} placeholder="+380..." />
        </label>
        <label>
          Р†РјКјСЏ РєР»С–С”РЅС‚Р°
          <input value={clientName} onChange={(event) => onClientNameChange(event.target.value)} placeholder="РџР†Р‘ Р°Р±Рѕ РЅР°Р·РІР° РєРѕРјРїР°РЅС–С—" />
        </label>
        <label>
          РџСЂРёСЃС‚СЂС–Р№
          <input value={device} onChange={(event) => onDeviceChange(event.target.value)} placeholder="РќРѕСѓС‚Р±СѓРє Lenovo, РњР¤РЈ Canon..." />
        </label>
        <label>
          РџСЂРѕР±Р»РµРјР°
          <input value={problem} onChange={(event) => onProblemChange(event.target.value)} placeholder="РќРµ РІРјРёРєР°С”С‚СЊСЃСЏ, РЅРµ РґСЂСѓРєСѓС”..." />
        </label>
        <label>
          Р†РЅР¶РµРЅРµСЂ
          <select value={engineerId} onChange={(event) => onEngineerChange(event.target.value)}>
            {engineers.map((engineer) => <option key={engineer.id} value={engineer.id}>{engineer.name}</option>)}
          </select>
        </label>
        <button className="submit-button" type="submit">РџСЂРёР№РЅСЏС‚Рё Р·Р°РјРѕРІР»РµРЅРЅСЏ</button>
      </form>
    </section>
  );
}

function Dashboard({
  analytics,
  orders,
  sales,
  products,
  documents,
  actionLogs,
  requirements,
  purchases,
  taxInvoices,
  setPage,
  activeUser,
  users,
  quickPhone,
  quickClientName,
  quickDevice,
  quickProblem,
  quickEngineerId,
  customerList,
  setQuickPhone,
  setQuickClientName,
  setQuickDevice,
  setQuickProblem,
  setQuickEngineerId,
  createQuickOrder,
  setSelectedOrderId,
}: {
  analytics: { stockValue: number; partsInRepairs: number; ordered: number; required: number; salesRevenue?: number; salesDebt?: number; serviceDebt?: number; salesProfit?: number; serviceProfit?: number };
  orders: ServiceOrder[];
  sales: Sale[];
  products: Product[];
  documents: PrintDocument[];
  actionLogs: ActionLog[];
  requirements: PartRequirement[];
  purchases: PurchaseOrder[];
  taxInvoices: TaxInvoice[];
  setPage: (page: Page) => void;
  activeUser: User;
  users: User[];
  quickPhone: string;
  quickClientName: string;
  quickDevice: string;
  quickProblem: string;
  quickEngineerId: string;
  customerList: Array<{ name: string; phone: string; orders: number }>;
  setQuickPhone: (phone: string) => void;
  setQuickClientName: (name: string) => void;
  setQuickDevice: (device: string) => void;
  setQuickProblem: (problem: string) => void;
  setQuickEngineerId: (id: string) => void;
  createQuickOrder: () => void;
  setSelectedOrderId: (id: string) => void;
}) {
  const newOrders = orders.filter((order) => order.status === 'РџСЂРёР№РЅСЏС‚Рѕ').length;
  const diagnostics = orders.filter((order) => order.status === 'РќР° РґС–Р°РіРЅРѕСЃС‚РёС†С–').length;
  const waitingParts = orders.filter((order) => order.status === 'РћС‡С–РєСѓС” Р·Р°РїС‡Р°СЃС‚РёРЅСѓ').length;
  const inRepair = orders.filter((order) => order.status === 'Р’ СЂРµРјРѕРЅС‚С–').length;
  const ready = orders.filter((order) => ['Р“РѕС‚РѕРІРёР№ РґРѕ РІРёРґР°С‡С–', 'РќРµ РїС–РґР»СЏРіР°С” СЂРµРјРѕРЅС‚Сѓ'].includes(order.status)).length;
  const issuedToday = orders.filter((order) => order.status === 'Р’РёРґР°РЅРѕ').length;
  const stuckOrders = orders.filter((order) => daysSince(order.statusChangedAt) > 2);
  const minStock = products.filter((product) => available(product) <= product.min);
  const salesToday = sales.reduce((sum, sale) => sum + saleTotals(sale).paid, 0);
  const serviceRevenue = orders.reduce((sum, order) => sum + orderTotals(order).paid, 0);
  const monthRevenue = salesToday + serviceRevenue;
  const monthProfit = (analytics.salesProfit ?? 0) + (analytics.serviceProfit ?? 0);
  const debt = (analytics.salesDebt ?? 0) + (analytics.serviceDebt ?? 0);
  const activeRepairs = orders.filter((order) => !['Р—Р°РєСЂРёС‚Рѕ', 'РЎРєР°СЃРѕРІР°РЅРѕ', 'Р’РёРґР°РЅРѕ', 'РќРµ РїС–РґР»СЏРіР°С” СЂРµРјРѕРЅС‚Сѓ'].includes(order.status)).length;
  const averageCheck = sales.length + orders.length > 0 ? Math.round(monthRevenue / (sales.length + orders.length)) : 0;
  const returnsAmount = sales.reduce((sum, sale) => sum + sale.returns.reduce((inner, item) => inner + item.refund, 0), 0);
  const writeOffs = products.reduce((sum, product) => sum + product.installed * product.cost, 0);
  const overdueOrders = orders.filter((order) => daysSince(order.promisedDate) > 0 && !['Р—Р°РєСЂРёС‚Рѕ', 'Р’РёРґР°РЅРѕ', 'РЎРєР°СЃРѕРІР°РЅРѕ'].includes(order.status));
  const problemOrders = [...stuckOrders, ...overdueOrders, ...orders.filter((order) => order.status === 'РћС‡С–РєСѓС” Р·Р°РїС‡Р°СЃС‚РёРЅСѓ' && daysSince(order.statusChangedAt) > 2)].filter((order, index, list) => list.findIndex((item) => item.id === order.id) === index);
  const statusBars = [
    { label: 'Р”С–Р°РіРЅРѕСЃС‚РёРєР°', value: diagnostics },
    { label: 'Р РµРјРѕРЅС‚', value: inRepair },
    { label: 'Р—Р°РїС‡Р°СЃС‚РёРЅР°', value: waitingParts },
    { label: 'Р“РѕС‚РѕРІРѕ', value: ready },
    { label: 'РџСЂРѕСЃСЂРѕС‡РµРЅС–', value: overdueOrders.length },
  ];
  const revenueBars = [
    { label: 'Р РµРјРѕРЅС‚', value: serviceRevenue },
    { label: 'РџСЂРѕРґР°Р¶С–', value: analytics.salesRevenue ?? 0 },
    { label: 'Р‘РѕСЂРіРё', value: debt },
    { label: 'РџРѕРІРµСЂРЅРµРЅРЅСЏ', value: returnsAmount },
  ];
  const managerRows = users.filter((user) => ['РњРµРЅРµРґР¶РµСЂ', 'РђРґРјС–РЅС–СЃС‚СЂР°С‚РѕСЂ'].includes(user.role)).map((user) => {
    const managerOrders = orders.filter((order) => order.manager === user.name);
    const managerSales = sales.filter((sale) => sale.manager === user.name);
    const revenue = managerSales.reduce((sum, sale) => sum + saleTotals(sale).paid, 0) + managerOrders.reduce((sum, order) => sum + orderTotals(order).paid, 0);
    const closed = managerOrders.filter((order) => ['Р—Р°РєСЂРёС‚Рѕ', 'Р’РёРґР°РЅРѕ'].includes(order.status)).length;
    const paymentsCount = managerOrders.reduce((sum, order) => sum + order.payments.length, 0) + managerSales.reduce((sum, sale) => sum + sale.payments.length, 0);
    const documentsCount = managerOrders.filter((order) => order.legalEntity && order.actIssuedAt && !order.actReturnedAt).length;
    const managerDebt = managerOrders.reduce((sum, order) => sum + orderTotals(order).debt, 0) + managerSales.reduce((sum, sale) => sum + saleTotals(sale).debt, 0);
    const avg = managerOrders.length + managerSales.length ? Math.round(revenue / (managerOrders.length + managerSales.length)) : 0;
    return { name: user.name, orders: managerOrders.length, closed, sales: managerSales.length, revenue, paymentsCount, avg, debt: managerDebt, documentsCount };
  }).filter((row) => row.orders || row.sales);
  const engineerRows = users.filter((user) => user.role === 'Р†РЅР¶РµРЅРµСЂ').map((user) => {
    const engineerOrders = orders.filter((order) => order.engineer === user.name);
    const finished = engineerOrders.filter((order) => ['Р“РѕС‚РѕРІРёР№ РґРѕ РІРёРґР°С‡С–', 'РќРµ РїС–РґР»СЏРіР°С” СЂРµРјРѕРЅС‚Сѓ', 'Р’РёРґР°РЅРѕ', 'Р—Р°РєСЂРёС‚Рѕ'].includes(order.status)).length;
    const avgDays = engineerOrders.length ? Math.round(engineerOrders.reduce((sum, order) => sum + daysSince(order.intakeDate), 0) / engineerOrders.length) : 0;
    const stuck = engineerOrders.filter((order) => daysSince(order.statusChangedAt) > 2 && !['Р—Р°РєСЂРёС‚Рѕ', 'Р’РёРґР°РЅРѕ', 'РЎРєР°СЃРѕРІР°РЅРѕ'].includes(order.status)).length;
    const repeated = engineerOrders.filter((order) => order.clientComment?.toLowerCase().includes('РїРѕРІС‚РѕСЂ')).length;
    const earning = engineerOrders.reduce((sum, order) => sum + order.works.reduce((inner, work) => inner + payrollForWork(order, work, payrollRules.find((rule) => rule.employee === (work.engineer ?? order.engineer))), 0), 0);
    const companyProfit = engineerOrders.reduce((sum, order) => sum + orderTotals(order).finalProfit, 0);
    return { name: user.name, orders: engineerOrders.length, active: engineerOrders.filter((order) => !['Р—Р°РєСЂРёС‚Рѕ', 'Р’РёРґР°РЅРѕ', 'РЎРєР°СЃРѕРІР°РЅРѕ', 'РќРµ РїС–РґР»СЏРіР°С” СЂРµРјРѕРЅС‚Сѓ'].includes(order.status)).length, finished, avgDays, stuck, repeated, earning, companyProfit };
  }).filter((row) => row.active || row.finished);
  const topProducts = products.map((product) => {
    const sold = sales.reduce((sum, sale) => sum + sale.items.filter((item) => item.productId === product.id).reduce((inner, item) => inner + item.qty, 0), 0);
    return { product, sold, availableQty: available(product) };
  }).sort((a, b) => b.sold - a.sold);
  const isEngineer = activeUser.role === 'Р†РЅР¶РµРЅРµСЂ';
  const isManager = activeUser.role === 'РњРµРЅРµРґР¶РµСЂ' || activeUser.role === 'РђРґРјС–РЅС–СЃС‚СЂР°С‚РѕСЂ';
  const isAccountant = activeUser.role === 'Р‘СѓС…РіР°Р»С‚РµСЂ';
  const isStock = activeUser.role === 'РљРѕРјС–СЂРЅРёРє';
  const isOwner = activeUser.role === 'Р СѓРєРѕРІРѕРґРёС‚РµР»СЊ' || activeUser.role === 'РђРґРјС–РЅС–СЃС‚СЂР°С‚РѕСЂ';
  const roleOrders = isEngineer ? orders.filter((order) => order.engineer === activeUser.name) : orders;
  const roleActiveRepairs = roleOrders.filter((order) => !['Р—Р°РєСЂРёС‚Рѕ', 'РЎРєР°СЃРѕРІР°РЅРѕ', 'Р’РёРґР°РЅРѕ', 'РќРµ РїС–РґР»СЏРіР°С” СЂРµРјРѕРЅС‚Сѓ'].includes(order.status));
  const roleReadyOrders = roleOrders.filter((order) => ['Р“РѕС‚РѕРІРёР№ РґРѕ РІРёРґР°С‡С–', 'РќРµ РїС–РґР»СЏРіР°С” СЂРµРјРѕРЅС‚Сѓ', 'РћС‡С–РєСѓС” РєР»С–С”РЅС‚Р°', 'РћС‡С–РєСѓС” РѕРїР»Р°С‚Рё'].includes(order.status));
  const noPaymentOrders = orders.filter((order) => orderTotals(order).debt > 0);
  const noActOrders = orders.filter((order) => order.legalEntity && order.actIssuedAt && !order.actReturnedAt);
  const serviceProblems = buildServiceProblems(orders, documents);
  const roleServiceProblems = isManager && !isOwner
    ? serviceProblems.filter((problem) => problem.manager === activeUser.name || problem.responsible === activeUser.name)
    : serviceProblems;
  const criticalProblems = roleServiceProblems.filter((problem) => problem.level === 'РљСЂРёС‚РёС‡РЅРѕ');
  const overdueTaxInvoices = taxInvoices.filter((invoice) => invoice.status === 'РџСЂРѕСЃС‚СЂРѕС‡РµРЅРѕ');
  const missingParts = requirements.filter((item) => ['РџРѕС‚СЂС–Р±РЅРѕ', 'Р”Рѕ Р·Р°РєСѓРїС–РІР»С–'].includes(item.status));
  const delayedPurchases = purchases.filter((purchase) => purchase.status !== 'РџСЂРёР±СѓР»Рѕ' && daysSince(purchase.expectedAt) > 0);
  const accountantKpi = {
    readyTax: taxInvoices.filter((invoice) => invoice.status === 'Р“РѕС‚РѕРІРѕ РґРѕ СЂРµС”СЃС‚СЂР°С†С–С—').length,
    overdueTax: overdueTaxInvoices.length,
    acts: noActOrders.length,
    unpaid: noPaymentOrders.length,
  };
  const stockKpi = {
    receipts: purchases.filter((purchase) => purchase.status === 'РџСЂРёР±СѓР»Рѕ' || purchase.status === 'Р§Р°СЃС‚РєРѕРІРѕ РїСЂРёР±СѓР»Рѕ').length,
    stock: products.reduce((sum, product) => sum + available(product), 0),
    critical: minStock.length,
    delays: delayedPurchases.length,
  };
  const dashboardTitle = isEngineer
    ? `Р РѕР±РѕС‡РёР№ СЃС‚С–Р» С–РЅР¶РµРЅРµСЂР°: ${activeUser.name}`
    : isAccountant
      ? 'Р РѕР±РѕС‡РёР№ СЃС‚С–Р» Р±СѓС…РіР°Р»С‚РµСЂР°'
      : isStock
        ? 'Р РѕР±РѕС‡РёР№ СЃС‚С–Р» СЃРєР»Р°РґСѓ'
      : isManager
        ? 'Р РѕР±РѕС‡РёР№ СЃС‚С–Р» РјРµРЅРµРґР¶РµСЂР°'
        : 'Р РѕР±РѕС‡РёР№ СЃС‚С–Р» РєРµСЂС–РІРЅРёРєР°';

  return (
    <div className="page-grid">
      <PageTitle eyebrow="Р“РѕР»РѕРІРЅР°" title={dashboardTitle} text="РџРµСЂС€РёР№ РµРєСЂР°РЅ РґР»СЏ С‰РѕРґРµРЅРЅРѕС— СЂРѕР±РѕС‚Рё: С€РІРёРґРєС– РґС–С—, РїРѕС‚РѕС‡РЅС– Р·Р°РґР°С‡С–, СЃРёРіРЅР°Р»Рё С– РіСЂРѕС€С– Р±РµР· Р·Р°Р№РІРёС… РїРµСЂРµС…РѕРґС–РІ." />
      {(isManager || isOwner) && (
        <QuickOrderIntake
          phone={quickPhone}
          clientName={quickClientName}
          device={quickDevice}
          problem={quickProblem}
          engineerId={quickEngineerId}
          users={users}
          customerList={customerList}
          onPhoneChange={setQuickPhone}
          onClientNameChange={setQuickClientName}
          onDeviceChange={setQuickDevice}
          onProblemChange={setQuickProblem}
          onEngineerChange={setQuickEngineerId}
          onSubmit={createQuickOrder}
        />
      )}
     
      {(isManager || isOwner) && (
        <section className="panel">
          <div className="panel-heading">
            <h2>РљРѕРЅС‚СЂРѕР»СЊ РїРѕРјРёР»РѕРє</h2>
            <span>{criticalProblems.length} РєСЂРёС‚РёС‡РЅРѕ В· Р°РІС‚РѕРѕРЅРѕРІР»РµРЅРЅСЏ 5-10 С…РІ</span>
          </div>
          <div className="table problem-table">
            <div className="table-row table-head"><span>Р С–РІРµРЅСЊ</span><span>Р—Р°РєР°Р·</span><span>РџСЂРѕР±Р»РµРјР°</span><span>Р”РЅС–РІ</span><span>Р’С–РґРїРѕРІС–РґР°Р»СЊРЅРёР№</span><span>Р”С–СЏ</span></div>
            {roleServiceProblems.slice(0, 5).map((problem) => (
              <div className="table-row" key={`dash-${problem.id}`}>
                <span>{problem.level}</span>
                <span>{problem.orderId}<small>{problem.client}</small></span>
                <span>{problem.type}<small>{problem.description}</small></span>
                <span>{problem.days}</span>
                <span>{problem.responsible}</span>
                <span><button type="button" onClick={() => { setSelectedOrderId(problem.orderId); setPage('orders'); }}>Р’С–РґРєСЂРёС‚Рё Р·Р°РєР°Р·</button></span>
              </div>
            ))}
          </div>
          {roleServiceProblems.length === 0 && <div className="empty-state">РљСЂРёС‚РёС‡РЅРёС… РїСЂРѕР±Р»РµРј Р·Р°СЂР°Р· РЅРµРјР°С”.</div>}
        </section>
      )}
      {isOwner && (
        <>
          <section className="stats-grid">
            <Metric icon={<Banknote />} label="Р’РёСЂСѓС‡РєР° СЃСЊРѕРіРѕРґРЅС–" value={money(salesToday + serviceRevenue)} hint="РѕРїР»Р°С‚Рё СЂРµРјРѕРЅС‚С–РІ + РїСЂРѕРґР°Р¶С–" />
            <Metric icon={<Banknote />} label="Р’РёСЂСѓС‡РєР° Р·Р° РјС–СЃСЏС†СЊ" value={money(monthRevenue)} hint="РґРµРјРѕ-РїРµСЂС–РѕРґ Сѓ CRM" />
            <Metric icon={<CheckCircle2 />} label="РџСЂРёР±СѓС‚РѕРє" value={money(monthProfit)} hint="С‚С–Р»СЊРєРё С„С–РЅР°Р»СЊРЅС– СЂРµРјРѕРЅС‚Рё + РїСЂРѕРґР°Р¶С–" />
            <Metric icon={<History />} label="Р”РѕР»РіРё" value={money(debt)} hint="РєР»С–С”РЅС‚Рё С– РїСЂРѕРґР°Р¶С–" />
          </section>
          <section className="content-split">
            <div className="panel">
              <div className="panel-heading"><h2>РџСЂРѕР±Р»РµРјРё</h2><span>РґР»СЏ СЂС–С€РµРЅРЅСЏ Р·Р°СЂР°Р·</span></div>
              <div className="task-list">
                <Task icon={<History />} title="Р—Р°РєР°Р·С‹ Р±РµР· СЂСѓС…Сѓ" text={`${stuckOrders.length} РЅРµ Р·РјС–РЅСЋРІР°Р»Рё СЃС‚Р°С‚СѓСЃ Р±С–Р»СЊС€Рµ 2 РґРЅС–РІ.`} />
                <Task icon={<Banknote />} title="РќРµРјР°С” РѕРїР»Р°С‚Рё" text={`${noPaymentOrders.length} Р·Р°РєР°Р·С–РІ С–Р· Р±РѕСЂРіРѕРј.`} />
                <Task icon={<ClipboardList />} title="РќРµРјР°С” Р°РєС‚С–РІ" text={`${noActOrders.length} Р°РєС‚С–РІ РЅРµ РїРѕРІРµСЂРЅРµРЅРѕ.`} />
                <Task icon={<X />} title="РџСЂРѕСЃСЂРѕС‡РєРё РџРќ" text={`${overdueTaxInvoices.length} РїРѕРґР°С‚РєРѕРІРёС… РЅР°РєР»Р°РґРЅРёС… РїСЂРѕСЃС‚СЂРѕС‡РµРЅРѕ.`} />
                <Task icon={<PackagePlus />} title="РќРµРјР°С” Р·Р°РїС‡Р°СЃС‚РµР№" text={`${missingParts.length} РїРѕС‚СЂРµР± С‚СЂРµР±Р° Р·Р°РєСѓРїРёС‚Рё.`} />
              </div>
            </div>
            <div className="panel">
              <div className="panel-heading"><h2>РћРїРµСЂР°С†С–С—</h2><span>СЃС‚Р°РЅ СЃРµСЂРІС–СЃСѓ</span></div>
              <div className="details-grid">
                <Info label="РђРєС‚РёРІРЅС– Р·Р°РєР°Р·С‹" value={String(activeRepairs)} />
                <Info label="Р’ СЂРµРјРѕРЅС‚С–" value={String(inRepair)} />
                <Info label="Р“РѕС‚РѕРІРѕ" value={String(ready)} />
                <Info label="РќР° РІРёРґР°С‡Сѓ" value={String(roleReadyOrders.length)} />
              </div>
            </div>
          </section>
          <section className="content-split">
            <div className="panel">
              <div className="panel-heading"><h2>РЎРѕС‚СЂСѓРґРЅРёРєРё KPI</h2><span>РјРµРЅРµРґР¶РµСЂРё, С–РЅР¶РµРЅРµСЂРё, Р±СѓС…РіР°Р»С‚РµСЂС–СЏ</span></div>
              <div className="task-list">
                {managerRows.map((row) => <Task key={`owner-manager-${row.name}`} icon={<Users />} title={`РњРµРЅРµРґР¶РµСЂ В· ${row.name}`} text={`РџСЂРёР№РЅСЏС‚Рѕ ${row.orders}, РІРёРґР°РЅРѕ ${row.closed}, РѕРїР»Р°С‚ ${row.paymentsCount}, СЃРµСЂРµРґРЅС–Р№ С‡РµРє ${money(row.avg)}, Р±РѕСЂРіРё ${money(row.debt)}, Р°РєС‚С–РІ РЅРµ РїРѕРІРµСЂРЅРµРЅРѕ ${row.documentsCount}.`} />)}
                {engineerRows.map((row) => <Task key={`owner-engineer-${row.name}`} icon={<Wrench />} title={`Р†РЅР¶РµРЅРµСЂ В· ${row.name}`} text={`Р—Р°РєР°Р·С–РІ ${row.orders}, Р·Р°РІРµСЂС€РµРЅРѕ ${row.finished}, СЃРµСЂРµРґРЅС–Р№ С‡Р°СЃ ${row.avgDays} РґРЅ., Р±РµР· СЂСѓС…Сѓ ${row.stuck}, РїРѕРІС‚РѕСЂРё ${row.repeated}, Р·Р°СЂРѕР±С–С‚РѕРє ${money(row.earning)}, РїСЂРёР±СѓС‚РѕРє РєРѕРјРїР°РЅС–С— ${money(row.companyProfit)}.`} />)}
                <Task icon={<ClipboardList />} title="Р‘СѓС…РіР°Р»С‚РµСЂ" text={`Р“РѕС‚РѕРІРѕ РџРќ ${accountantKpi.readyTax}, РїСЂРѕСЃСЂРѕС‡РµРЅРѕ ${accountantKpi.overdueTax}, Р°РєС‚Рё Р±РµР· РїРѕРІРµСЂРЅРµРЅРЅСЏ ${accountantKpi.acts}, РЅРµРѕРїР»Р°С‡РµРЅС– Р·Р°РєР°Р·С‹ ${accountantKpi.unpaid}.`} />
              </div>
            </div>
            <div className="panel">
              <div className="panel-heading"><h2>РЎРєР»Р°Рґ</h2><span>Р·Р°Р»РёС€РєРё С– Р·Р°РєСѓРїРєРё</span></div>
              <div className="task-list">
                <Task icon={<Archive />} title="РћСЃС‚Р°С‚РєРё" text={`${stockKpi.stock} РѕРґРёРЅРёС†СЊ РґРѕСЃС‚СѓРїРЅРѕ РЅР° СЃРєР»Р°РґС–.`} />
                <Task icon={<X />} title="РљСЂРёС‚РёС‡РЅС– Р·Р°Р»РёС€РєРё" text={`${stockKpi.critical} РїРѕР·РёС†С–Р№ РЅРёР¶С‡Рµ РјС–РЅС–РјСѓРјСѓ.`} />
                <Task icon={<Truck />} title="РџСЂРёС…РѕРґРё" text={`${stockKpi.receipts} Р·Р°РєСѓРїРѕРє РїСЂРёР±СѓР»Рё Р°Р±Рѕ С‡Р°СЃС‚РєРѕРІРѕ РїСЂРёР±СѓР»Рё.`} />
                <Task icon={<History />} title="Р—Р°С‚СЂРёРјРєРё РїРѕСЃС‚Р°РІРѕРє" text={`${stockKpi.delays} Р·Р°РєСѓРїРѕРє РїСЂРѕСЃС‚СЂРѕС‡РµРЅС– Р·Р° РѕС‡С–РєСѓРІР°РЅРѕСЋ РґР°С‚РѕСЋ.`} />
              </div>
            </div>
          </section>
          <section className="panel">
            <div className="panel-heading"><h2>РЈРІРµРґРѕРјР»РµРЅРЅСЏ РєРµСЂС–РІРЅРёРєСѓ</h2><span>РїСЂРѕР±Р»РµРјРЅС– РїРѕРґС–С—</span></div>
            <div className="task-list">
              {[...problemOrders.slice(0, 3).map((order) => <Task key={`problem-${order.id}`} icon={<Bell />} title={`${order.id} В· ${order.status}`} text={`${order.client}: ${order.issue}`} />),
                ...overdueTaxInvoices.slice(0, 2).map((invoice) => <Task key={`tax-${invoice.id}`} icon={<ClipboardList />} title={`${invoice.id} В· РїСЂРѕСЃСЂРѕС‡РєР° РџРќ`} text={`${invoice.client}: ${money(invoice.amount)} В· РґРµРґР»Р°Р№РЅ ${invoice.deadline}`} />),
                ...minStock.slice(0, 2).map((product) => <Task key={`stock-${product.id}`} icon={<Archive />} title={`${product.name} В· РєСЂРёС‚РёС‡РЅРёР№ Р·Р°Р»РёС€РѕРє`} text={`Р”РѕСЃС‚СѓРїРЅРѕ ${available(product)} С€С‚., РјС–РЅС–РјСѓРј ${product.min}.`} />),
              ]}
            </div>
          </section>
        </>
      )}
      <section className="content-split">
        <div className="panel">
          <div className="panel-heading"><h2>РџРѕС‚РѕС‡РЅР° СЂРѕР±РѕС‚Р°</h2><span>{roleOrders.length} Р·Р°РєР°Р·С–РІ</span></div>
          <div className="task-list">
            {isStock ? (
              <>
                <Task icon={<Truck />} title="РџСЂРёС…С–Рґ" text={`${purchases.length} Р·Р°РєСѓРїС–РІРµР»СЊ Сѓ РєРѕРЅС‚СЂРѕР»С– СЃРєР»Р°РґСѓ.`} />
                <Task icon={<History />} title="РџРµСЂРµРјС–С‰РµРЅРЅСЏ" text="Р СѓС…Рё СЃРєР»Р°РґСѓ РІС–РґРєСЂРёРІР°СЋС‚СЊСЃСЏ РІ РѕРґРёРЅ РєР»С–Рє." />
                <Task icon={<Archive />} title="РћСЃС‚Р°С‚РєРё" text={`${minStock.length} РїРѕР·РёС†С–Р№ РЅРёР¶С‡Рµ РјС–РЅС–РјР°Р»СЊРЅРѕРіРѕ Р·Р°Р»РёС€РєСѓ.`} />
              </>
            ) : (
              <>
                <Task icon={<Wrench />} title="РђРєС‚РёРІРЅС– СЂРµРјРѕРЅС‚Рё" text={`${roleActiveRepairs.length} Сѓ СЂРѕР±РѕС‚С– Р·Р°СЂР°Р·.`} />
                <Task icon={<PackageCheck />} title="Р“РѕС‚РѕРІРѕ РґРѕ РІРёРґР°С‡С–" text={`${roleReadyOrders.length} РјРѕР¶РЅР° РІРёРґР°РІР°С‚Рё Р°Р±Рѕ РєРѕРЅС‚СЂРѕР»СЋРІР°С‚Рё РєР»С–С”РЅС‚Р°.`} />
                <Task icon={<History />} title="РџСЂРѕР±Р»РµРјРЅС– Р·Р°РєР°Р·С‹" text={`${problemOrders.length} Р·Р°РІРёСЃР»Рё, РїСЂРѕСЃС‚СЂРѕС‡РµРЅС– Р°Р±Рѕ РґРѕРІРіРѕ С‡РµРєР°СЋС‚СЊ Р·Р°РїС‡Р°СЃС‚РёРЅСѓ.`} />
              </>
            )}
          </div>
        </div>
        <div className="panel">
          <div className="panel-heading"><h2>РЎРёРіРЅР°Р»Рё</h2><span>РґС–С— СЃСЊРѕРіРѕРґРЅС–</span></div>
          <div className="task-list">
            {isStock ? (
              <>
                <Task icon={<Archive />} title="РљСЂРёС‚РёС‡РЅС– Р·Р°Р»РёС€РєРё" text={`${minStock.length} С‚РѕРІР°СЂС–РІ РїРѕС‚СЂРµР±СѓСЋС‚СЊ Р·Р°РєСѓРїРєРё Р°Р±Рѕ РєРѕРЅС‚СЂРѕР»СЋ.`} />
                <Task icon={<PackagePlus />} title="РџРѕС‚СЂРµР±Рё СЃРµСЂРІС–СЃСѓ" text={`${requirements.length} РїРѕС‚СЂРµР± С–Р· СЂРµРјРѕРЅС‚С–РІ РѕС‡С–РєСѓСЋС‚СЊ Р·Р°Р±РµР·РїРµС‡РµРЅРЅСЏ.`} />
                <Task icon={<Truck />} title="Р’ РґРѕСЂРѕР·С–" text={`${analytics.ordered} РѕРґРёРЅРёС†СЊ Р·Р°РјРѕРІР»РµРЅРѕ Р°Р±Рѕ РѕС‡С–РєСѓС”С‚СЊСЃСЏ.`} />
              </>
            ) : (
              <>
                {(isManager || isAccountant || isOwner) && <Task icon={<Banknote />} title="РќРµРјР°С” РѕРїР»Р°С‚Рё" text={`${noPaymentOrders.length} Р·Р°РєР°Р·С–РІ Р°Р±Рѕ РїСЂРѕРґР°Р¶С–РІ РјР°СЋС‚СЊ Р±РѕСЂРі.`} />}
                {(isManager || isAccountant || isOwner) && <Task icon={<ClipboardList />} title="РќРµРјР°С” Р°РєС‚С–РІ" text={`${noActOrders.length} Р°РєС‚С–РІ РЅРµ РїРѕРІРµСЂРЅРµРЅС– Р°Р±Рѕ РїРѕС‚СЂРµР±СѓСЋС‚СЊ РєРѕРЅС‚СЂРѕР»СЋ.`} />}
                <Task icon={<History />} title="Р—Р°РІРёСЃР»С– Р·Р°РєР°Р·С‹" text={`${stuckOrders.length} Р±РµР· СЂСѓС…Сѓ Р±С–Р»СЊС€Рµ 2 РґРЅС–РІ.`} />
              </>
            )}
          </div>
        </div>
      </section>
     
      {(isManager || isAccountant || isOwner || isStock) && <section className="content-split">
        <div className="panel">
          <div className="panel-heading"><h2>{isStock ? 'РЎРєР»Р°РґСЃСЊРєС– РїСЂРѕР±Р»РµРјРё' : 'Р”Рµ РїСЂРѕР±Р»РµРјРё'}</h2><span>{isStock ? minStock.length : problemOrders.length} СЃРёРіРЅР°Р»С–РІ</span></div>
          <div className="task-list">
            {isStock ? (
              <>
                <Task icon={<Archive />} title="РњС–РЅС–РјР°Р»СЊРЅС– Р·Р°Р»РёС€РєРё" text={`${minStock.length} РїРѕР·РёС†С–Р№ РЅРёР¶С‡Рµ РјС–РЅС–РјСѓРјСѓ.`} />
                <Task icon={<PackagePlus />} title="РџРѕС‚СЂРµР±Рё СЂРµРјРѕРЅС‚Сѓ" text={`${requirements.length} РїРѕС‚СЂРµР± С‚СЂРµР±Р° Р·Р°РєСЂРёС‚Рё РїСЂРёС…РѕРґРѕРј Р°Р±Рѕ Р·Р°РєСѓРїРєРѕСЋ.`} />
                <Task icon={<Truck />} title="Р—Р°РєСѓРїРєРё" text={`${purchases.length} РґРѕРєСѓРјРµРЅС‚С–РІ Р·Р°РєСѓРїРєРё Сѓ СЂРѕР±РѕС‚С–.`} />
              </>
            ) : (
              <>
                <Task icon={<History />} title="Р—Р°РєР°Р·С‹ Р±РµР· СЂСѓС…Сѓ" text={`${stuckOrders.length} РЅРµ Р·РјС–РЅСЋРІР°Р»Рё СЃС‚Р°С‚СѓСЃ Р±С–Р»СЊС€Рµ 2 РґРЅС–РІ.`} />
                <Task icon={<Truck />} title="Р”РѕРІРіРѕ С‡РµРєР°СЋС‚СЊ Р·Р°РїС‡Р°СЃС‚РёРЅСѓ" text={`${orders.filter((order) => order.status === 'РћС‡С–РєСѓС” Р·Р°РїС‡Р°СЃС‚РёРЅСѓ').length} Сѓ СЃС‚Р°С‚СѓСЃС– РѕС‡С–РєСѓРІР°РЅРЅСЏ.`} />
                <Task icon={<PackageCheck />} title="Р“РѕС‚РѕРІС–, Р°Р»Рµ РЅРµ РІРёРґР°РЅС–" text={`${orders.filter((order) => ['Р“РѕС‚РѕРІРёР№ РґРѕ РІРёРґР°С‡С–', 'РќРµ РїС–РґР»СЏРіР°С” СЂРµРјРѕРЅС‚Сѓ', 'РћС‡С–РєСѓС” РєР»С–С”РЅС‚Р°', 'РћС‡С–РєСѓС” РѕРїР»Р°С‚Рё'].includes(order.status)).length} РїРѕС‚СЂРµР±СѓСЋС‚СЊ РґС–С— РјРµРЅРµРґР¶РµСЂР°.`} />
                <Task icon={<Banknote />} title="Р’С‚СЂР°С‚Рё" text={`РџРѕРІРµСЂРЅРµРЅРЅСЏ ${money(returnsAmount)}, СЃРїРёСЃР°РЅРЅСЏ РІ СЂРµРјРѕРЅС‚Р°С… ${money(writeOffs)}.`} />
              </>
            )}
          </div>
        </div>
       
      </section>}
      {(isManager || isOwner) && <section className="content-split">
        <div className="panel">
          <div className="panel-heading"><h2>Р—Р°РєР°Р·С‹ РїРѕ СЃС‚Р°С‚СѓСЃР°С…</h2><span>РґРµ Р·Р°РІРёСЃР°С” СЃРµСЂРІС–СЃ</span></div>
          <MiniBars rows={statusBars} />
        </div>
        <div className="panel">
          <div className="panel-heading"><h2>РЎРєР»Р°Рґ С– РѕР±РѕСЂР°С‡РёРІР°РµРјС–СЃС‚СЊ</h2><span>{minStock.length} РєСЂРёС‚РёС‡РЅРёС…</span></div>
          <div className="task-list">
            {topProducts.slice(0, 4).map((item) => <Task key={item.product.id} icon={<Archive />} title={item.product.name} text={`РџСЂРѕРґР°РЅРѕ ${item.sold} С€С‚. В· РґРѕСЃС‚СѓРїРЅРѕ ${item.availableQty} С€С‚. В· РјС–РЅС–РјСѓРј ${item.product.min} С€С‚.`} />)}
          </div>
        </div>
      </section>}
      {isOwner && <section className="content-split">
        <div className="panel">
          <div className="panel-heading"><h2>Р•С„РµРєС‚РёРІРЅС–СЃС‚СЊ РјРµРЅРµРґР¶РµСЂС–РІ</h2><span>{managerRows.length} СЃРїС–РІСЂРѕР±С–С‚РЅРёРєС–РІ</span></div>
          <div className="task-list">
            {managerRows.map((row) => <Task key={row.name} icon={<Users />} title={row.name} text={`РџСЂРёР№РЅСЏС‚Рѕ ${row.orders}, РІРёРґР°РЅРѕ ${row.closed}, РѕРїР»Р°С‚ ${row.paymentsCount}, СЃРµСЂРµРґРЅС–Р№ С‡РµРє ${money(row.avg)}, Р±РѕСЂРіРё ${money(row.debt)}, Р°РєС‚Рё РЅРµ РїРѕРІРµСЂРЅРµРЅС– ${row.documentsCount}.`} />)}
          </div>
        </div>
        <div className="panel">
          <div className="panel-heading"><h2>Р•С„РµРєС‚РёРІРЅС–СЃС‚СЊ С–РЅР¶РµРЅРµСЂС–РІ</h2><span>{engineerRows.length} РјР°Р№СЃС‚СЂС–РІ</span></div>
          <div className="task-list">
            {engineerRows.map((row) => <Task key={row.name} icon={<Wrench />} title={row.name} text={`Р—Р°РєР°Р·С–РІ ${row.orders}, Р·Р°РІРµСЂС€РµРЅРѕ ${row.finished}, СЃРµСЂРµРґРЅС–Р№ С‡Р°СЃ ${row.avgDays} РґРЅ., Р±РµР· СЂСѓС…Сѓ ${row.stuck}, РїРѕРІС‚РѕСЂРё ${row.repeated}, Р·Р°СЂРѕР±С–С‚РѕРє ${money(row.earning)}, РїСЂРёР±СѓС‚РѕРє РєРѕРјРїР°РЅС–С— ${money(row.companyProfit)}.`} />)}
          </div>
        </div>
      </section>}
      {isEngineer && <section className="panel">
        <div className="panel-heading"><h2>РњРѕС— РЅР°Р№Р±Р»РёР¶С‡С– РґС–С—</h2><span>{roleOrders.length} Р·Р°РєР°Р·С–РІ</span></div>
        <OrderSummaryList orders={roleOrders.slice(0, 5)} />
      </section>} {(isManager || isAccountant || isOwner) && <section className="content-split">
        <div className="panel">
          <div className="panel-heading"><h2>РџСЂРѕР±Р»РµРјРЅС– Р·Р°РєР°Р·С‹</h2><span>{problemOrders.length}</span></div>
          <OrderSummaryList orders={problemOrders.length ? problemOrders.slice(0, 4) : orders.slice(0, 3)} />
        </div>
        <div className="panel">
          <div className="panel-heading"><h2>РЎРёРіРЅР°Р»Рё РєРµСЂС–РІРЅРёРєСѓ</h2><span>Р°РІС‚РѕРєРѕРЅС‚СЂРѕР»СЊ</span></div>
          <div className="task-list">
            <Task icon={<Archive />} title="РљСЂРёС‚РёС‡РЅРёР№ СЃРєР»Р°Рґ" text={`${minStock.length} С‚РѕРІР°СЂС–РІ РЅРёР¶С‡Рµ РјС–РЅС–РјСѓРјСѓ.`} />
            <Task icon={<Banknote />} title="РљР°СЃР° С– С‚РµСЂРјС–РЅР°Р»" text={`Р“РѕС‚С–РІРєР°, РєР°СЂС‚РєР° С– Р±РµР·РЅР°Р» РєРѕРЅС‚СЂРѕР»СЋСЋС‚СЊСЃСЏ РѕРєСЂРµРјРѕ РІ СЂРѕР·РґС–Р»С– РћРїР»Р°С‚Рё / РљР°СЃР°.`} />
            <Task icon={<History />} title="РћСЃС‚Р°РЅРЅСЏ РґС–СЏ" text={actionLogs[0]?.comment ?? 'Р”С–Р№ С‰Рµ РЅРµРјР°С”.'} />
          </div>
        </div>
      </section>}
     
     
    </div>
  );
}

function OrdersPage(props: {
  orders: ServiceOrder[];
  allRoleOrders?: ServiceOrder[];
  selectedOrder: ServiceOrder;
  products: Product[];
  selectedOrderId: string;
  setSelectedOrderId: (id: string) => void;
  selectedProductId: string;
  setSelectedProductId: (id: string) => void;
  qty: number;
  setQty: (qty: number) => void;
  addPartToRepair: () => void;
  orderPart: (order: ServiceOrder, part: OrderPart) => void;
  reserveArrived: (order: ServiceOrder, part: OrderPart) => void;
  issueToEngineer: (order: ServiceOrder, part: OrderPart) => void;
  markInstalled: (order: ServiceOrder, part: OrderPart) => void;
  returnServicePart: (order: ServiceOrder, part: OrderPart, destination: 'РќР° СЃРєР»Р°Рґ' | 'Р‘СЂР°Рє') => void;
  addOrderPayment: (order: ServiceOrder, amount: number, method: PaymentMethod, comment: string) => void;
  changeOrderStatus: (order: ServiceOrder, nextStatus: OrderStatus, comment: string) => void;
  acceptOrderWork: (order: ServiceOrder) => void;
  reassignEngineer: (order: ServiceOrder) => void;
  closeOrder: (order: ServiceOrder) => void;
  issueReadyOrder: (order: ServiceOrder) => void;
  transferOrderToBas: (order: ServiceOrder) => void;
  printDocument: (kind: DocumentKind, entityType: PrintDocument['entityType'], entityId: string, clientOrSupplier: string) => void;
  documents: PrintDocument[];
  notifications: ClientNotification[];
  sendClientNotification: (order: ServiceOrder, event: NotificationEvent, preferredChannel?: NotificationChannel, manual?: boolean) => void;
  approval?: RepairApproval;
  sendRepairApproval: (order: ServiceOrder, channel?: NotificationChannel) => void;
  recordApprovalResponse: (approvalId: string, accepted: boolean, manual?: boolean) => void;
  markApprovalNoAnswer: (approvalId: string) => void;
  canDo: (permission: Permission) => boolean;
  showCost: boolean;
  activeUser: User;
}) {
  const isEngineer = props.activeUser.role === 'Р†РЅР¶РµРЅРµСЂ';
  const isManager = props.activeUser.role === 'РњРµРЅРµРґР¶РµСЂ';
  const roleOrders = props.allRoleOrders ?? props.orders;
  const engineerNew = roleOrders.filter((order) => !order.engineerAcceptedAt && !['Р“РѕС‚РѕРІРёР№ РґРѕ РІРёРґР°С‡С–', 'РќРµ РїС–РґР»СЏРіР°С” СЂРµРјРѕРЅС‚Сѓ', 'Р’РёРґР°РЅРѕ', 'Р—Р°РєСЂРёС‚Рѕ', 'РЎРєР°СЃРѕРІР°РЅРѕ'].includes(order.status));
  const engineerInWork = roleOrders.filter((order) => ['РќР° РґС–Р°РіРЅРѕСЃС‚РёС†С–', 'Р’ СЂРµРјРѕРЅС‚С–'].includes(order.status));
  const engineerWaitingParts = roleOrders.filter((order) => order.status === 'РћС‡С–РєСѓС” Р·Р°РїС‡Р°СЃС‚РёРЅСѓ');
  const engineerOnTest = roleOrders.filter((order) => order.status === 'РќР° С‚РµСЃС‚СѓРІР°РЅРЅС–');
  const engineerFinished = roleOrders.filter((order) => ['Р“РѕС‚РѕРІРёР№ РґРѕ РІРёРґР°С‡С–', 'РќРµ РїС–РґР»СЏРіР°С” СЂРµРјРѕРЅС‚Сѓ', 'Р’РёРґР°РЅРѕ', 'Р—Р°РєСЂРёС‚Рѕ'].includes(order.status));
  const managerReadyOrders = props.orders.filter((order) => ['Р“РѕС‚РѕРІРёР№ РґРѕ РІРёРґР°С‡С–', 'РќРµ РїС–РґР»СЏРіР°С” СЂРµРјРѕРЅС‚Сѓ', 'РћС‡С–РєСѓС” РѕРїР»Р°С‚Рё', 'РћС‡С–РєСѓС” РєР»С–С”РЅС‚Р°'].includes(order.status));
  const managerStatusOptions: OrderStatus[] = ['Готовий до видачі', 'Очікує оплати', 'Очікує клієнта', 'Не підлягає ремонту'];
  return (
    <div className="page-grid">
      <PageTitle eyebrow={isEngineer ? 'РњРѕС— Р·Р°РјРѕРІР»РµРЅРЅСЏ' : 'Р РµРјРѕРЅС‚Рё'} title={isEngineer ? `Р РѕР±РѕС‡РёР№ РµРєСЂР°РЅ С–РЅР¶РµРЅРµСЂР°: ${props.activeUser.name}` : 'РљР°СЂС‚РєР° Р·Р°РєР°Р·Р°'} text="Р’СЃСЏ СЂРѕР±РѕС‚Р° Р· СЂРµРјРѕРЅС‚РѕРј РЅР° РѕРґРЅРѕРјСѓ РµРєСЂР°РЅС–: РєР»С–С”РЅС‚, РїСЂРѕР±Р»РµРјР°, С–РЅР¶РµРЅРµСЂ, РјР°СЂС€СЂСѓС‚, Р·Р°РїС‡Р°СЃС‚РёРЅРё, РєРѕРјРµРЅС‚Р°СЂС–, С„С–РЅР°РЅСЃРё С– РґС–С— Р·Р° СЂРѕР»Р»СЋ." />
      {isEngineer && (
        <section className="stats-grid engineer-stats">
          <Metric icon={<ClipboardList />} label="РќРѕРІС–" value={String(engineerNew.length)} hint="РїРѕС‚СЂС–Р±РЅРѕ РІР·СЏС‚Рё" />
          <Metric icon={<Wrench />} label="Р’ СЂРѕР±РѕС‚С–" value={String(engineerInWork.length)} hint="РґС–Р°РіРЅРѕСЃС‚РёРєР° / СЂРµРјРѕРЅС‚" />
          <Metric icon={<Truck />} label="Р§РµРєР°СЋС‚СЊ Р·Р°РїС‡Р°СЃС‚РёРЅСѓ" value={String(engineerWaitingParts.length)} hint="РїРѕС‚СЂС–Р±РЅР° Р·Р°РєСѓРїРєР°" />
          <Metric icon={<CheckCircle2 />} label="РќР° С‚РµСЃС‚С–" value={String(engineerOnTest.length)} hint="РїРµСЂРµРІС–СЂРєР°" />
          <Metric icon={<PackageCheck />} label="Р—Р°РІРµСЂС€РµРЅС–" value={String(engineerFinished.length)} hint="РіРѕС‚РѕРІС– Р°Р±Рѕ РІРёРґР°РЅС–" />
        </section>
      )}
      {isManager && (
        <section className="panel">
          <div className="panel-heading"><h2>Р“РѕС‚РѕРІС– РґРѕ РІРёРґР°С‡С–</h2><span>{managerReadyOrders.length} РїРѕС‚СЂРµР±СѓСЋС‚СЊ РјРµРЅРµРґР¶РµСЂР°</span></div>
          <div className="order-list">
         {managerReadyOrders.map((order) => {
           const totals = orderTotals(order);
           const availableStatuses = managerStatusOptions.filter((status) => status === order.status || (orderStatusFlow[order.status] ?? []).includes(status));
           return (
             <div key={order.id} className={`order-card ${props.selectedOrderId === order.id ? 'order-card-active' : ''}`}>
               <div className="order-title"><strong>{order.id}</strong><span className={statusClass[order.status]}>{order.status}</span></div>
               <h3>{order.device}</h3>
               <p>{order.client} · {order.issue}</p>
               <div className="order-meta-row">
                 <span>{repairPaymentStatus(order)}</span>
                 <span>{money(totals.total)}</span>
                 <span>борг {money(totals.debt)}</span>
               </div>
               <div className="order-meta-row">
                 <button type="button" onClick={() => props.setSelectedOrderId(order.id)}>Відкрити замовлення</button>
                 <select
                   aria-label={`Статус ${order.id}`}
                   value={order.status}
                   onChange={(e) => {
                     const newStatus = e.target.value as OrderStatus;
                     if (newStatus === order.status) return;
                     const commentByStatus: Partial<Record<OrderStatus, string>> = {
                       'Готовий до видачі': 'Менеджер повернув замовлення у статус готовності до видачі.',
                       'Очікує оплати': 'Менеджер очікує оплату перед видачею.',
                       'Очікує клієнта': 'Менеджер звязався з клієнтом та очікує видачу.',
                       'Не підлягає ремонту': 'Менеджер перевів замовлення у статус неможливого ремонту.',
                     };
                     props.changeOrderStatus(order, newStatus, commentByStatus[newStatus] ?? 'Менеджер змінив статус у блоці готових до видачі.');
                   }}
                 >
                   {availableStatuses.map((status) => (
                     <option key={status} value={status}>{status}</option>
                   ))}
                 </select>
                 <button type="button" onClick={() => props.issueReadyOrder(order)}>Видати</button>
               </div>
             </div>
           );
         })}
            {managerReadyOrders.length === 0 && <div className="empty-state">Р“РѕС‚РѕРІРёС… РґРѕ РІРёРґР°С‡С– Р·Р°РјРѕРІР»РµРЅСЊ Р·Р°СЂР°Р· РЅРµРјР°С”.</div>}
          </div>
        </section>
      )}
      <section className="content-split orders-layout">
        <div className="panel">
          <div className="panel-heading"><h2>{isEngineer ? 'РћСЃРЅРѕРІРЅРёР№ СЃРїРёСЃРѕРє' : 'Р–СѓСЂРЅР°Р» СЂРµРјРѕРЅС‚С–РІ'}</h2><span>{props.orders.length} Р·РЅР°Р№РґРµРЅРѕ</span></div>
          <OrderSummaryList orders={props.orders} selectedId={props.selectedOrderId} onSelect={props.setSelectedOrderId} showPriority={isEngineer} />
        </div>
        <OrderDetail {...props} />
      </section>
    </div>
  );
}

function MyOrdersPage({ orders, activeUser, acceptOrderWork, changeOrderStatus }: { orders: ServiceOrder[]; activeUser: User; acceptOrderWork: (order: ServiceOrder) => void; changeOrderStatus: (order: ServiceOrder, nextStatus: OrderStatus, comment: string) => void }) {
  const newOrders = orders.filter((order) => !order.engineerAcceptedAt);
  const inWork = orders.filter((order) => ['РќР° РґС–Р°РіРЅРѕСЃС‚РёС†С–', 'Р’ СЂРµРјРѕРЅС‚С–', 'РќР° С‚РµСЃС‚СѓРІР°РЅРЅС–'].includes(order.status));
  const waitingParts = orders.filter((order) => order.status === 'РћС‡С–РєСѓС” Р·Р°РїС‡Р°СЃС‚РёРЅСѓ');
  const finished = orders.filter((order) => ['Р“РѕС‚РѕРІРёР№ РґРѕ РІРёРґР°С‡С–', 'РќРµ РїС–РґР»СЏРіР°С” СЂРµРјРѕРЅС‚Сѓ', 'Р’РёРґР°РЅРѕ', 'Р—Р°РєСЂРёС‚Рѕ'].includes(order.status));

  return (
    <div className="page-grid">
      <PageTitle eyebrow="РњРѕС— Р·Р°РјРѕРІР»РµРЅРЅСЏ" title={`Р РѕР±РѕС‡РёР№ СЃРїРёСЃРѕРє С–РЅР¶РµРЅРµСЂР°: ${activeUser.name}`} text="Р†РЅР¶РµРЅРµСЂ Р±Р°С‡РёС‚СЊ С‚С–Р»СЊРєРё РїСЂРёР·РЅР°С‡РµРЅС– Р№РѕРјСѓ Р·Р°РјРѕРІР»РµРЅРЅСЏ, РїС–РґС‚РІРµСЂРґР¶СѓС” РІР·СЏС‚С‚СЏ РІ СЂРѕР±РѕС‚Сѓ С‚Р° Р·РјС–РЅСЋС” С‚РµС…РЅС–С‡РЅС– СЃС‚Р°С‚СѓСЃРё." />
      <section className="stats-grid">
        <Metric icon={<ClipboardList />} label="РќРѕРІС–" value={String(newOrders.length)} hint="РїРѕС‚СЂС–Р±РЅРѕ РІР·СЏС‚Рё РІ СЂРѕР±РѕС‚Сѓ" />
        <Metric icon={<Wrench />} label="Р’ СЂРѕР±РѕС‚С–" value={String(inWork.length)} hint="РґС–Р°РіРЅРѕСЃС‚РёРєР°, СЂРµРјРѕРЅС‚, С‚РµСЃС‚" />
        <Metric icon={<Truck />} label="РћС‡С–РєСѓСЋС‚СЊ Р·Р°РїС‡Р°СЃС‚СЊ" value={String(waitingParts.length)} hint="РєРѕРЅС‚СЂРѕР»СЊ Р·Р°РєСѓРїРѕРє" />
        <Metric icon={<CheckCircle2 />} label="Р—Р°РІРµСЂС€РµРЅС–" value={String(finished.length)} hint="РіРѕС‚РѕРІС– Р°Р±Рѕ Р·Р°РєСЂРёС‚С–" />
      </section>
      <section className="content-split">
        <div className="panel">
          <div className="panel-heading"><h2>РќРѕРІС– РґР»СЏ С–РЅР¶РµРЅРµСЂР°</h2><span>{newOrders.length}</span></div>
          <div className="order-list">
            {newOrders.map((order) => (
              <article className="order-card" key={order.id}>
                <div className="order-title"><strong>{order.id}</strong><span className={statusClass[order.status]}>{order.status}</span></div>
                <h3>{order.device}</h3>
                <p>{order.client} В· {order.issue}</p>
                <div className="action-row"><button type="button" onClick={() => acceptOrderWork(order)}>Р’Р·СЏС‚Рё РІ СЂРѕР±РѕС‚Сѓ</button></div>
              </article>
            ))}
            {newOrders.length === 0 && <div className="empty-state">РќРѕРІРёС… РїСЂРёР·РЅР°С‡РµРЅРёС… Р·Р°РјРѕРІР»РµРЅСЊ РЅРµРјР°С”.</div>}
          </div>
        </div>
        <div className="panel">
          <div className="panel-heading"><h2>Р’ СЂРѕР±РѕС‚С–</h2><span>{inWork.length}</span></div>
          <div className="task-list">
            {inWork.map((order) => (
              <Task key={order.id} icon={<Wrench />} title={`${order.id} В· ${order.device}`} text={`${order.status}. РљР»С–С”РЅС‚: ${order.client}. РЎРµСЂС–Р№РЅРёР№ РЅРѕРјРµСЂ: ${order.serial}`} />
            ))}
          </div>
        </div>
      </section>
      <section className="content-split">
        <div className="panel">
          <div className="panel-heading"><h2>РћС‡С–РєСѓСЋС‚СЊ Р·Р°РїС‡Р°СЃС‚СЊ</h2><span>{waitingParts.length}</span></div>
          <OrderSummaryList orders={waitingParts} />
        </div>
        <div className="panel">
          <div className="panel-heading"><h2>РўРµС…РЅС–С‡РЅС– РґС–С—</h2><span>С€РІРёРґРєРѕ</span></div>
          <div className="task-list">
            {inWork.slice(0, 4).map((order) => (
              <article className="task" key={order.id}>
                <div className="task-icon"><CheckCircle2 /></div>
                <div>
                  <strong>{order.id}</strong>
                  <p>{order.device}</p>
                  <div className="action-row">
                    <button type="button" onClick={() => changeOrderStatus(order, 'РќР° С‚РµСЃС‚СѓРІР°РЅРЅС–', 'Р†РЅР¶РµРЅРµСЂ РїРµСЂРµРґР°РІ РїСЂРёСЃС‚СЂС–Р№ РЅР° С‚РµСЃС‚СѓРІР°РЅРЅСЏ.')}>РќР° С‚РµСЃС‚</button>
                    <button type="button" onClick={() => changeOrderStatus(order, 'Р“РѕС‚РѕРІРёР№ РґРѕ РІРёРґР°С‡С–', 'Р†РЅР¶РµРЅРµСЂ РїС–РґС‚РІРµСЂРґРёРІ РіРѕС‚РѕРІРЅС–СЃС‚СЊ РґРѕ РІРёРґР°С‡С–.')}>Р“РѕС‚РѕРІРёР№</button>
                  </div>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>
    </div>
  );
}

function OrderDetail({ selectedOrder, products, selectedProductId, setSelectedProductId, qty, setQty, addPartToRepair, orderPart, reserveArrived, issueToEngineer, markInstalled, returnServicePart, addOrderPayment, changeOrderStatus, acceptOrderWork, reassignEngineer, closeOrder, issueReadyOrder, transferOrderToBas, printDocument, documents, notifications, sendClientNotification, approval, sendRepairApproval, recordApprovalResponse, markApprovalNoAnswer, canDo, showCost, activeUser }: {
  selectedOrder: ServiceOrder;
  products: Product[];
  selectedProductId: string;
  setSelectedProductId: (id: string) => void;
  qty: number;
  setQty: (qty: number) => void;
  addPartToRepair: () => void;
  orderPart: (order: ServiceOrder, part: OrderPart) => void;
  reserveArrived: (order: ServiceOrder, part: OrderPart) => void;
  issueToEngineer: (order: ServiceOrder, part: OrderPart) => void;
  markInstalled: (order: ServiceOrder, part: OrderPart) => void;
  returnServicePart: (order: ServiceOrder, part: OrderPart, destination: 'РќР° СЃРєР»Р°Рґ' | 'Р‘СЂР°Рє') => void;
  addOrderPayment: (order: ServiceOrder, amount: number, method: PaymentMethod, comment: string) => void;
  changeOrderStatus: (order: ServiceOrder, nextStatus: OrderStatus, comment: string) => void;
  acceptOrderWork: (order: ServiceOrder) => void;
  reassignEngineer: (order: ServiceOrder) => void;
  closeOrder: (order: ServiceOrder) => void;
  issueReadyOrder: (order: ServiceOrder) => void;
  transferOrderToBas: (order: ServiceOrder) => void;
  printDocument: (kind: DocumentKind, entityType: PrintDocument['entityType'], entityId: string, clientOrSupplier: string) => void;
  documents: PrintDocument[];
  notifications: ClientNotification[];
  sendClientNotification: (order: ServiceOrder, event: NotificationEvent, preferredChannel?: NotificationChannel, manual?: boolean) => void;
  approval?: RepairApproval;
  sendRepairApproval: (order: ServiceOrder, channel?: NotificationChannel) => void;
  recordApprovalResponse: (approvalId: string, accepted: boolean, manual?: boolean) => void;
  markApprovalNoAnswer: (approvalId: string) => void;
  canDo: (permission: Permission) => boolean;
  showCost: boolean;
  activeUser: User;
}) {
  const totals = orderTotals(selectedOrder);
  const paymentStatus = repairPaymentStatus(selectedOrder);
  const statusAge = daysSince(selectedOrder.statusChangedAt);
  const totalAge = daysSince(selectedOrder.intakeDate);
  const nextStatuses = orderStatusFlow[selectedOrder.status] ?? [];
  const canSeeFinance = activeUser.role !== 'Р†РЅР¶РµРЅРµСЂ';
  const canManageDocuments = activeUser.role !== 'Р†РЅР¶РµРЅРµСЂ';
  const canSendApproval = activeUser.role === 'РњРµРЅРµРґР¶РµСЂ' || activeUser.role === 'Р СѓРєРѕРІРѕРґРёС‚РµР»СЊ' || activeUser.role === 'РђРґРјС–РЅС–СЃС‚СЂР°С‚РѕСЂ';
  const canAddParts = activeUser.role === 'Р†РЅР¶РµРЅРµСЂ' || activeUser.role === 'РњРµРЅРµРґР¶РµСЂ' || activeUser.role === 'Р СѓРєРѕРІРѕРґРёС‚РµР»СЊ' || activeUser.role === 'РђРґРјС–РЅС–СЃС‚СЂР°С‚РѕСЂ';
  const [paymentAmount, setPaymentAmount] = useState(0);
  const [paymentMethod, setPaymentMethod] = useState<PaymentMethod>('Р“РѕС‚С–РІРєР°');
  const effectivePaymentAmount = Math.min(paymentAmount > 0 ? paymentAmount : totals.debt, totals.debt);
  const recordOrderPayment = (comment = 'РћРїР»Р°С‚Р° СЂРµРјРѕРЅС‚Сѓ') => addOrderPayment(selectedOrder, effectivePaymentAmount, paymentMethod, comment);
  const directOrderUrl = typeof window === 'undefined' ? selectedOrder.qrUrl : `${window.location.origin}${window.location.pathname}#${selectedOrder.qrUrl}`;
  const hasDocument = (kind: DocumentKind) => documents.some((document) => document.entityType === 'service_order' && document.entityId === selectedOrder.id && document.kind === kind);
  const hasIssueAct = ['РђРєС‚ РЅР°РґР°РЅРЅСЏ РїРѕСЃР»СѓРі', 'РђРєС‚ РІРёРєРѕРЅР°РЅРёС… СЂРѕР±С–С‚', 'РђРєС‚ РІРёРґР°С‡С–', 'РђРєС‚ С‚РµС…РЅС–С‡РЅРѕРіРѕ СЃС‚Р°РЅСѓ'].some((kind) => hasDocument(kind as DocumentKind));
  const isReadyForClient = ['Р“РѕС‚РѕРІРёР№ РґРѕ РІРёРґР°С‡С–', 'РћС‡С–РєСѓС” РѕРїР»Р°С‚Рё', 'РћС‡С–РєСѓС” РєР»С–С”РЅС‚Р°', 'Р’РёРґР°РЅРѕ', 'Р—Р°РєСЂРёС‚Рѕ'].includes(selectedOrder.status);
  const canFormActAndInvoice = canManageDocuments && isReadyForClient;
  const canFormTechnicalAct = canManageDocuments && selectedOrder.status === 'РќРµ РїС–РґР»СЏРіР°С” СЂРµРјРѕРЅС‚Сѓ';
  const canCreateDeliveryNote = canManageDocuments && selectedOrder.parts.length > 0;
  const canIssueOrder = ['Р“РѕС‚РѕРІРёР№ РґРѕ РІРёРґР°С‡С–', 'РќРµ РїС–РґР»СЏРіР°С” СЂРµРјРѕРЅС‚Сѓ', 'РћС‡С–РєСѓС” РѕРїР»Р°С‚Рё', 'РћС‡С–РєСѓС” РєР»С–С”РЅС‚Р°'].includes(selectedOrder.status) && roleCanSetOrderStatus(activeUser.role, 'Р’РёРґР°РЅРѕ') && totals.debt <= 0 && hasIssueAct;
  const canTransferBas = isReadyForClient && hasIssueAct && hasDocument('Р Р°С…СѓРЅРѕРє РЅР° РѕРїР»Р°С‚Сѓ') && totals.paid > 0 && (selectedOrder.parts.length === 0 || hasDocument('Р’РёРґР°С‚РєРѕРІР° РЅР°РєР»Р°РґРЅР°'));
  return (
    <section className="panel">
      <div className="panel-heading">
        <h2>{selectedOrder.id} В· {selectedOrder.device}</h2>
        <span className={statusClass[selectedOrder.status]}>{selectedOrder.status}</span>
      </div>
      <div className="details-grid">
        <Info label="РљР»С–С”РЅС‚" value={`${selectedOrder.client}, ${selectedOrder.phone}`} />
        <Info label="РЎРµСЂС–Р№РЅРёР№ РЅРѕРјРµСЂ" value={selectedOrder.serial} />
        <Info label="Р†РЅР¶РµРЅРµСЂ" value={selectedOrder.engineer} />
        <Info label="РџС–РґС‚РІРµСЂРґР¶РµРЅРЅСЏ С–РЅР¶РµРЅРµСЂР°" value={selectedOrder.engineerAcceptedAt ?? 'Р©Рµ РЅРµ РІР·СЏРІ Сѓ СЂРѕР±РѕС‚Сѓ'} />
        <Info label="РњРµРЅРµРґР¶РµСЂ" value={selectedOrder.manager} />
        <Info label="РќРµСЃРїСЂР°РІРЅС–СЃС‚СЊ" value={selectedOrder.issue} />
        {canSeeFinance && <Info label="Р—Р°РіР°Р»СЊРЅР° СЃСѓРјР°" value={money(totals.total)} />}
        {canSeeFinance && <Info label="РЎСѓРјР° СЂРѕР±С–С‚" value={money(totals.works)} />}
        {canSeeFinance && <Info label="РЎСѓРјР° Р·Р°РїС‡Р°СЃС‚РёРЅ" value={money(totals.parts)} />}
        {canSeeFinance && <Info label="Р”РѕСЃС‚Р°РІРєР°" value={money(totals.delivery)} />}
        {canSeeFinance && <Info label="РџСЂРѕС‡С– РІРёС‚СЂР°С‚Рё" value={money(totals.additionalExpenses + totals.consumables + totals.externalServices)} />}
        {canSeeFinance && <Info label="Р—Р°СЂРїР»Р°С‚Р° С–РЅР¶РµРЅРµСЂР°" value={showCost ? money(totals.engineerSalary) : 'РџСЂРёС…РѕРІР°РЅРѕ РїСЂР°РІР°РјРё РґРѕСЃС‚СѓРїСѓ'} />}
        {canSeeFinance && <Info label="Р—Р°РєСѓРїРєР° Р·Р°РїС‡Р°СЃС‚РёРЅ" value={showCost ? money(totals.purchaseCost) : 'РџСЂРёС…РѕРІР°РЅРѕ РїСЂР°РІР°РјРё РґРѕСЃС‚СѓРїСѓ'} />}
        {canSeeFinance && <Info label="РџС–РґСЃСѓРјРєРѕРІРёР№ РїСЂРёР±СѓС‚РѕРє" value={showCost ? `${money(totals.profit)}${totals.isFinal ? '' : ' В· С„С–РЅР°Р»СЊРЅРѕ РїС–СЃР»СЏ Р·Р°РєСЂРёС‚С‚СЏ'}` : 'РџСЂРёС…РѕРІР°РЅРѕ РїСЂР°РІР°РјРё РґРѕСЃС‚СѓРїСѓ'} />}
        {canSeeFinance && <Info label="РћРїР»Р°С‚Р°" value={`${paymentStatus} В· РѕРїР»Р°С‡РµРЅРѕ ${money(totals.paid)} В· Р±РѕСЂРі ${money(totals.debt)}`} />}
        {canSeeFinance && <Info label="РЎРѕР±С–РІР°СЂС‚С–СЃС‚СЊ" value={showCost ? money(totals.cost) : 'РџСЂРёС…РѕРІР°РЅРѕ РїСЂР°РІР°РјРё РґРѕСЃС‚СѓРїСѓ'} />}
        <Info label="РљРѕРЅС‚СЂРѕР»СЊ СЃС‚СЂРѕРєС–РІ" value={`РЈ СЃС‚Р°С‚СѓСЃС– ${statusAge} РґРЅ. В· Р· РїСЂРёР№РѕРјСѓ ${totalAge} РґРЅ. В· РѕР±С–С†СЏРЅРѕ ${selectedOrder.promisedDate}`} />
      </div>
      <div className="linear-status">
        {['РџСЂРёР№РЅСЏС‚Рѕ', 'РќР° РґС–Р°РіРЅРѕСЃС‚РёС†С–', 'РћС‡С–РєСѓС” РїРѕРіРѕРґР¶РµРЅРЅСЏ', 'Р’ СЂРµРјРѕРЅС‚С–', 'Р“РѕС‚РѕРІРёР№ РґРѕ РІРёРґР°С‡С–', 'Р’РёРґР°РЅРѕ', 'Р—Р°РєСЂРёС‚Рѕ'].map((status) => (
          <span key={status} className={selectedOrder.status === status ? 'linear-status-active' : ''}>{status}</span>
        ))}
      </div>
      <section className="qr-panel">
        <div>
          <h3>QR-РєРѕРґ Р·Р°РјРѕРІР»РµРЅРЅСЏ</h3>
          <p>РЎРєР°РЅ РІС–РґРєСЂРёРІР°С” РєР°СЂС‚РєСѓ {selectedOrder.id} РЅР°РїСЂСЏРјСѓ. QR РґСЂСѓРєСѓС”С‚СЊСЃСЏ РЅР° РєРІРёС‚Р°РЅС†С–С— С‚Р° РјРѕР¶Рµ РєР»РµС—С‚РёСЃСЏ РЅР° С‚РµС…РЅС–РєСѓ.</p>
          <strong>{directOrderUrl}</strong>
        </div>
        <img
          alt={`QR ${selectedOrder.id}`}
          src={`https://api.qrserver.com/v1/create-qr-code/?size=132x132&data=${encodeURIComponent(directOrderUrl)}`}
        />
      </section>
      {canSendApproval && <section className="panel-subsection approval-panel">
        <div className="panel-heading">
          <h2>РЎРѕРіР»Р°СЃСѓРІР°РЅРЅСЏ</h2>
          <span>{approval?.status ?? 'РќРµ РІС–РґРїСЂР°РІР»РµРЅРѕ'}</span>
        </div>
        <div className="details-grid">
          <Info label="РЎСѓРјР° РґР»СЏ РєР»С–С”РЅС‚Р°" value={approval ? money(approval.totalAmount) : money(totals.total)} />
          <Info label="Р’С–РґРїСЂР°РІР»РµРЅРѕ" value={approval ? `${approval.sentAt} В· ${approval.sentChannel}` : 'Р©Рµ РЅРµ РІС–РґРїСЂР°РІР»РµРЅРѕ'} />
          <Info label="Р’С–РґРїРѕРІС–РґСЊ" value={approval?.responseAt ? `${approval.responseAt} В· ${approval.responseIp}` : 'РќРµРјР°С” РІС–РґРїРѕРІС–РґС–'} />
        </div>
        {approval && (
          <div className="approval-card">
            <div>
              <strong>РЎС‚РѕСЂС–РЅРєР° РєР»С–С”РЅС‚Р°</strong>
              <p>{approval.clientUrl}</p>
            </div>
            <div>
              <strong>Р—Р°С„С–РєСЃРѕРІР°РЅРѕ РІ РїСЂРѕРїРѕР·РёС†С–С—</strong>
              <p>{approval.worksSnapshot.length} СЂРѕР±С–С‚ В· {approval.partsSnapshot.length} Р·Р°РїС‡Р°СЃС‚РёРЅ В· {money(approval.totalAmount)}</p>
            </div>
          </div>
        )}
        <div className="action-row">
          <button type="button" onClick={() => sendRepairApproval(selectedOrder, 'Telegram')}>Р’С–РґРїСЂР°РІРёС‚Рё РЅР° РїРѕРіРѕРґР¶РµРЅРЅСЏ</button>
          <button type="button" onClick={() => sendRepairApproval(selectedOrder, 'SMS')}>РџРѕРІС‚РѕСЂРёС‚Рё РІС–РґРїСЂР°РІРєСѓ</button>
          <button type="button" onClick={() => approval && recordApprovalResponse(approval.id, true, true)} disabled={!approval}>Р—Р°С„С–РєСЃСѓРІР°С‚Рё РІСЂСѓС‡РЅСѓ</button>
          <button type="button" onClick={() => approval && markApprovalNoAnswer(approval.id)} disabled={!approval || approval.status !== 'РћС‡С–РєСѓС” РІС–РґРїРѕРІС–РґСЊ'}>РќРµРјР°С” РІС–РґРїРѕРІС–РґС–</button>
          <button type="button" onClick={() => approval && recordApprovalResponse(approval.id, false, true)} disabled={!approval}>Р’С–РґРјРѕРІР°</button>
        </div>
        {approval && (
          <div className="client-approval-preview">
            <h3>РЎС‚РѕСЂС–РЅРєР° РґР»СЏ РєР»С–С”РЅС‚Р°</h3>
            <p>{approval.device}</p>
            <p>{approval.issue}</p>
            <div className="table approval-table">
              <div className="table-row table-head"><span>РџРѕР·РёС†С–СЏ</span><span>РљС–Р»СЊРєС–СЃС‚СЊ</span><span>РЎСѓРјР°</span></div>
              {approval.worksSnapshot.map((work) => <div className="table-row" key={work.name}><span>{work.name}<small>{work.serviceType}</small></span><span>{work.qty ?? 1}</span><span>{money(work.price * (work.qty ?? 1))}</span></div>)}
              {approval.partsSnapshot.map((part) => <div className="table-row" key={part.name}><span>{part.name}</span><span>{part.qty}</span><span>{money(part.price * part.qty)}</span></div>)}
            </div>
            <strong>Р”Рѕ РїРѕРіРѕРґР¶РµРЅРЅСЏ: {money(approval.totalAmount)} В· СЃС‚СЂРѕРє {approval.promisedDate}</strong>
          </div>
        )}
      </section>}
      <section className="process-panel">
        <div className="panel-heading">
          <h2>РњР°СЂС€СЂСѓС‚ СЂРµРјРѕРЅС‚Сѓ</h2>
          <span>Р“РѕР»РѕРІРЅС– РґС–С— Р±РµР· СЃРєР»Р°РґРЅРёС… СЃРїРёСЃРєС–РІ</span>
        </div>
        <div className="simple-action-panel">
          {activeUser.role === 'Р†РЅР¶РµРЅРµСЂ' && (
            <button type="button" onClick={() => acceptOrderWork(selectedOrder)} disabled={selectedOrder.engineer !== activeUser.name || Boolean(selectedOrder.engineerAcceptedAt)}>Р’Р·СЏС‚Рё РІ СЂРѕР±РѕС‚Сѓ</button>
          )}
          {activeUser.role === 'Р†РЅР¶РµРЅРµСЂ' && (
            <button type="button" onClick={() => changeOrderStatus(selectedOrder, 'РћС‡С–РєСѓС” РїРѕРіРѕРґР¶РµРЅРЅСЏ', 'Р”С–Р°РіРЅРѕСЃС‚РёРєСѓ Р·Р°РІРµСЂС€РµРЅРѕ, РїРѕС‚СЂС–Р±РЅРµ РїРѕРіРѕРґР¶РµРЅРЅСЏ РєР»С–С”РЅС‚Р°.')} disabled={!nextStatuses.includes('РћС‡С–РєСѓС” РїРѕРіРѕРґР¶РµРЅРЅСЏ') || !roleCanSetOrderStatus(activeUser.role, 'РћС‡С–РєСѓС” РїРѕРіРѕРґР¶РµРЅРЅСЏ')}>Р—Р°РІРµСЂС€РёС‚Рё РґС–Р°РіРЅРѕСЃС‚РёРєСѓ</button>
          )}
          {activeUser.role === 'Р†РЅР¶РµРЅРµСЂ' && (
            <button type="button" onClick={() => changeOrderStatus(selectedOrder, 'РћС‡С–РєСѓС” Р·Р°РїС‡Р°СЃС‚РёРЅСѓ', 'Р†РЅР¶РµРЅРµСЂ РІРєР°Р·Р°РІ, С‰Рѕ РїРѕС‚СЂС–Р±РЅР° Р·Р°РєСѓРїРєР° Р·Р°РїС‡Р°СЃС‚РёРЅРё.')} disabled={!selectedOrder.parts.length || !roleCanSetOrderStatus(activeUser.role, 'РћС‡С–РєСѓС” Р·Р°РїС‡Р°СЃС‚РёРЅСѓ')}>РџРѕС‚СЂС–Р±РЅРѕ Р·Р°РєСѓРїРёС‚Рё</button>
          )}
          {activeUser.role === 'Р†РЅР¶РµРЅРµСЂ' && (
            <button type="button" onClick={() => changeOrderStatus(selectedOrder, 'РќР° С‚РµСЃС‚СѓРІР°РЅРЅС–', 'Р†РЅР¶РµРЅРµСЂ РїРµСЂРµРґР°РІ РїСЂРёСЃС‚СЂС–Р№ РЅР° С‚РµСЃС‚СѓРІР°РЅРЅСЏ.')} disabled={!nextStatuses.includes('РќР° С‚РµСЃС‚СѓРІР°РЅРЅС–') || !roleCanSetOrderStatus(activeUser.role, 'РќР° С‚РµСЃС‚СѓРІР°РЅРЅС–')}>РџРµСЂРµРґР°С‚Рё РЅР° С‚РµСЃС‚</button>
          )}
          {canSendApproval && <button type="button" onClick={() => sendRepairApproval(selectedOrder, 'Telegram')}>Р’С–РґРїСЂР°РІРёС‚Рё РЅР° РїРѕРіРѕРґР¶РµРЅРЅСЏ</button>}
          <button type="button" onClick={() => changeOrderStatus(selectedOrder, 'Р“РѕС‚РѕРІРёР№ РґРѕ РІРёРґР°С‡С–', 'РўРµСЃС‚СѓРІР°РЅРЅСЏ РїСЂРѕР№РґРµРЅРѕ, РїСЂРёСЃС‚СЂС–Р№ РіРѕС‚РѕРІРёР№.')} disabled={!nextStatuses.includes('Р“РѕС‚РѕРІРёР№ РґРѕ РІРёРґР°С‡С–') || !roleCanSetOrderStatus(activeUser.role, 'Р“РѕС‚РѕРІРёР№ РґРѕ РІРёРґР°С‡С–')}>Р“РѕС‚РѕРІРѕ</button>
          {activeUser.role !== 'Р†РЅР¶РµРЅРµСЂ' && canIssueOrder && <button type="button" onClick={() => issueReadyOrder(selectedOrder)}>Р’РёРґР°С‚Рё Р·Р°РјРѕРІР»РµРЅРЅСЏ</button>}
          <button type="button" onClick={() => changeOrderStatus(selectedOrder, 'РќРµ РїС–РґР»СЏРіР°С” СЂРµРјРѕРЅС‚Сѓ', 'РџСЂРёС‡РёРЅР°: СЂРµРјРѕРЅС‚ С‚РµС…РЅС–С‡РЅРѕ Р°Р±Рѕ РµРєРѕРЅРѕРјС–С‡РЅРѕ РЅРµРјРѕР¶Р»РёРІРёР№.')} disabled={!roleCanSetOrderStatus(activeUser.role, 'РќРµ РїС–РґР»СЏРіР°С” СЂРµРјРѕРЅС‚Сѓ') || ['Р—Р°РєСЂРёС‚Рѕ', 'Р’РёРґР°РЅРѕ', 'РЎРєР°СЃРѕРІР°РЅРѕ'].includes(selectedOrder.status)}>РќРµ РїС–РґР»СЏРіР°С” СЂРµРјРѕРЅС‚Сѓ</button>
        </div>
      </section>
      {activeUser.role === 'РњРµРЅРµРґР¶РµСЂ' && ['Р“РѕС‚РѕРІРёР№ РґРѕ РІРёРґР°С‡С–', 'РќРµ РїС–РґР»СЏРіР°С” СЂРµРјРѕРЅС‚Сѓ', 'РћС‡С–РєСѓС” РѕРїР»Р°С‚Рё', 'РћС‡С–РєСѓС” РєР»С–С”РЅС‚Р°'].includes(selectedOrder.status) && (
        <section className="panel-subsection">
          <div className="panel-heading">
            <h2>Р РѕР±РѕС‚Р° РјРµРЅРµРґР¶РµСЂР° РїС–СЃР»СЏ РіРѕС‚РѕРІРЅРѕСЃС‚С–</h2>
            <span>{paymentStatus} В· Р±РѕСЂРі {money(totals.debt)}</span>
          </div>
          <div className="action-row">
            <button type="button" onClick={() => sendClientNotification(selectedOrder, 'Р“РѕС‚РѕРІРѕ РґРѕ РІРёРґР°С‡С–', 'SMS', true)}>РџРѕРІС–РґРѕРјРёС‚Рё РєР»С–С”РЅС‚Р°</button>
            <button type="button" onClick={() => recordOrderPayment('РћРїР»Р°С‚Р° РїРµСЂРµРґ РІРёРґР°С‡РµСЋ')} disabled={!canDo('finance.payments') || totals.debt <= 0}>РџСЂРёР№РЅСЏС‚Рё РѕРїР»Р°С‚Сѓ</button>
            {canIssueOrder && <button type="button" onClick={() => issueReadyOrder(selectedOrder)}>Р’РёРґР°С‚Рё Р·Р°РјРѕРІР»РµРЅРЅСЏ</button>}
          </div>
        </section>
      )}
      {canManageDocuments && (
        <section className="panel-subsection">
          <div className="panel-heading">
            <h2>Р”РѕРєСѓРјРµРЅС‚Рё, РѕРїР»Р°С‚Р° С– BAS</h2>
            <span>С‚С–Р»СЊРєРё РїРѕС‚СЂС–Р±РЅС– РєРЅРѕРїРєРё</span>
          </div>
          {totals.debt > 0 && (
            <div className="action-row payment-actions">
              <input aria-label="РЎСѓРјР° РѕРїР»Р°С‚Рё" type="number" min={1} max={totals.debt || undefined} placeholder={String(totals.debt)} value={paymentAmount || ''} onChange={(event) => setPaymentAmount(Number(event.target.value))} />
              <select aria-label="РўРёРї РѕРїР»Р°С‚Рё" value={paymentMethod} onChange={(event) => setPaymentMethod(event.target.value as PaymentMethod)}>
                <option value="Р“РѕС‚С–РІРєР°">Р“РѕС‚С–РІРєР°</option>
                <option value="РљР°СЂС‚РєР°">РљР°СЂС‚РєР°</option>
                <option value="Р‘РµР·РіРѕС‚С–РІРєР°">Р‘РµР·РіРѕС‚С–РІРєР°</option>
              </select>
              <button type="button" onClick={() => recordOrderPayment(paymentMethod === 'Р‘РµР·РіРѕС‚С–РІРєР°' ? 'Р‘РµР·РіРѕС‚С–РІРєРѕРІР° РѕРїР»Р°С‚Р°' : 'РћРїР»Р°С‚Р° СЂРµРјРѕРЅС‚Сѓ')} disabled={!canDo('finance.payments')}>РџСЂРёР№РЅСЏС‚Рё РѕРїР»Р°С‚Сѓ</button>
              {!isReadyForClient && <button type="button" onClick={() => addOrderPayment(selectedOrder, Math.min(500, totals.debt || 500), 'Р“РѕС‚С–РІРєР°', 'РџРµСЂРµРґРїР»Р°С‚Р°')} disabled={!canDo('finance.payments')}>РџСЂРёР№РЅСЏС‚Рё РїРµСЂРµРґРїР»Р°С‚Сѓ</button>}
            </div>
          )}
          <div className="action-row secondary-actions">
            {canFormActAndInvoice && !hasDocument('РђРєС‚ РЅР°РґР°РЅРЅСЏ РїРѕСЃР»СѓРі') && <button type="button" onClick={() => printDocument('РђРєС‚ РЅР°РґР°РЅРЅСЏ РїРѕСЃР»СѓРі', 'service_order', selectedOrder.id, selectedOrder.client)}>РЎС„РѕСЂРјСѓРІР°С‚Рё Р°РєС‚</button>}
            {canFormActAndInvoice && !hasDocument('Р Р°С…СѓРЅРѕРє РЅР° РѕРїР»Р°С‚Сѓ') && <button type="button" onClick={() => printDocument('Р Р°С…СѓРЅРѕРє РЅР° РѕРїР»Р°С‚Сѓ', 'service_order', selectedOrder.id, selectedOrder.client)}>РЎС„РѕСЂРјСѓРІР°С‚Рё СЂР°С…СѓРЅРѕРє</button>}
            {canCreateDeliveryNote && !hasDocument('Р’РёРґР°С‚РєРѕРІР° РЅР°РєР»Р°РґРЅР°') && <button type="button" onClick={() => printDocument('Р’РёРґР°С‚РєРѕРІР° РЅР°РєР»Р°РґРЅР°', 'service_order', selectedOrder.id, selectedOrder.client)}>РЎС‚РІРѕСЂРёС‚Рё РІРёРґР°С‚РєРѕРІСѓ</button>}
            {canFormTechnicalAct && !hasDocument('РђРєС‚ С‚РµС…РЅС–С‡РЅРѕРіРѕ СЃС‚Р°РЅСѓ') && <button type="button" onClick={() => printDocument('РђРєС‚ С‚РµС…РЅС–С‡РЅРѕРіРѕ СЃС‚Р°РЅСѓ', 'service_order', selectedOrder.id, selectedOrder.client)}>РЎС„РѕСЂРјСѓРІР°С‚Рё Р°РєС‚ С‚РµС…РЅС–С‡РЅРѕРіРѕ СЃС‚Р°РЅСѓ</button>}
            {canTransferBas && <button type="button" onClick={() => transferOrderToBas(selectedOrder)}>РџРµСЂРµРґР°С‚Рё РІ BAS</button>}
            {!canFormActAndInvoice && !canFormTechnicalAct && !canCreateDeliveryNote && totals.debt <= 0 && <div className="empty-state">РќР° С†СЊРѕРјСѓ РµС‚Р°РїС– Р·Р°Р№РІС– РґРѕРєСѓРјРµРЅС‚Рё РїСЂРёС…РѕРІР°РЅС–. РќР°СЃС‚СѓРїРЅС– РєРЅРѕРїРєРё Р·КјСЏРІР»СЏС‚СЊСЃСЏ РїС–СЃР»СЏ РіРѕС‚РѕРІРЅРѕСЃС‚С–, РІС–РґРјРѕРІРё Р°Р±Рѕ РїРѕСЏРІРё С‚РѕРІР°СЂРЅРёС… РїРѕР·РёС†С–Р№.</div>}
          </div>
        </section>
      )}
      {canSeeFinance && <section className="panel-subsection">
        <div className="panel-heading"><h2>РћРїР»Р°С‚Рё Р·Р°РєР°Р·Р°</h2><span>РІРёРґР°Р»РµРЅРЅСЏ С– Р·РјС–РЅР° Р·Р°РґРЅС–Рј С‡РёСЃР»РѕРј Р·Р°Р±РѕСЂРѕРЅРµРЅС–</span></div>
        <div className="table payments-table">
          <div className="table-row table-head"><span>Р”Р°С‚Р°</span><span>РЎСѓРјР°</span><span>РўРёРї</span><span>РЎС‚Р°С‚СѓСЃ</span><span>РўСЂР°РЅР·Р°РєС†С–СЏ</span><span>РЎРїС–РІСЂРѕР±С–С‚РЅРёРє</span></div>
          {selectedOrder.payments.map((payment) => (
            <div className="table-row" key={payment.id}>
              <span>{payment.date}</span>
              <span>{money(payment.amount)}</span>
              <span>{payment.method}<small>{payment.type}</small></span>
              <span>{payment.status ?? 'РџС–РґС‚РІРµСЂРґР¶РµРЅРѕ'}{payment.confirmedBy ? <small>{payment.confirmedBy} В· {payment.confirmedAt}</small> : null}</span>
              <span>{payment.transactionNo}</span>
              <span>{payment.acceptedBy}</span>
            </div>
          ))}
          {selectedOrder.payments.length === 0 && <div className="empty-state">РћРїР»Р°С‚ С‰Рµ РЅРµРјР°С”. РћРїР»Р°С‚Р° РґРѕРґР°С”С‚СЊСЃСЏ С‚С–Р»СЊРєРё С‚СѓС‚, Сѓ РєР°СЂС‚С†С– Р·Р°РєР°Р·Р°.</div>}
        </div>
      </section>}
      <section className="panel-subsection">
        <div className="panel-heading"><h2>РљРѕРјРµРЅС‚Р°СЂС–</h2><span>РєРѕСЂРѕС‚РєРѕ РїРѕ СЃСѓС‚С–</span></div>
        <div className="task-list">
          <Task icon={<ClipboardList />} title="РџСЂРѕР±Р»РµРјР° РєР»С–С”РЅС‚Р°" text={selectedOrder.issue} />
          <Task icon={<Wrench />} title="Р”С–Р°РіРЅРѕСЃС‚РёРєР°" text={selectedOrder.diagnosisResult ?? 'Р©Рµ РЅРµ Р·Р°РїРѕРІРЅРµРЅРѕ'} />
          <Task icon={<CheckCircle2 />} title="РўРµСЃС‚ / СЂРµР·СѓР»СЊС‚Р°С‚" text={selectedOrder.testResult ?? selectedOrder.clientComment ?? 'РљРѕРјРµРЅС‚Р°СЂС–РІ РїРѕРєРё РЅРµРјР°С”'} />
        </div>
      </section>
      <section className="panel-subsection">
        <div className="panel-heading">
          <h2>РџРѕРІС–РґРѕРјР»РµРЅРЅСЏ РєР»С–С”РЅС‚Сѓ</h2>
          <span>{notifications.length ? `${notifications[0].status} В· ${notifications[0].channel}` : 'С‰Рµ РЅРµ РЅР°РґСЃРёР»Р°Р»Рё'}</span>
        </div>
        <div className="action-row">
          <button type="button" onClick={() => sendClientNotification(selectedOrder, 'Р“РѕС‚РѕРІРѕ РґРѕ РІРёРґР°С‡С–', 'SMS', true)}>Р’С–РґРїСЂР°РІРёС‚Рё РїРѕРІС–РґРѕРјР»РµРЅРЅСЏ</button>
          <button type="button" onClick={() => sendClientNotification(selectedOrder, 'РќР°РіР°РґСѓРІР°РЅРЅСЏ', 'Telegram', true)}>РџРѕРІС‚РѕСЂРёС‚Рё СѓРІРµРґРѕРјР»РµРЅРЅСЏ</button>
        </div>
        <div className="task-list">
          {notifications.slice(0, 4).map((message) => (
            <Task key={message.id} icon={<Bell />} title={`${message.event} В· ${message.channel} В· ${message.status}`} text={`${message.createdAt}. ${message.message}${message.error ? ` РџРѕРјРёР»РєР°: ${message.error}` : ''}`} />
          ))}
          {notifications.length === 0 && <div className="empty-state">CRM Р°РІС‚РѕРјР°С‚РёС‡РЅРѕ СЃС‚РІРѕСЂРёС‚СЊ SMS Р°Р±Рѕ Telegram-РїРѕРІС–РґРѕРјР»РµРЅРЅСЏ РїСЂРё Р·РјС–РЅС– СЃС‚Р°С‚СѓСЃСѓ: РїСЂРёР№РѕРј, РґС–Р°РіРЅРѕСЃС‚РёРєР°, РїРѕРіРѕРґР¶РµРЅРЅСЏ, Р·Р°РїС‡Р°СЃС‚РёРЅР°, РіРѕС‚РѕРІРЅС–СЃС‚СЊ, РІРёРґР°С‡Р°.</div>}
        </div>
      </section>
      <section className="panel-subsection">
        <div className="panel-heading"><h2>Р†СЃС‚РѕСЂС–СЏ СЃС‚Р°С‚СѓСЃС–РІ</h2><span>{selectedOrder.statusHistory.length} Р·Р°РїРёСЃС–РІ</span></div>
        <div className="task-list">
          {selectedOrder.statusHistory.slice(0, 6).map((entry) => (
            <Task key={entry.id} icon={<History />} title={`${entry.oldStatus ?? 'РЎС‚Р°СЂС‚'} -> ${entry.newStatus}`} text={`${entry.changedAt} В· ${entry.changedBy}. ${entry.comment}`} />
          ))}
        </div>
      </section>
      <div className="panel-heading parts-heading">
        <h2>Р—Р°РїС‡Р°СЃС‚РёРЅРё РІ СЂРµРјРѕРЅС‚С–</h2>
        {canDo('repairs.close') && <button className="primary-action" type="button" onClick={() => issueReadyOrder(selectedOrder)}>Р—Р°РєСЂРёС‚Рё С– РІРёРґР°С‚Рё</button>}
      </div>
      {canAddParts && (
        <div className="inline-part-form">
          <select value={selectedProductId} onChange={(event) => setSelectedProductId(event.target.value)} aria-label="Р—Р°РїС‡Р°СЃС‚РёРЅР°">
            {products.map((product) => <option key={product.id} value={product.id}>{product.name} В· РґРѕСЃС‚СѓРїРЅРѕ {available(product)}</option>)}
          </select>
          <input aria-label="РљС–Р»СЊРєС–СЃС‚СЊ" type="number" min={1} value={qty} onChange={(event) => setQty(Number(event.target.value))} />
          <button className="submit-button" type="button" onClick={addPartToRepair}>Р”РѕРґР°С‚Рё Р·Р°РїС‡Р°СЃС‚РёРЅСѓ</button>
        </div>
      )}
      <div className="repair-parts">
        {selectedOrder.parts.length === 0 && <div className="empty-state">Р—Р°РїС‡Р°СЃС‚РёРЅРё С‰Рµ РЅРµ РґРѕРґР°РЅС–.</div>}
        {selectedOrder.parts.map((part) => {
          const product = products.find((item) => item.id === part.productId);
          return (
            <article className="repair-part-card" key={part.id}>
              <div>
                <strong>{product?.name}</strong>
                <p>{part.qty} С€С‚.{canSeeFinance ? ` В· СЃРѕР±С–РІР°СЂС‚С–СЃС‚СЊ ${showCost ? money(part.cost * part.qty) : 'РїСЂРёС…РѕРІР°РЅРѕ'} В· РїСЂРѕРґР°Р¶ ${money(part.price * part.qty)}` : ' В· С„С–РЅР°РЅСЃРё РїСЂРёС…РѕРІР°РЅРѕ'}</p>
              </div>
              <span className={statusClass[part.status]}>{part.status}</span>
              <div className="action-row">
                <button type="button" onClick={() => orderPart(selectedOrder, part)} disabled={!canDo('purchases.create') || !['РџРѕС‚СЂС–Р±РЅРѕ', 'Р”Рѕ Р·Р°РєСѓРїС–РІР»С–'].includes(part.status)}>Р—Р°РјРѕРІРёС‚Рё Р·Р°РїС‡Р°СЃС‚РёРЅСѓ</button>
                <button type="button" onClick={() => reserveArrived(selectedOrder, part)} disabled={!canDo('stock.reserve') || part.status !== 'РџСЂРёР±СѓР»Рѕ'}>Р—Р°СЂРµР·РµСЂРІСѓРІР°С‚Рё</button>
                <button type="button" onClick={() => issueToEngineer(selectedOrder, part)} disabled={!canDo('stock.writeoff') || part.status !== 'Р—Р°СЂРµР·РµСЂРІРѕРІР°РЅРѕ'}>Р’РёРґР°С‚Рё С–РЅР¶РµРЅРµСЂСѓ</button>
                <button type="button" onClick={() => markInstalled(selectedOrder, part)} disabled={!canDo('repairs.status') || part.status !== 'Р’РёРґР°РЅРѕ С–РЅР¶РµРЅРµСЂСѓ'}>Р’С–РґРјС–С‚РёС‚Рё РІСЃС‚Р°РЅРѕРІР»РµРЅРѕСЋ</button>
                <button type="button" onClick={() => returnServicePart(selectedOrder, part, 'РќР° СЃРєР»Р°Рґ')} disabled={!canDo('stock.unreserve') || !['Р—Р°СЂРµР·РµСЂРІРѕРІР°РЅРѕ', 'Р’РёРґР°РЅРѕ С–РЅР¶РµРЅРµСЂСѓ', 'Р’СЃС‚Р°РЅРѕРІР»РµРЅРѕ'].includes(part.status)}>РџРѕРІРµСЂРЅСѓС‚Рё РІ СЃРµСЂРІС–СЃС–</button>
                <button type="button" onClick={() => returnServicePart(selectedOrder, part, 'Р‘СЂР°Рє')} disabled={!canDo('stock.writeoff') || !['Р’РёРґР°РЅРѕ С–РЅР¶РµРЅРµСЂСѓ', 'Р’СЃС‚Р°РЅРѕРІР»РµРЅРѕ'].includes(part.status)}>РЎРїРёСЃР°С‚Рё РІ Р±СЂР°Рє</button>
              </div>
            </article>
          );
        })}
      </div>
    </section>
  );
}

function SalesPage(props: {
  sales: Sale[];
  selectedSale: Sale;
  products: Product[];
  selectedSaleId: string;
  setSelectedSaleId: (id: string) => void;
  selectedSaleProductId: string;
  setSelectedSaleProductId: (id: string) => void;
  saleQty: number;
  setSaleQty: (qty: number) => void;
  addSaleItem: () => void;
  reserveSale: (sale: Sale) => void;
  acceptSalePayment: (sale: Sale, amount: number, method: PaymentMethod, comment: string) => void;
  issueSale: (sale: Sale) => void;
  returnSale: (sale: Sale) => void;
  cancelSale: (sale: Sale) => void;
  printDocument: (kind: DocumentKind, entityType: PrintDocument['entityType'], entityId: string, clientOrSupplier: string) => void;
  canDo: (permission: Permission) => boolean;
  showCost: boolean;
  showProfit: boolean;
}) {
  const totals = saleTotals(props.selectedSale);
  const [showSaleMore, setShowSaleMore] = useState(false);
  const [saleScanCode, setSaleScanCode] = useState('');
  const scannedSaleProduct = props.products.find((product) => product.barcode === saleScanCode.trim() || product.sku.toLowerCase() === saleScanCode.trim().toLowerCase());
  return (
    <div className="page-grid">
      <PageTitle eyebrow="РџСЂРѕРґР°Р¶С–" title="РџСЂРѕРґР°Р¶ в†’ СЂРµР·РµСЂРІ в†’ РѕРїР»Р°С‚Р° в†’ РІРёРґР°С‡Р° в†’ СЃРїРёСЃР°РЅРЅСЏ" text="РўРѕРІР°СЂ СЃРїРёСЃСѓС”С‚СЊСЃСЏ С‚С–Р»СЊРєРё РїС–СЃР»СЏ РїС–РґС‚РІРµСЂРґР¶РµРЅРѕС— РІРёРґР°С‡С–. Р”Рѕ С†СЊРѕРіРѕ РІС–РЅ Р°Р±Рѕ РІ С‡РµСЂРЅРµС‚С†С–, Р°Р±Рѕ РІ СЂРµР·РµСЂРІС–." />
      <section className="content-split orders-layout">
        <div className="panel">
          <div className="panel-heading"><h2>РџСЂРѕРґР°Р¶С–</h2><span>{props.sales.length} РґРѕРєСѓРјРµРЅС‚С–РІ</span></div>
          <div className="order-list">
            {props.sales.map((sale) => {
              const saleInfo = saleTotals(sale);
              return (
                <button type="button" className={props.selectedSaleId === sale.id ? 'order-card order-card-active' : 'order-card'} key={sale.id} onClick={() => props.setSelectedSaleId(sale.id)}>
                  <div className="order-main">
                    <div>
                      <div className="order-title"><strong>{sale.id}</strong><span className={statusClass[sale.status]}>{sale.status}</span></div>
                      <h3>{sale.client}</h3>
                      <p>{sale.manager} В· {sale.date}</p>
                    </div>
                    <div className="order-price"><strong>{money(saleInfo.total)}</strong><span>Р±РѕСЂРі {money(saleInfo.debt)}</span></div>
                  </div>
                </button>
              );
            })}
          </div>
        </div>
        <div className="panel order-form">
          <div className="panel-heading"><h2>Р”РѕРґР°С‚Рё С‚РѕРІР°СЂ</h2></div>
          <label>
            РЎРєР°РЅРµСЂ С€С‚СЂРёС…-РєРѕРґСѓ
            <input
              value={saleScanCode}
              placeholder="РЎРєР°РЅСѓР№С‚Рµ barcode Р°Р±Рѕ РІРІРµРґС–С‚СЊ Р°СЂС‚РёРєСѓР»"
              onChange={(event) => {
                const code = event.target.value;
                setSaleScanCode(code);
                const product = props.products.find((item) => item.barcode === code.trim() || item.sku.toLowerCase() === code.trim().toLowerCase());
                if (product) props.setSelectedSaleProductId(product.id);
              }}
            />
            <small>{scannedSaleProduct ? `Р—РЅР°Р№РґРµРЅРѕ: ${scannedSaleProduct.name}` : 'РЎРєР°РЅРµСЂ РїСЂР°С†СЋС” СЏРє РєР»Р°РІС–Р°С‚СѓСЂР°: РЅР°РІРµРґС–С‚СЊ РєСѓСЂСЃРѕСЂ Сѓ РїРѕР»Рµ С– СЃРєР°РЅСѓР№С‚Рµ.'}</small>
          </label>
          <label>
            РўРѕРІР°СЂ
            <select value={props.selectedSaleProductId} onChange={(event) => props.setSelectedSaleProductId(event.target.value)}>
              {props.products.map((product) => <option key={product.id} value={product.id}>{product.name} В· РґРѕСЃС‚СѓРїРЅРѕ {available(product)}</option>)}
            </select>
          </label>
          <label>
            РљС–Р»СЊРєС–СЃС‚СЊ
            <input type="number" min={1} value={props.saleQty} onChange={(event) => props.setSaleQty(Number(event.target.value))} />
          </label>
          <button className="submit-button" type="button" onClick={props.addSaleItem} disabled={!props.canDo('sales.create')}>Р”РѕРґР°С‚Рё С‚РѕРІР°СЂ</button>
        </div>
      </section>

      <section className="panel">
        <div className="panel-heading">
          <h2>{props.selectedSale.id} В· {props.selectedSale.client}</h2>
          <span className={statusClass[props.selectedSale.status]}>{props.selectedSale.status}</span>
        </div>
        <div className="details-grid">
          <Info label="РњРµРЅРµРґР¶РµСЂ" value={props.selectedSale.manager} />
          <Info label="Р”Р°С‚Р°" value={props.selectedSale.date} />
          <Info label="РџРѕРІ'СЏР·Р°РЅРёР№ СЂРµРјРѕРЅС‚" value={props.selectedSale.serviceOrderId ?? "РќРµ РїСЂРёРІ'СЏР·Р°РЅРѕ"} />
        </div>
        <section className="stats-grid">
          <Metric icon={<Banknote />} label="РЎСѓРјР° РїСЂРѕРґР°Р¶Сѓ" value={money(totals.total)} hint={`Р·РЅРёР¶РєР° ${money(totals.discount)}`} />
          <Metric icon={<CheckCircle2 />} label="РћРїР»Р°С‡РµРЅРѕ" value={money(totals.paid)} hint={`Р±РѕСЂРі ${money(totals.debt)}`} />
          <Metric icon={<Archive />} label="РЎРѕР±С–РІР°СЂС‚С–СЃС‚СЊ" value={props.showCost ? money(totals.cost) : 'РџСЂРёС…РѕРІР°РЅРѕ'} hint="РїС–СЃР»СЏ РІРёРґР°С‡С–" />
          <Metric icon={<PackageCheck />} label="РџСЂРёР±СѓС‚РѕРє" value={props.showProfit ? money(totals.profit) : 'РџСЂРёС…РѕРІР°РЅРѕ'} hint="Р· СѓСЂР°С…СѓРІР°РЅРЅСЏРј РїРѕРІРµСЂРЅРµРЅСЊ" />
        </section>
        <div className="repair-parts">
          {props.selectedSale.items.length === 0 && <div className="empty-state">Р”РѕРґР°Р№С‚Рµ С‚РѕРІР°СЂ Сѓ РїСЂРѕРґР°Р¶.</div>}
          {props.selectedSale.items.map((item) => {
            const product = props.products.find((entry) => entry.id === item.productId);
            return (
              <article className="repair-part-card" key={item.id}>
                <div>
                  <strong>{product?.name}</strong>
                  <p>{item.qty} С€С‚. В· С†С–РЅР° {money(item.price)} В· СЃРѕР±С–РІР°СЂС‚С–СЃС‚СЊ {props.showCost ? money(item.cost) : 'РїСЂРёС…РѕРІР°РЅРѕ'} В· Р·РЅРёР¶РєР° {money(item.discount)}</p>
                </div>
                <span className={statusClass[item.status === 'Р§РµСЂРЅРµС‚РєР°' ? 'Р§РµСЂРЅРµС‚РєР°' : item.status === 'РЎРєР°СЃРѕРІР°РЅРѕ' ? 'РЎРєР°СЃРѕРІР°РЅРѕ' : item.status === 'РџРѕРІРµСЂРЅРµРЅРЅСЏ' ? 'РџРѕРІРµСЂРЅРµРЅРЅСЏ' : item.status === 'Р’РёРґР°РЅРѕ' ? 'Р’РёРґР°РЅРѕ' : 'Р—Р°СЂРµР·РµСЂРІРѕРІР°РЅРѕ']}>{item.status}</span>
              </article>
            );
          })}
        </div>
        <div className="action-row payment-actions">
          <button type="button" onClick={() => props.reserveSale(props.selectedSale)} disabled={!props.canDo('stock.reserve')}>Р—Р°СЂРµР·РµСЂРІСѓРІР°С‚Рё</button>
          <button type="button" onClick={() => props.acceptSalePayment(props.selectedSale, totals.debt, 'Р“РѕС‚С–РІРєР°', 'РћРїР»Р°С‚Р° РіРѕС‚С–РІРєРѕСЋ')} disabled={!props.canDo('finance.payments')}>РџСЂРёР№РЅСЏС‚Рё РѕРїР»Р°С‚Сѓ</button>
          <button type="button" onClick={() => props.issueSale(props.selectedSale)} disabled={!props.canDo('sales.post')}>Р’РёРґР°С‚Рё С‚РѕРІР°СЂ</button>
          <button type="button" onClick={() => props.printDocument('РўРѕРІР°СЂРЅРёР№ С‡РµРє', 'sale', props.selectedSale.id, props.selectedSale.client)}>РЎС„РѕСЂРјСѓРІР°С‚Рё С‡РµРє</button>
          <button className="ghost-toggle compact-toggle" type="button" onClick={() => setShowSaleMore((value) => !value)}>{showSaleMore ? 'РЎС…РѕРІР°С‚Рё РґРѕРґР°С‚РєРѕРІС– РґС–С—' : 'РџРѕРєР°Р·Р°С‚Рё С‰Рµ'}</button>
        </div>
        {showSaleMore && <div className="action-row secondary-actions">
          <button type="button" onClick={() => props.acceptSalePayment(props.selectedSale, totals.debt, 'РљР°СЂС‚РєР°', 'РћРїР»Р°С‚Р° РєР°СЂС‚РєРѕСЋ')} disabled={!props.canDo('finance.payments')}>РџСЂРѕРІРµСЃС‚Рё РѕРїР»Р°С‚Сѓ РєР°СЂС‚РєРѕСЋ</button>
          <button type="button" onClick={() => props.acceptSalePayment(props.selectedSale, Math.max(Math.round(totals.debt / 2), 1), 'Р“РѕС‚С–РІРєР°', 'Р§Р°СЃС‚РєРѕРІР° РѕРїР»Р°С‚Р°')} disabled={!props.canDo('finance.payments')}>Р’С–РґРјС–С‚РёС‚Рё С‡Р°СЃС‚РєРѕРІСѓ РѕРїР»Р°С‚Сѓ</button>
          <button type="button" onClick={() => props.printDocument('РќР°РєР»Р°РґРЅР° РїСЂРѕРґР°Р¶Сѓ', 'sale', props.selectedSale.id, props.selectedSale.client)}>РЎС„РѕСЂРјСѓРІР°С‚Рё РЅР°РєР»Р°РґРЅСѓ</button>
          {props.selectedSale.items.length > 0 && <button type="button" onClick={() => props.printDocument('Р’РёРґР°С‚РєРѕРІР° РЅР°РєР»Р°РґРЅР°', 'sale', props.selectedSale.id, props.selectedSale.client)}>РЎС‚РІРѕСЂРёС‚Рё РІРёРґР°С‚РєРѕРІСѓ</button>}
          <button type="button" onClick={() => props.returnSale(props.selectedSale)} disabled={!props.canDo('sales.return') || !props.canDo('finance.refund')}>Р—СЂРѕР±РёС‚Рё РїРѕРІРµСЂРЅРµРЅРЅСЏ</button>
          <button type="button" onClick={() => props.cancelSale(props.selectedSale)} disabled={!props.canDo('sales.cancel')}>РЎРєР°СЃСѓРІР°С‚Рё РїСЂРѕРґР°Р¶</button>
        </div>}
        <div className="panel-heading parts-heading"><h2>РџР»Р°С‚РµР¶С–</h2><span>{props.selectedSale.payments.length} РѕРїРµСЂР°С†С–Р№</span></div>
        <div className="task-list">
          {props.selectedSale.payments.length === 0 && <div className="empty-state">РћРїР»Р°С‚ С‰Рµ РЅРµРјР°С”.</div>}
          {props.selectedSale.payments.map((payment) => (
            <Task key={payment.id} icon={<Banknote />} title={`${payment.type} В· ${payment.method} В· ${money(payment.amount)}`} text={`РўСЂР°РЅР·Р°РєС†С–СЏ: ${payment.transactionNo}. РџСЂРёР№РЅСЏРІ: ${payment.acceptedBy}. ${payment.comment}`} />
          ))}
        </div>
      </section>
    </div>
  );
}

function PartsPage({ products, requirements, productName, showCost }: { products: Product[]; requirements: PartRequirement[]; productName: (id: string) => string; showCost: boolean }) {
  const [stockScanCode, setStockScanCode] = useState('');
  const scannedProduct = products.find((product) => product.barcode === stockScanCode.trim() || product.sku.toLowerCase() === stockScanCode.trim().toLowerCase());
  return (
    <div className="page-grid">
      <PageTitle eyebrow="РЎРєР»Р°Рґ" title="Р РµР°Р»СЊРЅС– Р·Р°Р»РёС€РєРё С‚Р° РїРѕС‚СЂРµР±Рё" text="Р—Р°Р»РёС€РѕРє РЅРµ Р·РјС–РЅСЋС”С‚СЊСЃСЏ РЅР°РїСЂСЏРјСѓ. Р РµР·РµСЂРІРё, РІРёРґР°С‡С–, РїСЂРёС…РѕРґРё Р№ СЃРїРёСЃР°РЅРЅСЏ СЃС‚РІРѕСЂСЋСЋС‚СЊСЃСЏ РґРѕРєСѓРјРµРЅС‚Р°РјРё." />
      <section className="panel">
        <div className="panel-heading"><h2>РЎРєР°РЅРµСЂ С€С‚СЂРёС…-РєРѕРґСѓ</h2><span>barcode / Р°СЂС‚РёРєСѓР»</span></div>
        <label>
          РЎРєР°РЅСѓР№С‚Рµ С‚РѕРІР°СЂ
          <input value={stockScanCode} placeholder="РќР°РїСЂРёРєР»Р°Рґ 4820001115008 Р°Р±Рѕ SSD-KIN-500" onChange={(event) => setStockScanCode(event.target.value)} />
          <small>USB-СЃРєР°РЅРµСЂ РїСЂР°С†СЋС” СЏРє РєР»Р°РІС–Р°С‚СѓСЂР°. РџРѕСЃС‚Р°РІС‚Рµ РєСѓСЂСЃРѕСЂ Сѓ РїРѕР»Рµ С– СЃРєР°РЅСѓР№С‚Рµ РµС‚РёРєРµС‚РєСѓ.</small>
        </label>
        {scannedProduct && (
          <div className="scan-result">
            <strong>{scannedProduct.name}</strong>
            <span>{scannedProduct.sku} В· barcode {scannedProduct.barcode} В· РґРѕСЃС‚СѓРїРЅРѕ {available(scannedProduct)} С€С‚. В· РїР°СЂС‚С–Р№ {scannedProduct.batches.length}</span>
          </div>
        )}
      </section>
      <section className="panel">
        <div className="table stock-table">
          <div className="table-row table-head"><span>Р—Р°РїС‡Р°СЃС‚РёРЅР°</span><span>Р”РѕСЃС‚СѓРїРЅРѕ</span><span>Р РµР·РµСЂРІ</span><span>РЈ С–РЅР¶РµРЅРµСЂР°</span><span>РџР°СЂС‚С–С— FIFO</span><span>Barcode</span></div>
          {products.map((product) => (
            <div className="table-row" key={product.id}>
              <span>{product.name}<small>{product.sku} В· {product.category}</small></span>
              <span className={available(product) <= product.min ? 'stock-warning' : ''}>{available(product)} С€С‚.</span>
              <span>{product.reserved} С€С‚.</span>
              <span>{product.withEngineer} С€С‚.</span>
              <span>{product.batches.length}<small>{oldestBatchAge(product) > 60 ? `С” РїР°СЂС‚С–СЏ ${oldestBatchAge(product)} РґРЅ.` : `РЅР°Р№СЃС‚Р°СЂС€Р° ${oldestBatchAge(product)} РґРЅ.`}</small></span>
              <span>{product.barcode}<small>{showCost ? `РјС–РЅ. ${product.min} В· ${money(product.cost)}` : `РјС–РЅ. ${product.min}`}</small></span>
            </div>
          ))}
        </div>
      </section>
      <section className="panel">
        <div className="panel-heading"><h2>РџР°СЂС‚С–С— С‚РѕРІР°СЂС–РІ</h2><span>FIFO-СЃРїРёСЃР°РЅРЅСЏ Р±РµР· СЂСѓС‡РЅРѕРіРѕ РІРёР±РѕСЂСѓ</span></div>
        <div className="task-list">
          {products.map((product) => (
            <Task
              key={product.id}
              icon={<Archive />}
              title={`${product.name} В· РІСЃСЊРѕРіРѕ ${batchTotalAvailable(product)} С€С‚.`}
              text={product.batches.length
                ? product.batches
                  .map((batch) => `${batch.id}: ${batch.qtyAvailable}/${batch.qtyTotal} С€С‚. В· ${money(batch.purchasePrice)} В· ${batch.purchaseDate}${daysSince(batch.purchaseDate) > 60 ? ` В· Р»РµР¶РёС‚СЊ ${daysSince(batch.purchaseDate)} РґРЅ.` : ''}`)
                  .join(' | ')
                : 'РџР°СЂС‚С–Р№ С‰Рµ РЅРµРјР°С”, С‚РѕРІР°СЂ РЅРµ Р·Р°РєСѓРїРѕРІСѓРІР°РІСЃСЏ.'}
            />
          ))}
        </div>
      </section>
      <section className="panel">
        <div className="panel-heading"><h2>РџРѕС‚СЂРµР±Рё С–Р· СЂРµРјРѕРЅС‚С–РІ</h2><span>{requirements.length} РїРѕР·РёС†С–Р№</span></div>
        <div className="task-list">
          {requirements.map((req) => <Task key={req.id} icon={<PackagePlus />} title={`${productName(req.productId)} В· ${req.qty} С€С‚.`} text={`${req.orderId} В· СЃС‚Р°С‚СѓСЃ: ${req.status}`} />)}
        </div>
      </section>
    </div>
  );
}

function PurchasesPage({ purchases, receipts, productName, movePurchase, receivePurchase, printDocument, canDo }: { purchases: PurchaseOrder[]; receipts: GoodsReceipt[]; productName: (id: string) => string; movePurchase: (id: string) => void; receivePurchase: (id: string) => void; printDocument: (kind: DocumentKind, entityType: PrintDocument['entityType'], entityId: string, clientOrSupplier: string) => void; canDo: (permission: Permission) => boolean }) {
  return (
    <div className="page-grid">
      <PageTitle eyebrow="Р—Р°РєСѓРїС–РІР»С–" title="Р©Рѕ Р·Р°РјРѕРІР»РµРЅРѕ С– С‰Рѕ РІ РґРѕСЂРѕР·С–" text="Р—Р°РєСѓРїРєР° РїРѕРІ'СЏР·Р°РЅР° С–Р· РїРѕС‚СЂРµР±РѕСЋ С‚Р° СЃРµСЂРІС–СЃРЅРёРј Р·Р°РјРѕРІР»РµРЅРЅСЏРј. РџСЂРёС…С–Рґ СЃС‚РІРѕСЂСЋС” РґРѕРєСѓРјРµРЅС‚ С– СЂСѓС… СЃРєР»Р°РґСѓ." />
      <section className="cards-grid purchase-grid">
        {purchases.length === 0 && <div className="panel empty-state">РџРѕРєРё РЅРµРјР°С” Р·Р°РєСѓРїС–РІРµР»СЊ. Р”РѕРґР°Р№С‚Рµ РІ СЂРµРјРѕРЅС‚ Р·Р°РїС‡Р°СЃС‚РёРЅСѓ, СЏРєРѕС— РЅРµРјР°С” РЅР° СЃРєР»Р°РґС–.</div>}
        {purchases.map((purchase) => (
          <article className="purchase-card" key={purchase.id}>
            <div className="panel-heading"><h2>{purchase.id}</h2><span className={statusClass[purchase.status]}>{purchase.status}</span></div>
            <p>{purchase.supplier} В· РѕС‡С–РєСѓС”С‚СЊСЃСЏ {purchase.expectedAt}</p>
            {purchase.items.map((item) => <p key={item.productId}>{productName(item.productId)} В· {item.qty} С€С‚. В· СЂРµРјРѕРЅС‚ {item.orderId}</p>)}
            <div className="action-row">
              <button type="button" onClick={() => movePurchase(purchase.id)} disabled={!canDo('purchases.status') || purchase.status !== 'Р—Р°РјРѕРІР»РµРЅРѕ'}>РџРѕР·РЅР°С‡РёС‚Рё "Р’ РґРѕСЂРѕР·С–"</button>
              <button type="button" onClick={() => receivePurchase(purchase.id)} disabled={!canDo('stock.receive') || purchase.status === 'РџСЂРёР±СѓР»Рѕ'}>РћРїСЂРёР±СѓС‚РєСѓРІР°С‚Рё</button>
              <button type="button" onClick={() => printDocument('РџСЂРёС…С–РґРЅР° РЅР°РєР»Р°РґРЅР°', 'purchase_order', purchase.id, purchase.supplier)}>РџРµС‡Р°С‚СЊ РїСЂРёС…РѕРґРЅРѕС— РЅР°РєР»Р°РґРЅРѕС—</button>
            </div>
          </article>
        ))}
      </section>
      <section className="panel">
        <div className="panel-heading"><h2>РџСЂРёС…РѕРґРё РЅР° СЃРєР»Р°Рґ</h2><span>{receipts.length} РґРѕРєСѓРјРµРЅС‚С–РІ</span></div>
        <div className="task-list">
          {receipts.map((receipt) => <Task key={receipt.id} icon={<Truck />} title={`${receipt.id} В· ${productName(receipt.productId)}`} text={`${receipt.qty} С€С‚. В· ${money(receipt.price)} В· Р·Р°РєСѓРїС–РІР»СЏ ${receipt.purchaseId}`} />)}
        </div>
      </section>
    </div>
  );
}

function CashPage({ orders, sales, cashShift, activeUser, confirmBankPayment }: { orders: ServiceOrder[]; sales: Sale[]; cashShift: CashShift; activeUser: User; confirmBankPayment: (paymentId: string) => void }) {
  const salePayments = sales.flatMap((sale) => sale.payments.map((payment) => ({ ...payment, client: sale.client, document: sale.id })));
  const orderPayments = orders.flatMap((order) => order.payments.map((payment) => ({ ...payment, client: order.client, document: order.id })));
  const payments = [...salePayments, ...orderPayments].sort((a, b) => b.date.localeCompare(a.date));

  return (
    <div className="page-grid">
      <PageTitle eyebrow="РћРїР»Р°С‚Рё / РљР°СЃР°" title="РљР°СЃР°, С‚РµСЂРјС–РЅР°Р», Р±РµР·РіРѕС‚С–РІРєР° С– РїРѕРІРµСЂРЅРµРЅРЅСЏ РєРѕС€С‚С–РІ" text="РћРєСЂРµРјРёР№ СЂРѕР±РѕС‡РёР№ РµРєСЂР°РЅ Р±СѓС…РіР°Р»С‚РµСЂР° Р№ РјРµРЅРµРґР¶РµСЂР° РґР»СЏ РєРѕРЅС‚СЂРѕР»СЋ РѕРїР»Р°С‚, РєР°СЃРѕРІРѕС— Р·РјС–РЅРё С‚Р° РїРѕРІРµСЂРЅРµРЅСЊ." />
      <section className="stats-grid">
        <Metric icon={<Banknote />} label="Р“РѕС‚С–РІРєР°" value={money(cashShift.cashIncome)} hint="РїСЂРёС…С–Рґ Сѓ РєР°СЃСѓ" />
        <Metric icon={<CheckCircle2 />} label="РљР°СЂС‚РєР°" value={money(cashShift.cardIncome)} hint="С‚РµСЂРјС–РЅР°Р»" />
        <Metric icon={<Archive />} label="Р‘РµР·РіРѕС‚С–РІРєР°" value={money(cashShift.bankIncome)} hint="РїРµСЂРµРєР°Р·Рё" />
        <Metric icon={<PackageCheck />} label="РџРѕРІРµСЂРЅРµРЅРЅСЏ" value={money(cashShift.cashExpense)} hint="РІРёРґР°РЅРѕ РєР»С–С”РЅС‚Р°Рј" />
      </section>
      <section className="quick-actions">
        <button type="button">РћРїР»Р°С‚Р° С‚С–Р»СЊРєРё РІ РєР°СЂС‚С†С– Р·Р°РєР°Р·Р°</button>
        <button type="button">РџРѕРІРµСЂРЅРµРЅРЅСЏ РєРѕС€С‚С–РІ</button>
        <button type="button">Р’С–РґРєСЂРёС‚Рё Р·РјС–РЅСѓ</button>
        <button type="button">Р—Р°РєСЂРёС‚Рё Р·РјС–РЅСѓ</button>
      </section>
      <section className="panel">
        <div className="panel-heading"><h2>РўРµСЂРјС–РЅР°Р»</h2><span>РµС‚Р°Рї 1</span></div>
        <div className="task-list">
          <Task icon={<CheckCircle2 />} title="РљР°СЂС‚РєР° С‡РµСЂРµР· С‚РµСЂРјС–РЅР°Р»" text="РњРµРЅРµРґР¶РµСЂ С„С–РєСЃСѓС” РѕРїР»Р°С‚Сѓ РєР°СЂС‚РєРѕСЋ, СЃСѓРјСѓ С– РЅРѕРјРµСЂ С‚СЂР°РЅР·Р°РєС†С–С—. РЎРїРёСЃР°РЅРЅСЏ С‚РѕРІР°СЂСѓ РІСЃРµ РѕРґРЅРѕ РІС–РґР±СѓРІР°С”С‚СЊСЃСЏ С‚С–Р»СЊРєРё РїС–СЃР»СЏ РІРёРґР°С‡С–." />
          <Task icon={<Banknote />} title="Р РѕР·РґС–Р»СЊРЅР° РєР°СЃР°" text={`Р“РѕС‚С–РІРєР°: ${money(cashShift.cashIncome - cashShift.cashExpense)}. РљР°СЂС‚РєР°: ${money(cashShift.cardIncome)}. Р‘РµР·РіРѕС‚С–РІРєР°: ${money(cashShift.bankIncome)}.`} />
        </div>
      </section>
      <section className="panel">
        <div className="panel-heading"><h2>Р–СѓСЂРЅР°Р» РєР°СЃРё</h2><span>{payments.length} РѕРїРµСЂР°С†С–Р№</span></div>
        <div className="table payments-table">
          <div className="table-row table-head"><span>Р”Р°С‚Р°</span><span>РљР»С–С”РЅС‚</span><span>Р—Р°РєР°Р·</span><span>РЎСѓРјР°</span><span>РўРёРї</span><span>РЎС‚Р°С‚СѓСЃ</span><span>РЎРїС–РІСЂРѕР±С–С‚РЅРёРє</span></div>
          {payments.map((payment) => (
            <div className="table-row" key={payment.id}>
              <span>{payment.date}</span>
              <span>{payment.client}</span>
              <span>{payment.document}</span>
              <span>{money(payment.amount)}</span>
              <span>{payment.method}<small>{payment.transactionNo}</small></span>
              <span>{payment.status ?? 'РџС–РґС‚РІРµСЂРґР¶РµРЅРѕ'}{payment.status === 'РћС‡С–РєСѓС” РїС–РґС‚РІРµСЂРґР¶РµРЅРЅСЏ' && activeUser.role === 'Р‘СѓС…РіР°Р»С‚РµСЂ' ? <button type="button" onClick={() => confirmBankPayment(payment.id)}>РџС–РґС‚РІРµСЂРґРёС‚Рё</button> : null}</span>
              <span>{payment.acceptedBy}</span>
            </div>
          ))}
        </div>
      </section>
    </div>
  );
}

function ReturnsPage({ sales, orders, products, productName }: { sales: Sale[]; orders: ServiceOrder[]; products: Product[]; productName: (id: string) => string }) {
  const saleReturns = sales.flatMap((sale) => sale.returns.map((item) => ({ id: item.id, source: sale.id, client: sale.client, product: productName(item.productId), qty: item.qty, amount: item.refund, reason: item.reason, decision: item.destination })));
  const serviceReturns = orders.flatMap((order) => order.parts.filter((part) => part.status === 'РџРѕРІРµСЂРЅРµРЅРЅСЏ').map((part) => ({ id: part.id, source: order.id, client: order.client, product: productName(part.productId), qty: part.qty, amount: part.price * part.qty, reason: 'Р”РµС‚Р°Р»СЊ РЅРµ РїС–РґС–Р№С€Р»Р° Р°Р±Рѕ Р·РЅСЏС‚Р° Р· СЂРµРјРѕРЅС‚Сѓ', decision: 'РЎРµСЂРІС–СЃРЅРµ РїРѕРІРµСЂРЅРµРЅРЅСЏ' })));
  const rows = [...saleReturns, ...serviceReturns];
  const defectCandidates = products.filter((product) => product.installed > 0 || product.withEngineer > 0);

  return (
    <div className="page-grid">
      <PageTitle eyebrow="РџРѕРІРµСЂРЅРµРЅРЅСЏ" title="РџРѕРІРµСЂРЅРµРЅРЅСЏ РїРѕ РїСЂРѕРґР°Р¶Р°С… С– СЂРµРјРѕРЅС‚Р°С…" text="Р’ РѕРґРЅРѕРјСѓ РјС–СЃС†С– РІРёРґРЅРѕ РїСЂРёС‡РёРЅСѓ РїРѕРІРµСЂРЅРµРЅРЅСЏ, СЃСѓРјСѓ, РґРѕРєСѓРјРµРЅС‚-РґР¶РµСЂРµР»Рѕ С– СЂС–С€РµРЅРЅСЏ РїРѕ С‚РѕРІР°СЂСѓ: СЃРєР»Р°Рґ Р°Р±Рѕ Р±СЂР°Рє." />
      <section className="stats-grid">
        <Metric icon={<PackageCheck />} label="РџРѕРІРµСЂРЅРµРЅСЊ" value={String(rows.length)} hint="РїСЂРѕРґР°Р¶С– + СЃРµСЂРІС–СЃ" />
        <Metric icon={<Banknote />} label="РЎСѓРјР° РїРѕРІРµСЂРЅРµРЅСЊ" value={money(rows.reduce((sum, item) => sum + item.amount, 0))} hint="РґРѕ РєРѕРЅС‚СЂРѕР»СЋ Р±СѓС…РіР°Р»С‚РµСЂРѕРј" />
        <Metric icon={<Archive />} label="РљР°РЅРґРёРґР°С‚Рё РІ Р±СЂР°Рє" value={String(defectCandidates.length)} hint="РїРѕС‚СЂРµР±СѓСЋС‚СЊ СЂС–С€РµРЅРЅСЏ" />
      </section>
      <section className="panel">
        <div className="panel-heading"><h2>Р–СѓСЂРЅР°Р» РїРѕРІРµСЂРЅРµРЅСЊ</h2><span>{rows.length} Р·Р°РїРёСЃС–РІ</span></div>
        <div className="table returns-table">
          <div className="table-row table-head"><span>Р”РѕРєСѓРјРµРЅС‚</span><span>РљР»С–С”РЅС‚</span><span>РўРѕРІР°СЂ</span><span>Рљ-СЃС‚СЊ</span><span>РЎСѓРјР°</span><span>Р С–С€РµРЅРЅСЏ</span></div>
          {rows.map((item) => (
            <div className="table-row" key={item.id}>
              <span>{item.source}</span>
              <span>{item.client}</span>
              <span>{item.product}</span>
              <span>{item.qty}</span>
              <span>{money(item.amount)}</span>
              <span>{item.decision}</span>
            </div>
          ))}
        </div>
        {rows.length === 0 && <div className="empty-state">РџРѕРІРµСЂРЅРµРЅСЊ РїРѕРєРё РЅРµРјР°С”.</div>}
      </section>
    </div>
  );
}

function DocumentsPage({ documents, templates }: { documents: PrintDocument[]; templates: Array<{ kind: DocumentKind; description: string; lockedRule: string }> }) {
  const sampleOrder = initialOrders[1] ?? initialOrders[0];
  const sampleTotals = orderTotals(sampleOrder);
  const sampleVat = documentVatTotals(sampleTotals.total);
  const sampleClient = clientDetails(sampleOrder.client, sampleOrder.phone);
  const sampleProductName = (productId: string) => initialProducts.find((product) => product.id === productId)?.name ?? productId;
  return (
    <div className="page-grid">
      <PageTitle eyebrow="Р”РѕРєСѓРјРµРЅС‚Рё" title="PDF, РґСЂСѓРє С– СЋСЂРёРґРёС‡РЅРёР№ Р°СЂС…С–РІ" text="РљРІРёС‚Р°РЅС†С–С—, Р°РєС‚Рё, С‡РµРєРё, РЅР°РєР»Р°РґРЅС– С‚Р° РїРѕРІРµСЂРЅРµРЅРЅСЏ СЃС‚РІРѕСЂСЋСЋС‚СЊСЃСЏ Р· РєР°СЂС‚РѕРє Р·Р°РјРѕРІР»РµРЅСЊ, РїСЂРѕРґР°Р¶С–РІ С– Р·Р°РєСѓРїС–РІРµР»СЊ. РљРѕР¶РµРЅ РґРѕРєСѓРјРµРЅС‚ РјР°С” РІРµСЂСЃС–СЋ, Р°РІС‚РѕСЂР°, PDF-С€Р»СЏС… С– Р·РІКјСЏР·РѕРє Р· РґРѕРєСѓРјРµРЅС‚РѕРј-РґР¶РµСЂРµР»РѕРј." />
      <section className="stats-grid">
        <Metric icon={<ClipboardList />} label="Р”РѕРєСѓРјРµРЅС‚С–РІ" value={String(documents.length)} hint="Р·Р±РµСЂРµР¶РµРЅС– PDF" />
        <Metric icon={<ShieldCheck />} label="РЁР°Р±Р»РѕРЅС–РІ" value={String(templates.length)} hint="РґР»СЏ СЂРµРјРѕРЅС‚Сѓ, РїСЂРѕРґР°Р¶Сѓ, СЃРєР»Р°РґСѓ" />
        <Metric icon={<History />} label="Р’РµСЂСЃС–Р№РЅС–СЃС‚СЊ" value="РЈРІС–РјРєРЅРµРЅРѕ" hint="РїС–РґРїРёСЃР°РЅС– РґРѕРєСѓРјРµРЅС‚Рё Р±Р»РѕРєСѓСЋС‚СЊСЃСЏ" />
        <Metric icon={<CheckCircle2 />} label="РђРІС‚РѕР·РІКјСЏР·РѕРє" value="Р„" hint="Р·Р°РјРѕРІР»РµРЅРЅСЏ, РїСЂРѕРґР°Р¶, Р·Р°РєСѓРїРєР°" />
      </section>
      <section className="content-split">
        <div className="panel document-preview">
          <div className="panel-heading"><h2>Р Р°С…СѓРЅРѕРє РЅР° РѕРїР»Р°С‚Сѓ</h2><span>РѕС„С–С†С–Р№РЅРёР№ Р±Р»Р°РЅРє</span></div>
          <div className="official-document">
            <h3>Р РђРҐРЈРќРћРљ РќРђ РћРџР›РђРўРЈ в„– Р РҐ-1001</h3>
            <p>РІС–Рґ {today}</p>
            <div className="details-grid">
              <Info label="РџРѕСЃС‚Р°С‡Р°Р»СЊРЅРёРє" value={`${companyRequisites.name}, Р„Р”Р РџРћРЈ ${companyRequisites.edrpou}, ${companyRequisites.iban}, ${companyRequisites.bank}`} />
              <Info label="РџРѕРєСѓРїРµС†СЊ" value={`${sampleClient.name}, Р„Р”Р РџРћРЈ ${sampleClient.edrpou}, ${sampleClient.address}`} />
              <Info label="Р”РѕРіРѕРІС–СЂ" value={sampleClient.contract} />
              <Info label="РЎСѓРјР° РїСЂРѕРїРёСЃСЊСЋ" value={amountInWordsUA(sampleVat.amountGross)} />
            </div>
