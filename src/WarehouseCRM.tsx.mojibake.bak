              <Info label="РЈСЃСЊРѕРіРѕ Р· РџР”Р’" value={money(sampleVat.amountGross)} />
              <Info label="РџСЂРµС‚РµРЅР·С–С—" value="РЎС‚РѕСЂРѕРЅРё РїСЂРµС‚РµРЅР·С–Р№ С‰РѕРґРѕ РѕР±СЃСЏРіСѓ, СЏРєРѕСЃС‚С– С‚Р° СЃС‚СЂРѕРєС–РІ РЅР°РґР°РЅРЅСЏ РїРѕСЃР»СѓРі РЅРµ РјР°СЋС‚СЊ." />
              <Info label="Р РµРєРІС–Р·РёС‚Рё РІРёРєРѕРЅР°РІС†СЏ" value={`${companyRequisites.name}, Р„Р”Р РџРћРЈ ${companyRequisites.edrpou}, ${companyRequisites.address}`} />
              <Info label="Р РµРєРІС–Р·РёС‚Рё Р·Р°РјРѕРІРЅРёРєР°" value={`${sampleClient.name}, Р„Р”Р РџРћРЈ ${sampleClient.edrpou}, ${sampleClient.address}`} />
            </div>
            <p>РџС–РґРїРёСЃРё СЃС‚РѕСЂС–РЅ: Р’РёРєРѕРЅР°РІРµС†СЊ ____________ / Р—Р°РјРѕРІРЅРёРє ____________</p>
          </div>
        </div>
      </section>
      <section className="content-split">
