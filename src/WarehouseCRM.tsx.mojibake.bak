        <div className="panel"><h2>РЈРІРµРґРѕРјР»РµРЅРЅСЏ РєР»С–С”РЅС‚Р°Рј</h2><div className="task-list">{clientNotificationTemplates.slice(0, 4).map((template) => <Task key={`${template.event}-${template.channel}`} icon={<Bell />} title={`${template.event} В· ${template.channel}`} text={`${template.enabled ? 'РЈРІС–РјРєРЅРµРЅРѕ' : 'Р’РёРјРєРЅРµРЅРѕ'}: ${template.text}`} />)}</div></div>
