        </div>
      </section>
      <section className="panel">
        <div className="panel-heading"><h2>РђСЂС…С–С‚РµРєС‚СѓСЂР°</h2><span>С†С–Р»СЊРѕРІРёР№ Р·Р°РїСѓСЃРє</span></div>
        <div className="task-list">
          <Task icon={<CheckCircle2 />} title="Р’РµР±-РґРѕСЃС‚СѓРї" text="CRM РјР°С” РїСЂР°С†СЋРІР°С‚Рё С‡РµСЂРµР· Р±СЂР°СѓР·РµСЂ Р· РѕС„С–СЃСѓ, РІС–РґРґР°Р»РµРЅРѕ С– Р· С‚РµР»РµС„РѕРЅР°." />
          <Task icon={<Archive />} title="РћРґРЅР° Р±Р°Р·Р°" text="РЈСЃС– РєРѕСЂРёСЃС‚СѓРІР°С‡С– РїСЂР°С†СЋСЋС‚СЊ РІ РѕРґРЅС–Р№ PostgreSQL Р±Р°Р·С– РЅР° VPS Р°Р±Рѕ cloud." />
          <Task icon={<ShieldCheck />} title="Р—Р°С…РёСЃС‚" text="HTTPS, Р»РѕРіС–РЅ/РїР°СЂРѕР»СЊ, СЂРѕР»С–, СЃРµСЃС–С—, Р¶СѓСЂРЅР°Р» РґС–Р№ С– С‰РѕРґРµРЅРЅРµ СЂРµР·РµСЂРІРЅРµ РєРѕРїС–СЋРІР°РЅРЅСЏ." />
        </div>
